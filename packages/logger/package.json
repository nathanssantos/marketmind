{
  "name": "@marketmind/logger",
  "version": "0.50.0",
  "description": "Unified logging infrastructure for MarketMind",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit",
    "dev": "tsc --watch --preserveWatchOutput"
  },
  "dependencies": {
    "@marketmind/types": "workspace:*",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  }
}
