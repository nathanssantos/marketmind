{
  "name": "@marketmind/ml",
  "version": "0.2.0",
  "description": "Machine Learning package for MarketMind trading predictions",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@marketmind/indicators": "workspace:*",
    "@marketmind/types": "workspace:*"
  },
  "optionalDependencies": {
    "onnxruntime-node": "^1.20.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  },
  "keywords": [
    "machine-learning",
    "trading",
    "prediction",
    "crypto",
    "feature-extraction",
    "onnx"
  ],
  "author": "MarketMind Team",
  "license": "MIT"
}
