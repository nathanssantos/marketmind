{
  "name": "@marketmind/trading-core",
  "version": "0.1.0",
  "description": "Shared trading logic and calculations for MarketMind",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@marketmind/types": "workspace:*",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
}
