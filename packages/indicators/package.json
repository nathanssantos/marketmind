{
  "name": "@marketmind/indicators",
  "version": "0.52.1",
  "description": "Technical analysis indicators for MarketMind",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench": "vitest bench",
    "test:mutation": "stryker run",
    "test:mutation:incremental": "stryker run --incremental"
  },
  "dependencies": {
    "@marketmind/fibonacci": "workspace:*",
    "@marketmind/types": "workspace:*"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^9.4.0",
    "@stryker-mutator/typescript-checker": "^9.4.0",
    "@stryker-mutator/vitest-runner": "^9.4.0",
    "fast-check": "^4.5.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  }
}
