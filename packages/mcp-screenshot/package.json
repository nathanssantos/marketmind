{
  "name": "@marketmind/mcp-screenshot",
  "version": "1.0.0",
  "description": "MCP server that drives a Playwright browser against the MarketMind dev server and captures screenshots of any tab/modal/sidebar.",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "mm-mcp-screenshot": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "type-check": "tsc --noEmit"
  },
  "mcp": {
    "env": {
      "MM_MCP_BASE_URL": "http://localhost:5174"
    }
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "playwright": "^1.60.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "tsx": "^4.21.0",
    "typescript": "5.9.3"
  }
}
