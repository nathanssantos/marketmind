{
  "name": "@marketmind/types",
  "version": "0.52.0",
  "description": "Shared TypeScript types for MarketMind",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
