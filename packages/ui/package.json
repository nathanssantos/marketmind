{
  "name": "@marketmind/ui",
  "version": "0.1.0",
  "description": "MarketMind UI primitives (Tier-1 + Tier-2 + select Tier-3) shared across the renderer and any future surface. Extracted in v1.6 per docs/UI_EXTRACTION_PLAN.md. Renamed from the working name 'ui-core' once the API stabilized.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@chakra-ui/react": "^3.35.0",
    "@emotion/react": "^11.14.0",
    "@marketmind/tokens": "workspace:*",
    "@marketmind/utils": "workspace:*",
    "next-themes": "^0.4.6",
    "react-icons": "^5.6.0",
    "recharts": "^3.8.1"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "typescript": "^6.0.3"
  }
}
