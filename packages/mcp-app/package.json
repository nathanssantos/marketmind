{
  "name": "@marketmind/mcp-app",
  "version": "1.0.0",
  "description": "MCP server that drives the live MarketMind dev app — open settings/modals, navigate symbols, dispatch UI actions, inspect/dispatch stores.",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "mm-mcp-app": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "type-check": "tsc --noEmit"
  },
  "mcp": {
    "env": {
      "MM_MCP_BASE_URL": "http://localhost:5174"
    }
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "playwright": "^1.49.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.2",
    "typescript": "5.9.3"
  }
}
