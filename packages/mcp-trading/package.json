{
  "name": "@marketmind/mcp-trading",
  "version": "1.0.0",
  "description": "MCP server that exposes trading read tools (and, in follow-up PRs, write tools gated by per-wallet agentTradingEnabled). Every call is audited via the backend mcp.recordAudit endpoint.",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "mm-mcp-trading": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "type-check": "tsc --noEmit"
  },
  "mcp": {
    "env": {
      "MM_MCP_TRPC_URL": "http://localhost:3001/trpc"
    }
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "tsx": "^4.21.0",
    "typescript": "5.9.3"
  }
}
