{
  "name": "@marketmind/mcp-strategy",
  "version": "1.0.0",
  "description": "MCP server for power users — list/export/create Pine strategies and run backtests through the live backend.",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "mm-mcp-strategy": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "type-check": "tsc --noEmit"
  },
  "mcp": {
    "env": {
      "MM_MCP_TRPC_URL": "http://localhost:3001/trpc"
    }
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.2",
    "typescript": "5.9.3"
  }
}
