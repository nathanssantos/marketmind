{
  "name": "@marketmind/mcp-backend",
  "version": "1.0.0",
  "description": "MCP server that exposes a read-only DB query layer + tRPC bridge against the running MarketMind backend.",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "mm-mcp-backend": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "type-check": "tsc --noEmit"
  },
  "mcp": {
    "env": {
      "DATABASE_URL": "postgres://postgres:postgres@localhost:5432/marketmind",
      "MM_MCP_TRPC_URL": "http://localhost:3001/trpc"
    }
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "@types/pg": "^8.20.0",
    "tsx": "^4.21.0",
    "typescript": "5.9.3"
  }
}
