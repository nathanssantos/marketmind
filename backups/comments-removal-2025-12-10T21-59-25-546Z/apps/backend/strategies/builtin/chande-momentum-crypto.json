{
  "id": "chande-momentum-crypto",
  "name": "Chande Momentum Crypto",
  "version": "1.0.0",
  "description": "Chande Momentum Oscillator (CMO) strategy. CMO mede força de momentum entre -100 e +100. Entry em níveis extremos ou cruzamentos zero.",
  "author": "MarketMind",
  "tags": [
    "momentum",
    "cmo",
    "chande",
    "oscillator"
  ],
  "source": "Tushar Chande - CMO Creator",
  "status": "active",
  "optimizedParams": {
    "maxPositionSize": 70,
    "maxConcurrentPositions": 2,
    "maxTotalExposure": 80,
    "useAlgorithmicLevels": true,
    "useTrailingStop": false,
    "onlyWithTrend": false,
    "minConfidence": 65,
    "commission": 0.001
  },
  "recommendedTimeframes": {
    "primary": "1d",
    "secondary": [
      "4h"
    ],
    "avoid": [
      "1m",
      "5m"
    ],
    "notes": "CMO works best on daily"
  },
  "parameters": {
    "cmoPeriod": {
      "default": 14,
      "min": 9,
      "max": 21,
      "step": 1,
      "description": "Período do CMO"
    },
    "oversold": {
      "default": -50,
      "min": -60,
      "max": -40,
      "step": 5,
      "description": "Nível oversold"
    },
    "overbought": {
      "default": 50,
      "min": 40,
      "max": 60,
      "step": 5,
      "description": "Nível overbought"
    },
    "atrMultiplier": {
      "default": 2,
      "min": 1.5,
      "max": 3,
      "step": 0.5,
      "description": "ATR para stop"
    }
  },
  "indicators": {
    "cmo": {
      "type": "cmo",
      "params": {
        "period": "$cmoPeriod"
      }
    },
    "atr": {
      "type": "atr",
      "params": {
        "period": 14
      }
    }
  },
  "entry": {
    "long": {
      "operator": "AND",
      "conditions": [
        {
          "left": "cmo",
          "op": "crossover",
          "right": "$oversold"
        }
      ]
    },
    "short": {
      "operator": "AND",
      "conditions": [
        {
          "left": "cmo",
          "op": "crossunder",
          "right": "$overbought"
        }
      ]
    }
  },
  "exit": {
    "stopLoss": {
      "type": "atr",
      "multiplier": "$atrMultiplier",
      "indicator": "atr"
    },
    "takeProfit": {
      "type": "riskReward",
      "multiplier": 2
    },
    "conditions": {
      "long": {
        "operator": "OR",
        "conditions": [
          {
            "left": "cmo",
            "op": ">",
            "right": "$overbought"
          }
        ]
      },
      "short": {
        "operator": "OR",
        "conditions": [
          {
            "left": "cmo",
            "op": "<",
            "right": "$oversold"
          }
        ]
      }
    }
  },
  "confidence": {
    "base": 65,
    "bonuses": [
      {
        "condition": {
          "left": "cmo",
          "op": "<",
          "right": -70
        },
        "bonus": 10,
        "description": "Extremely oversold"
      },
      {
        "condition": {
          "left": "volume",
          "op": ">",
          "right": "volume.sma20"
        },
        "bonus": 5,
        "description": "Volume confirms"
      }
    ],
    "max": 85
  },
  "filters": {
    "minConfidence": 65,
    "minRiskReward": 1.5
  }
}
