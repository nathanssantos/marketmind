{
  "id": "stochrsi-momentum",
  "name": "StochRSI Momentum",
  "version": "1.0.0",
  "description": "Estratégia baseada em Stochastic RSI. Backtestada com 78% win rate em S&P 500, adaptada para crypto. StochRSI combina Stochastic Oscillator com RSI para sinais mais sensíveis de momentum.",
  "author": "MarketMind",
  "tags": [
    "momentum",
    "stochrsi",
    "oscillator",
    "mean-reversion"
  ],
  "source": "QuantifiedStrategies.com - Stochastic RSI (StochRSI)",
  "status": "active",
  "optimizedParams": {
    "maxPositionSize": 70,
    "maxConcurrentPositions": 2,
    "maxTotalExposure": 80,
    "useAlgorithmicLevels": true,
    "useTrailingStop": false,
    "onlyWithTrend": false,
    "minConfidence": 65,
    "commission": 0.001
  },
  "backtestSummary": {
    "referenceWinRate": 78,
    "referenceAvgGainPerTrade": 0.7,
    "referenceTrades": 228,
    "referenceMaxDrawdown": 15,
    "referenceAnnualReturn": 4.85,
    "referenceTimeInvested": "10%",
    "testedAsset": "S&P 500",
    "testedPeriod": "1993-present",
    "source": "QuantifiedStrategies.com",
    "notes": "Works best for stocks, may need adjustment for crypto"
  },
  "recommendedTimeframes": {
    "primary": "1d",
    "secondary": [
      "4h"
    ],
    "avoid": [
      "1m",
      "5m",
      "15m"
    ],
    "notes": "StochRSI works best on daily for swing trading"
  },
  "parameters": {
    "rsiLength": {
      "default": 14,
      "min": 10,
      "max": 21,
      "step": 1,
      "description": "Período do RSI base"
    },
    "stochLength": {
      "default": 14,
      "min": 10,
      "max": 21,
      "step": 1,
      "description": "Período do Stochastic aplicado ao RSI"
    },
    "kSmooth": {
      "default": 3,
      "min": 1,
      "max": 5,
      "step": 1,
      "description": "Suavização da linha K"
    },
    "dSmooth": {
      "default": 3,
      "min": 1,
      "max": 5,
      "step": 1,
      "description": "Suavização da linha D"
    },
    "oversold": {
      "default": 20,
      "min": 10,
      "max": 30,
      "step": 5,
      "description": "Nível oversold"
    },
    "overbought": {
      "default": 80,
      "min": 70,
      "max": 90,
      "step": 5,
      "description": "Nível overbought"
    },
    "atrMultiplier": {
      "default": 2,
      "min": 1.5,
      "max": 3,
      "step": 0.5,
      "description": "Multiplicador ATR para stop"
    }
  },
  "indicators": {
    "stochRsi": {
      "type": "stochRsi",
      "params": {
        "rsiLength": "$rsiLength",
        "stochLength": "$stochLength",
        "kSmooth": "$kSmooth",
        "dSmooth": "$dSmooth"
      }
    },
    "atr": {
      "type": "atr",
      "params": {
        "period": 14
      }
    }
  },
  "entry": {
    "long": {
      "operator": "AND",
      "conditions": [
        {
          "left": "stochRsi.k",
          "op": "crossover",
          "right": "$oversold"
        }
      ]
    },
    "short": {
      "operator": "AND",
      "conditions": [
        {
          "left": "stochRsi.k",
          "op": "crossunder",
          "right": "$overbought"
        }
      ]
    }
  },
  "exit": {
    "stopLoss": {
      "type": "atr",
      "multiplier": "$atrMultiplier",
      "indicator": "atr"
    },
    "takeProfit": {
      "type": "riskReward",
      "multiplier": 2
    },
    "conditions": {
      "long": {
        "operator": "OR",
        "conditions": [
          {
            "left": "stochRsi.k",
            "op": "crossunder",
            "right": "$overbought"
          }
        ]
      },
      "short": {
        "operator": "OR",
        "conditions": [
          {
            "left": "stochRsi.k",
            "op": "crossover",
            "right": "$oversold"
          }
        ]
      }
    }
  },
  "confidence": {
    "base": 70,
    "bonuses": [
      {
        "condition": {
          "left": "stochRsi.k",
          "op": "<",
          "right": 10
        },
        "bonus": 10,
        "description": "Extremely oversold"
      },
      {
        "condition": {
          "left": "volume",
          "op": ">",
          "right": "volume.sma20"
        },
        "bonus": 5,
        "description": "Volume confirmation"
      }
    ],
    "max": 90
  },
  "filters": {
    "minConfidence": 65,
    "minRiskReward": 1.5
  }
}
