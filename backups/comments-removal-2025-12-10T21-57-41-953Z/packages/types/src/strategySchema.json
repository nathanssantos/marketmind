{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://marketmind.io/schemas/strategy-definition.json",
  "title": "MarketMind Strategy Definition",
  "description": "JSON Schema for declarative trading strategy definitions",
  "type": "object",
  "required": ["id", "name", "version", "parameters", "indicators", "entry", "exit"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "description": "Unique strategy identifier (kebab-case)"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable strategy name"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version (e.g., 1.0.0)"
    },
    "description": {
      "type": "string",
      "description": "Detailed description of the strategy"
    },
    "author": {
      "type": "string",
      "description": "Strategy author name"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Tags for categorization"
    },
    "parameters": {
      "type": "object",
      "additionalProperties": { "$ref": "#/definitions/parameter" },
      "description": "Strategy parameters with defaults and optimization ranges"
    },
    "indicators": {
      "type": "object",
      "additionalProperties": { "$ref": "#/definitions/indicator" },
      "description": "Indicator definitions"
    },
    "entry": {
      "$ref": "#/definitions/entryConditions",
      "description": "Entry conditions for long and short positions"
    },
    "exit": {
      "$ref": "#/definitions/exitConfig",
      "description": "Exit configuration with stop loss and take profit"
    },
    "confidence": {
      "$ref": "#/definitions/confidenceConfig",
      "description": "Confidence calculation configuration"
    },
    "filters": {
      "$ref": "#/definitions/filters",
      "description": "Strategy filters"
    }
  },
  "definitions": {
    "parameter": {
      "type": "object",
      "required": ["default"],
      "properties": {
        "default": { "type": "number" },
        "min": { "type": "number" },
        "max": { "type": "number" },
        "step": { "type": "number" },
        "description": { "type": "string" }
      }
    },
    "indicatorType": {
      "type": "string",
      "enum": ["sma", "ema", "rsi", "macd", "bollingerBands", "atr", "stochastic", "vwap", "pivotPoints"]
    },
    "priceSource": {
      "type": "string",
      "enum": ["open", "high", "low", "close", "volume"]
    },
    "indicator": {
      "type": "object",
      "required": ["type", "params"],
      "properties": {
        "type": { "$ref": "#/definitions/indicatorType" },
        "params": {
          "type": "object",
          "additionalProperties": {
            "oneOf": [
              { "type": "number" },
              { "type": "string", "pattern": "^\\$[a-zA-Z0-9]+$" }
            ]
          }
        },
        "source": { "$ref": "#/definitions/priceSource" }
      }
    },
    "comparisonOperator": {
      "type": "string",
      "enum": [">", "<", ">=", "<=", "==", "!=", "crossover", "crossunder"]
    },
    "logicalOperator": {
      "type": "string",
      "enum": ["AND", "OR"]
    },
    "conditionOperand": {
      "oneOf": [
        { "type": "number" },
        { "type": "string" }
      ]
    },
    "condition": {
      "type": "object",
      "required": ["left", "op", "right"],
      "properties": {
        "left": { "$ref": "#/definitions/conditionOperand" },
        "op": { "$ref": "#/definitions/comparisonOperator" },
        "right": { "$ref": "#/definitions/conditionOperand" }
      }
    },
    "conditionGroup": {
      "type": "object",
      "required": ["operator", "conditions"],
      "properties": {
        "operator": { "$ref": "#/definitions/logicalOperator" },
        "conditions": {
          "type": "array",
          "items": {
            "oneOf": [
              { "$ref": "#/definitions/condition" },
              { "$ref": "#/definitions/conditionGroup" }
            ]
          },
          "minItems": 1
        }
      }
    },
    "entryConditions": {
      "type": "object",
      "properties": {
        "long": { "$ref": "#/definitions/conditionGroup" },
        "short": { "$ref": "#/definitions/conditionGroup" }
      },
      "anyOf": [
        { "required": ["long"] },
        { "required": ["short"] }
      ]
    },
    "exitLevelType": {
      "type": "string",
      "enum": ["atr", "percent", "fixed", "indicator", "riskReward"]
    },
    "exitLevel": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "$ref": "#/definitions/exitLevelType" },
        "value": { "$ref": "#/definitions/conditionOperand" },
        "multiplier": { "$ref": "#/definitions/conditionOperand" },
        "indicator": { "type": "string" },
        "fallback": { "$ref": "#/definitions/exitLevel" }
      },
      "allOf": [
        {
          "if": { "properties": { "type": { "const": "atr" } } },
          "then": { "required": ["multiplier"] }
        },
        {
          "if": { "properties": { "type": { "const": "percent" } } },
          "then": { "required": ["value"] }
        },
        {
          "if": { "properties": { "type": { "const": "fixed" } } },
          "then": { "required": ["value"] }
        },
        {
          "if": { "properties": { "type": { "const": "indicator" } } },
          "then": { "required": ["value"] }
        },
        {
          "if": { "properties": { "type": { "const": "riskReward" } } },
          "then": { "required": ["multiplier"] }
        }
      ]
    },
    "trailingStopConfig": {
      "type": "object",
      "required": ["enabled", "type", "initialMultiplier", "trailMultiplier"],
      "properties": {
        "enabled": { "type": "boolean" },
        "type": { "type": "string", "enum": ["atr", "percent"] },
        "initialMultiplier": { "type": "number" },
        "trailMultiplier": { "type": "number" },
        "breakEvenAfterR": { "type": "number" }
      }
    },
    "exitConfig": {
      "type": "object",
      "required": ["stopLoss", "takeProfit"],
      "properties": {
        "stopLoss": { "$ref": "#/definitions/exitLevel" },
        "takeProfit": { "$ref": "#/definitions/exitLevel" },
        "trailingStop": { "$ref": "#/definitions/trailingStopConfig" }
      }
    },
    "confidenceBonus": {
      "type": "object",
      "required": ["condition", "bonus"],
      "properties": {
        "condition": { "$ref": "#/definitions/condition" },
        "bonus": { "type": "number" },
        "description": { "type": "string" }
      }
    },
    "confidenceConfig": {
      "type": "object",
      "required": ["base"],
      "properties": {
        "base": { "type": "number", "minimum": 0, "maximum": 100 },
        "bonuses": {
          "type": "array",
          "items": { "$ref": "#/definitions/confidenceBonus" }
        },
        "max": { "type": "number", "minimum": 0, "maximum": 100 }
      }
    },
    "timeFilters": {
      "type": "object",
      "properties": {
        "allowedDays": {
          "type": "array",
          "items": { "type": "integer", "minimum": 0, "maximum": 6 }
        },
        "allowedHours": {
          "type": "array",
          "items": { "type": "integer", "minimum": 0, "maximum": 23 }
        },
        "excludeDates": {
          "type": "array",
          "items": { "type": "string", "format": "date" }
        }
      }
    },
    "trendFilter": {
      "type": "object",
      "required": ["enabled", "indicator", "period", "allowCounterTrend"],
      "properties": {
        "enabled": { "type": "boolean" },
        "indicator": { "type": "string" },
        "period": { "type": "integer", "minimum": 1 },
        "allowCounterTrend": { "type": "boolean" }
      }
    },
    "filters": {
      "type": "object",
      "properties": {
        "minConfidence": { "type": "number", "minimum": 0, "maximum": 100 },
        "minRiskReward": { "type": "number", "minimum": 0 },
        "trendFilter": { "$ref": "#/definitions/trendFilter" },
        "timeFilters": { "$ref": "#/definitions/timeFilters" }
      }
    }
  }
}
