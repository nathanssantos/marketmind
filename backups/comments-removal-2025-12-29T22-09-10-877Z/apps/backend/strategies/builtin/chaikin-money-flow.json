{
  "id": "chaikin-money-flow",
  "name": "Chaikin Money Flow",
  "version": "1.0.0",
  "description": "Chaikin Money Flow (CMF) para medir acumula\u00e7\u00e3o/distribui\u00e7\u00e3o. Entry quando CMF cruza zero indicando mudan\u00e7a no fluxo de dinheiro.",
  "author": "MarketMind",
  "tags": [
    "volume",
    "cmf",
    "chaikin",
    "accumulation-distribution"
  ],
  "source": "Marc Chaikin",
  "status": "active",
  "optimizedParams": {
    "maxPositionSize": 70,
    "maxConcurrentPositions": 2,
    "maxTotalExposure": 80,
    "useAlgorithmicLevels": true,
    "useTrailingStop": false,
    "onlyWithTrend": false,
    "minConfidence": 70,
    "commission": 0.001
  },
  "recommendedTimeframes": {
    "primary": "1d",
    "secondary": [
      "4h"
    ],
    "avoid": [
      "1m",
      "5m"
    ],
    "notes": "CMF works best on daily"
  },
  "parameters": {
    "cmfPeriod": {
      "default": 20,
      "min": 14,
      "max": 30,
      "step": 2,
      "description": "Per\u00edodo do CMF"
    },
    "threshold": {
      "default": 0.05,
      "min": 0,
      "max": 0.1,
      "step": 0.025,
      "description": "Threshold para confirma\u00e7\u00e3o"
    },
    "atrMultiplier": {
      "default": 2,
      "min": 1.5,
      "max": 3,
      "step": 0.5,
      "description": "ATR para stop"
    }
  },
  "indicators": {
    "cmf": {
      "type": "cmf",
      "params": {
        "period": "$cmfPeriod"
      }
    },
    "atr": {
      "type": "atr",
      "params": {
        "period": 14
      }
    }
  },
  "entry": {
    "long": {
      "operator": "AND",
      "conditions": [
        {
          "left": "cmf",
          "op": "crossover",
          "right": "$threshold"
        }
      ]
    },
    "short": {
      "operator": "AND",
      "conditions": [
        {
          "left": "cmf",
          "op": "crossunder",
          "right": {
            "calc": "-1 * $threshold"
          }
        }
      ]
    }
  },
  "exit": {
    "stopLoss": {
      "type": "swingHighLow",
      "buffer": 0.6,
      "indicator": "atr"
    },
    "takeProfit": {
      "type": "riskReward",
      "multiplier": 2
    },
    "conditions": {
      "long": {
        "operator": "OR",
        "conditions": [
          {
            "left": "cmf",
            "op": "<",
            "right": 0
          }
        ]
      },
      "short": {
        "operator": "OR",
        "conditions": [
          {
            "left": "cmf",
            "op": ">",
            "right": 0
          }
        ]
      }
    },
    "trailingStop": {
      "enabled": true,
      "type": "atr",
      "initialMultiplier": 2,
      "trailMultiplier": 1.5,
      "breakEvenAfterR": 1
    }
  },
  "confidence": {
    "base": 70,
    "bonuses": [
      {
        "condition": {
          "left": "cmf",
          "op": ">",
          "right": 0.15
        },
        "bonus": 10,
        "description": "Strong accumulation"
      },
      {
        "condition": {
          "left": "volume",
          "op": ">",
          "right": "volume.sma20"
        },
        "bonus": 5,
        "description": "Volume spike"
      }
    ],
    "max": 90
  },
  "filters": {
    "minConfidence": 70,
    "minRiskReward": 1.0
  }
}