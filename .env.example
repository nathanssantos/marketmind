# Environment configuration for the renderer / Electron app.
# Copy this file to `.env` and fill in only what you need.
#
# The backend's environment is configured separately — see
# `apps/backend/.env.example`. Exchange API keys (Binance, etc.) are NOT
# stored here; they live encrypted per-wallet in the backend database via
# the Wallets UI.

# ===========================
# Renderer (electron/web)
# ===========================

# Backend URL for the renderer's tRPC client + socket.io connection.
# Defaults to http://localhost:3001 when unset.
# VITE_BACKEND_URL=http://localhost:3001

# Detailed setup-detection logs in the renderer console:
# attempts, rejections, confidence scores, trend analysis.
VITE_DEBUG_SETUPS=false

# ===========================
# Shared
# ===========================

NODE_ENV=development
LOG_LEVEL=debug
