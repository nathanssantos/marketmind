# Exemplo de configuração de ambiente
# Copie este arquivo para .env e preencha com suas credenciais

# ===========================
# APIs de Mercado
# ===========================

# Binance (Cryptocurrencies)
# Obtenha em: https://www.binance.com/en/my/settings/api-management
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Alpha Vantage (Stocks)
# Obtenha em: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# ===========================
# APIs de Inteligência Artificial
# ===========================

# Anthropic Claude (Recommended - Claude 4.5 Sonnet)
# Get your API key at: https://console.anthropic.com
VITE_ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (GPT-4o)
# Get your API key at: https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=sk-proj-...

# Google Gemini
# Get your API key at: https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=AIza...

# ===========================
# APIs de Notícias
# ===========================

# NewsAPI (General financial news)
# Get your free API key at: https://newsapi.org/register
# Free tier: 100 requests/day
VITE_NEWSAPI_API_KEY=

# CryptoPanic (Cryptocurrency news)
# Get your free API key at: https://cryptopanic.com/developers/api/
# Free tier: Public feed access
VITE_CRYPTOPANIC_API_KEY=

# ===========================
# Configurações de Desenvolvimento
# ===========================

# Setup Detection Debug Logs
# Set to 'true' to enable detailed logs for setup detection
# Shows: attempts, rejections, confidence scores, trend analysis
VITE_DEBUG_SETUPS=false

NODE_ENV=development
LOG_LEVEL=debug

# ===========================
# Configurações de Produção
# ===========================

# URL do servidor de updates (configurar após deploy)
# UPDATE_SERVER_URL=https://updates.marketmind.app
