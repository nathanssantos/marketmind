# Exemplo de configuração de ambiente
# Copie este arquivo para .env e preencha com suas credenciais

# ===========================
# APIs de Mercado
# ===========================

# Binance (Cryptocurrencies)
# Obtenha em: https://www.binance.com/en/my/settings/api-management
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Alpha Vantage (Stocks)
# Obtenha em: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# ===========================
# APIs de Inteligência Artificial
# ===========================

# OpenAI (GPT-4 Vision)
# Obtenha em: https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4-vision-preview

# Anthropic (Claude 3)
# Obtenha em: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-opus-20240229

# Google Gemini
# Obtenha em: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-pro-vision

# ===========================
# APIs de Notícias
# ===========================

# NewsAPI
# Obtenha em: https://newsapi.org/register
NEWS_API_KEY=

# ===========================
# Configurações de Desenvolvimento
# ===========================

NODE_ENV=development
LOG_LEVEL=debug

# ===========================
# Configurações de Produção
# ===========================

# URL do servidor de updates (configurar após deploy)
# UPDATE_SERVER_URL=https://updates.marketmind.app
