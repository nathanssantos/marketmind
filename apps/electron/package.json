{
  "name": "@marketmind/electron",
  "version": "0.92.0",
  "description": "MarketMind Electron Desktop App",
  "main": "dist-electron/main/index.js",
  "author": "Nathan Santos",
  "license": "MIT",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/nathanssantos/marketmind.git"
  },
  "type": "module",
  "scripts": {
    "dev": "VITE_TARGET=electron vite",
    "dev:web": "VITE_TARGET=web vite",
    "build": "tsc && VITE_TARGET=electron vite build && electron-builder",
    "build:web": "tsc && VITE_TARGET=web vite build",
    "build:mac": "pnpm build && electron-builder --mac",
    "build:win": "pnpm build && electron-builder --win",
    "build:all": "pnpm build && electron-builder --mac --win",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "preview": "vite preview",
    "preview:web": "VITE_TARGET=web vite preview",
    "test": "npm run test:unit && npm run test:browser:run",
    "test:ui": "vitest --ui",
    "test:run": "npm run test:unit && npm run test:browser:run",
    "test:unit": "vitest run",
    "test:browser": "vitest --config vitest.browser.config.ts",
    "test:browser:run": "vitest run --config vitest.browser.config.ts",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:visual": "playwright test --project=visual-regression",
    "test:visual:update": "playwright test --project=visual-regression --update-snapshots",
    "clear-storage": "node ../../scripts/clear-storage.mjs",
    "clean": "rm -rf dist dist-web dist-electron node_modules"
  },
  "dependencies": {
    "@chakra-ui/react": "^3.30.0",
    "@emotion/react": "^11.14.0",
    "@marketmind/chart-studies": "workspace:*",
    "@marketmind/fibonacci": "workspace:*",
    "@marketmind/types": "workspace:*",
    "@marketmind/utils": "workspace:*",
    "@tanstack/react-query": "^5.90.12",
    "@trpc/client": "^11.7.2",
    "@trpc/react-query": "^11.7.2",
    "axios": "^1.13.2",
    "date-fns": "^4.1.0",
    "electron-log": "^5.4.3",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.6.2",
    "i18next": "^25.7.2",
    "i18next-browser-languagedetector": "^8.2.0",
    "immer": "^11.1.4",
    "nanoid": "^5.1.6",
    "pinets": "^0.9.9",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-error-boundary": "^6.0.0",
    "react-grid-layout": "^2.2.3",
    "react-i18next": "^16.4.1",
    "react-icons": "^5.5.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.12.0",
    "react-virtualized-auto-sizer": "^1.0.26",
    "react-window": "^2.2.3",
    "recharts": "^3.5.1",
    "socket.io-client": "^4.8.1",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.0.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/react-grid-layout": "^2.1.0",
    "@types/react-virtualized-auto-sizer": "^1.0.8",
    "@types/react-window": "^2.0.0",
    "@typescript-eslint/eslint-plugin": "^8.49.0",
    "@typescript-eslint/parser": "^8.49.0",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/browser": "^4.0.15",
    "@vitest/browser-playwright": "^4.0.15",
    "@vitest/coverage-v8": "^4.0.15",
    "@vitest/ui": "^4.0.15",
    "canvas": "^3.2.0",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "fast-check": "^4.5.3",
    "happy-dom": "^20.0.11",
    "jsdom": "^27.3.0",
    "playwright": "^1.57.0",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3",
    "vite": "^7.2.7",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.15",
    "vitest-canvas-mock": "^1.1.3"
  }
}
