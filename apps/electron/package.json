{
  "name": "@marketmind/electron",
  "version": "1.11.4",
  "description": "MarketMind Electron Desktop App",
  "keywords": [
    "trading",
    "crypto",
    "cryptocurrency",
    "charts",
    "klines",
    "candlestick",
    "technical-analysis",
    "indicators",
    "backtesting",
    "auto-trading",
    "binance",
    "futures",
    "electron",
    "desktop",
    "react",
    "chakra-ui"
  ],
  "main": "dist-electron/main/index.js",
  "author": "Nathan Santos",
  "license": "MIT",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/nathanssantos/marketmind.git"
  },
  "type": "module",
  "scripts": {
    "dev": "VITE_TARGET=electron vite",
    "dev:web": "VITE_TARGET=web vite",
    "build": "tsc && VITE_TARGET=electron vite build && electron-builder",
    "build:web": "tsc && VITE_TARGET=web vite build",
    "build:mac": "pnpm build && electron-builder --mac",
    "build:win": "pnpm build && electron-builder --win",
    "build:all": "pnpm build && electron-builder --mac --win",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "preview": "vite preview",
    "preview:web": "VITE_TARGET=web vite preview",
    "test": "npm run test:unit && npm run test:browser:run",
    "test:ui": "vitest --ui",
    "test:run": "npm run test:unit && npm run test:browser:run",
    "test:unit": "vitest run",
    "test:browser": "vitest --config vitest.browser.config.ts",
    "test:browser:run": "vitest run --config vitest.browser.config.ts",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:visual": "playwright test --project=visual-regression --workers=1",
    "test:visual:update": "playwright test --project=visual-regression --update-snapshots --workers=1",
    "test:perf": "playwright test --project=perf --reporter=list",
    "test:perf:diagnose": "PERF_DIAGNOSE=1 playwright test --project=perf --reporter=list",
    "test:perf:update": "tsx ../../scripts/perf/update-baseline.ts",
    "build:main": "VITE_TARGET=electron vite build",
    "bundle:analyze": "ANALYZE=1 pnpm build:web",
    "test:e2e:electron": "pnpm build:main && playwright test --project=electron --reporter=list",
    "clear-storage": "node ../../scripts/clear-storage.mjs",
    "clean": "rm -rf dist dist-web dist-electron node_modules"
  },
  "dependencies": {
    "@chakra-ui/react": "^3.35.0",
    "@emotion/react": "^11.14.0",
    "@marketmind/chart-studies": "workspace:*",
    "@marketmind/fibonacci": "workspace:*",
    "@marketmind/tokens": "workspace:*",
    "@marketmind/types": "workspace:*",
    "@marketmind/ui": "workspace:*",
    "@marketmind/utils": "workspace:*",
    "@tanstack/react-query": "^5.100.3",
    "@trpc/client": "^11.16.0",
    "@trpc/react-query": "^11.16.0",
    "@trpc/server": "^11.16.0",
    "axios": "^1.15.2",
    "date-fns": "^4.1.0",
    "electron-log": "^5.4.3",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "i18next": "^26.0.8",
    "i18next-browser-languagedetector": "^8.2.1",
    "immer": "^11.1.4",
    "nanoid": "^5.1.9",
    "pinets": "^0.9.13",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-error-boundary": "^6.1.1",
    "react-grid-layout": "^2.2.3",
    "react-i18next": "^17.0.4",
    "react-icons": "^5.6.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.14.2",
    "react-window": "^2.2.7",
    "recharts": "^3.8.1",
    "socket.io-client": "^4.8.3",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@playwright/test": "^1.59.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser": "^4.1.5",
    "@vitest/browser-playwright": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "canvas": "^3.2.3",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "fast-check": "^4.7.0",
    "happy-dom": "^20.9.0",
    "jsdom": "^29.0.2",
    "playwright": "^1.59.1",
    "prettier": "^3.8.3",
    "rollup-plugin-visualizer": "^7.0.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vite-plugin-electron": "0.29.1",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.5",
    "vitest-canvas-mock": "^1.1.4"
  }
}
