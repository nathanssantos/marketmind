{
  "name": "@marketmind/backend",
  "version": "0.31.0",
  "description": "MarketMind Backend API Server",
  "main": "./dist/index.js",
  "type": "module",
  "private": true,
  "exports": {
    ".": "./dist/index.js",
    "./types": "./src/index.export.ts"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.1.0",
    "@fastify/rate-limit": "^10.3.0",
    "@marketmind/indicators": "workspace:*",
    "@marketmind/types": "workspace:*",
    "@node-rs/argon2": "^2.0.0",
    "@trpc/server": "^11.7.2",
    "binance": "^3.1.5",
    "binance-api-node": "^0.13.4",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.44.7",
    "fastify": "^5.6.2",
    "pg": "^8.13.3",
    "pino": "^10.1.0",
    "socket.io": "^4.8.1",
    "ws": "^8.18.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/pg": "^8.11.10",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.48.0",
    "@typescript-eslint/parser": "^8.48.0",
    "drizzle-kit": "^0.31.7",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "pino-pretty": "^13.1.2",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  }
}
