{
  "name": "@marketmind/backend",
  "version": "1.5.0",
  "description": "MarketMind Backend API Server",
  "keywords": [
    "trading",
    "crypto",
    "backtesting",
    "auto-trading",
    "binance",
    "futures",
    "trpc",
    "fastify",
    "drizzle-orm",
    "postgresql",
    "timescaledb"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "private": true,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/index.export.d.ts",
      "default": "./dist/index.export.js"
    }
  },
  "scripts": {
    "dev": "caffeinate -dims tsx watch src/index.ts",
    "dev:allow-sleep": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "caffeinate -dims node dist/index.js",
    "start:allow-sleep": "node dist/index.js",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "pretest": "bash scripts/ensure-docker.sh",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:integration": "bash scripts/ensure-docker.sh && vitest run --project integration",
    "test:contract": "vitest run --project contracts",
    "test:load": "artillery run load-tests/config.yml",
    "test:load:health": "artillery run load-tests/health-check.yml",
    "test:load:wallet": "artillery run load-tests/wallet-api.yml",
    "test:load:trading": "artillery run load-tests/trading-api.yml",
    "test:load:report": "artillery run load-tests/config.yml --output load-test-report.json && artillery report load-test-report.json",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "backtest": "tsx src/cli/backtest-runner.ts",
    "backtest:validate": "tsx src/cli/backtest-runner.ts validate",
    "backtest:optimize": "tsx src/cli/backtest-runner.ts optimize",
    "backtest:walkforward": "tsx src/cli/backtest-runner.ts walkforward",
    "backtest:montecarlo": "tsx src/cli/backtest-runner.ts montecarlo",
    "backtest:sensitivity": "tsx src/cli/backtest-runner.ts sensitivity",
    "backtest:compare": "tsx src/cli/backtest-runner.ts compare",
    "backtest:export": "tsx src/cli/backtest-runner.ts export",
    "backtest:mw": "tsx src/cli/multi-watcher-backtest.ts",
    "backtest:volume": "tsx src/cli/compare-volume-filter.ts",
    "optimize:full": "tsx scripts/backtest/run-optimization.ts",
    "rank-strategies": "tsx scripts/backtest/rank-strategies.ts",
    "migrate:enabled-strategies": "tsx scripts/maintenance/migrate-enabled-strategies.ts",
    "reset-wallet": "tsx scripts/maintenance/reset-wallet.ts",
    "audit-klines": "tsx scripts/maintenance/audit-klines.ts",
    "clear-klines": "tsx scripts/maintenance/clear-klines.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@marketmind/fibonacci": "workspace:*",
    "@marketmind/logger": "workspace:*",
    "@marketmind/risk": "workspace:*",
    "@marketmind/trading-core": "workspace:*",
    "@marketmind/types": "workspace:*",
    "@marketmind/utils": "workspace:*",
    "@node-rs/argon2": "^2.0.2",
    "@stoqey/ib": "^1.5.3",
    "@trpc/server": "^11.16.0",
    "binance": "^3.5.5",
    "chalk": "^5.6.2",
    "cli-progress": "^3.12.0",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "ora": "^9.4.0",
    "pg": "^8.20.0",
    "pinets": "^0.9.13",
    "pino": "^10.3.1",
    "resend": "^6.12.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.3",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@pact-foundation/pact": "^16.3.0",
    "@testcontainers/postgresql": "^11.14.0",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitest/coverage-v8": "^4.1.5",
    "artillery": "^2.0.31",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "pino-pretty": "^13.1.3",
    "testcontainers": "^11.14.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
