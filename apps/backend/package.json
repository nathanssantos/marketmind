{
  "name": "@marketmind/backend",
  "version": "0.49.0",
  "description": "MarketMind Backend API Server",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "private": true,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/index.export.d.ts",
      "default": "./dist/index.export.js"
    }
  },
  "scripts": {
    "dev": "caffeinate -dims tsx watch src/index.ts",
    "dev:allow-sleep": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "caffeinate -dims node dist/index.js",
    "start:allow-sleep": "node dist/index.js",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "pretest": "bash scripts/ensure-docker.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run --exclude='**/routers/*.test.ts'",
    "test:contract": "vitest run --include='**/contracts/*.contract.test.ts'",
    "test:load": "artillery run load-tests/config.yml",
    "test:load:health": "artillery run load-tests/health-check.yml",
    "test:load:wallet": "artillery run load-tests/wallet-api.yml",
    "test:load:trading": "artillery run load-tests/trading-api.yml",
    "test:load:report": "artillery run load-tests/config.yml --output load-test-report.json && artillery report load-test-report.json",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "backtest": "tsx src/cli/backtest-runner.ts",
    "backtest:validate": "tsx src/cli/backtest-runner.ts validate",
    "backtest:optimize": "tsx src/cli/backtest-runner.ts optimize",
    "backtest:walkforward": "tsx src/cli/backtest-runner.ts walkforward",
    "backtest:montecarlo": "tsx src/cli/backtest-runner.ts montecarlo",
    "backtest:sensitivity": "tsx src/cli/backtest-runner.ts sensitivity",
    "backtest:compare": "tsx src/cli/backtest-runner.ts compare",
    "backtest:export": "tsx src/cli/backtest-runner.ts export",
    "backtest:multi": "tsx scripts/run-multi-timeframe-backtest.ts",
    "backtest:systematic": "tsx scripts/run-systematic-backtest.ts",
    "backtest:batch": "bash scripts/batch-backtest-comparison.sh",
    "backtest:fib-entry": "tsx scripts/run-fib-entry-comparison.ts",
    "backtest:fib-target": "tsx scripts/run-fib-target-comparison.ts",
    "validate:all": "tsx validate-strategies.mts",
    "optimize:all": "node batch-optimize.mjs",
    "test:all": "tsx validate-strategies.mts && node batch-optimize.mjs",
    "reset-wallet": "tsx src/scripts/reset-wallet.ts",
    "audit-klines": "tsx src/scripts/audit-klines.ts",
    "clear-klines": "tsx src/scripts/clear-klines.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@marketmind/fibonacci": "workspace:*",
    "@marketmind/indicators": "workspace:*",
    "@marketmind/logger": "workspace:*",
    "@marketmind/risk": "workspace:*",
    "@marketmind/trading-core": "workspace:*",
    "@marketmind/types": "workspace:*",
    "@marketmind/utils": "workspace:*",
    "@node-rs/argon2": "^2.0.2",
    "@trpc/server": "^11.7.2",
    "binance": "^3.1.5",
    "binance-api-node": "^0.13.5",
    "chalk": "^5.6.2",
    "cli-progress": "^3.12.0",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.2",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "fastify": "^5.6.2",
    "ora": "^9.0.0",
    "pg": "^8.16.3",
    "pino": "^10.1.0",
    "socket.io": "^4.8.1",
    "ws": "^8.18.3",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@pact-foundation/pact": "^16.0.4",
    "@testcontainers/postgresql": "^11.11.0",
    "@types/node": "^25.0.0",
    "@types/pg": "^8.16.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.49.0",
    "@typescript-eslint/parser": "^8.49.0",
    "@vitest/coverage-v8": "^4.0.16",
    "artillery": "^2.0.27",
    "drizzle-kit": "^0.31.8",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "pino-pretty": "^13.1.3",
    "testcontainers": "^11.11.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  }
}
