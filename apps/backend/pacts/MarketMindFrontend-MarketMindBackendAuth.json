{
  "consumer": {
    "name": "MarketMindFrontend"
  },
  "interactions": [
    {
      "description": "a login request with invalid password",
      "pending": false,
      "providerStates": [
        {
          "name": "user exists with email test@example.com"
        }
      ],
      "request": {
        "body": {
          "content": {
            "email": "test@example.com",
            "password": "WrongPassword"
          },
          "contentType": "application/json",
          "encoded": false
        },
        "headers": {
          "Content-Type": [
            "application/json"
          ]
        },
        "matchingRules": {
          "body": {
            "$.email": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.password": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "method": "POST",
        "path": "/trpc/auth.login"
      },
      "response": {
        "body": {
          "content": {
            "error": {
              "code": "UNAUTHORIZED",
              "message": "Invalid credentials"
            }
          },
          "contentType": "application/json",
          "encoded": false
        },
        "headers": {
          "Content-Type": [
            "application/json"
          ]
        },
        "matchingRules": {
          "body": {
            "$.error.code": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.error.message": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          },
          "header": {
            "Content-Type": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 401
      },
      "type": "Synchronous/HTTP"
    },
    {
      "description": "a login request with valid credentials",
      "pending": false,
      "providerStates": [
        {
          "name": "user exists with email test@example.com"
        }
      ],
      "request": {
        "body": {
          "content": {
            "email": "test@example.com",
            "password": "ValidPassword123!"
          },
          "contentType": "application/json",
          "encoded": false
        },
        "headers": {
          "Content-Type": [
            "application/json"
          ]
        },
        "matchingRules": {
          "body": {
            "$.email": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.password": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "method": "POST",
        "path": "/trpc/auth.login"
      },
      "response": {
        "body": {
          "content": {
            "result": {
              "data": {
                "email": "test@example.com",
                "id": 1
              }
            }
          },
          "contentType": "application/json",
          "encoded": false
        },
        "headers": {
          "Content-Type": [
            "application/json"
          ],
          "Set-Cookie": [
            "session=abc123-def456; Path=/; HttpOnly; SameSite=Strict"
          ]
        },
        "matchingRules": {
          "body": {
            "$.result.data.email": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.result.data.id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "integer"
                }
              ]
            }
          },
          "header": {
            "Content-Type": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "Set-Cookie": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "session=[a-zA-Z0-9-]+.*"
                }
              ]
            }
          }
        },
        "status": 200
      },
      "type": "Synchronous/HTTP"
    },
    {
      "description": "a logout request",
