# Backend environment configuration.
# Variables marked [docker] are read by docker-compose.yml even though the
# backend runtime doesn't reference them directly.

# ===========================
# Server
# ===========================
NODE_ENV=development
PORT=3001
HOST=0.0.0.0           # [docker] forwarded into the backend container
LOG_LEVEL=info

# ===========================
# Database (Postgres + TimescaleDB)
# ===========================
DATABASE_URL=postgresql://marketmind:password@localhost:5432/marketmind
DATABASE_NAME=marketmind         # [docker]
DATABASE_USER=marketmind         # [docker]
DATABASE_PASSWORD=password       # [docker]
DATABASE_PORT=5432               # [docker]

# ===========================
# Redis (cache; optional)
# ===========================
REDIS_URL=redis://:password@localhost:6379   # [docker]
REDIS_PASSWORD=password                       # [docker]
REDIS_PORT=6379                               # [docker]

# ===========================
# Security
# ===========================
ENCRYPTION_KEY=your-32-byte-hex-key-here    # AES-256-CBC for wallet API keys
SESSION_SECRET=your-session-secret-here     # Argon2 session signing

# ===========================
# CORS
# ===========================
CORS_ORIGIN=http://localhost:5173

# ===========================
# Trading
# ===========================
# IMPORTANT: 'true' enables REAL trading on Binance for live/testnet wallets.
# When 'false', all trades are simulated (paper-trading mode).
ENABLE_LIVE_TRADING=false

# ===========================
# pgAdmin (development only)
# ===========================
PGADMIN_EMAIL=admin@marketmind.local    # [docker]
PGADMIN_PASSWORD=admin                  # [docker]
PGADMIN_PORT=5050                       # [docker]
