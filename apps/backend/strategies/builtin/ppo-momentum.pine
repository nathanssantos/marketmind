// @id ppo-momentum
// @name PPO Momentum
// @version 1.0.0
// @description Percentage Price Oscillator momentum. Similar ao MACD mas em percentagem para melhor comparação entre ativos. Entry quando PPO cruza signal.
// @author MarketMind
// @tags momentum,ppo,oscillator,percentage
// @strategyType ANY
// @momentumType BREAKOUT
// @param fastPeriod Período EMA rápida
// @param slowPeriod Período EMA lenta
// @param signalPeriod Período signal line
// @param atrMultiplier ATR para stop

//@version=5
indicator('PPO Momentum', overlay=true)

fastPeriod = input.int(12, 'fastPeriod', minval=8, maxval=15, step=1)
slowPeriod = input.int(26, 'slowPeriod', minval=20, maxval=30, step=2)
signalPeriod = input.int(9, 'signalPeriod', minval=7, maxval=12, step=1)
atrMultiplier = input.float(2, 'atrMultiplier', minval=1.5, maxval=3, step=0.5)

ppo_fast = ta.ema(close, fastPeriod)
ppo_slow = ta.ema(close, slowPeriod)
ppo_ppo = (ppo_fast - ppo_slow) / ppo_slow * 100
ppo_signal = ta.ema(ppo_ppo, signalPeriod)
ppo_histogram = ppo_ppo - ppo_signal
atr = ta.atr(14)
atrVal = atr

volSma20 = ta.sma(volume, 20)

longEntry = ta.crossover(ppo_ppo, ppo_signal)
shortEntry = ta.crossunder(ppo_ppo, ppo_signal)

confBase = 65
confBonus0 = ppo_histogram > 0 ? 5 : 0
confBonus1 = volume > ta.sma(volume, 20) ? 10 : 0
confValue = math.min(confBase + confBonus0 + confBonus1, 85)

exitLong = ta.crossunder(ppo_ppo, ppo_signal)
exitShort = ta.crossover(ppo_ppo, ppo_signal)

sig = longEntry ? 1 : shortEntry ? -1 : 0
sl = longEntry ? close - atrVal * 0.6 : shortEntry ? close + atrVal * 0.6 : na
tp = longEntry ? close + math.abs(close - (close - atrVal * 0.6)) * 2 : shortEntry ? close - math.abs((close + atrVal * 0.6) - close) * 2 : na
conf = longEntry or shortEntry ? confValue : 0
exitSig = exitLong ? 1 : exitShort ? -1 : 0

plot(sig, 'signal', display=display.none)
plot(sl, 'stopLoss', display=display.none)
plot(tp, 'takeProfit', display=display.none)
plot(conf, 'confidence', display=display.none)
plot(exitSig, 'exitSignal', display=display.none)
