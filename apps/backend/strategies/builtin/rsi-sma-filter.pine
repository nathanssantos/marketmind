// @id rsi-sma-filter
// @name RSI SMA Filter
// @version 1.0.0
// @description RSI com filtro de SMA200 para confirmar tendência. Entry RSI < 30 quando preço acima da SMA200. Combina mean-reversion com trend filter.
// @author MarketMind
// @tags mean-reversion,rsi,sma,trend-filter
// @strategyType MEAN_REVERSION
// @momentumType REVERSAL
// @param rsiPeriod Período do RSI
// @param smaPeriod Período da SMA para filtro
// @param oversold Nível oversold
// @param overbought Nível overbought
// @param atrMultiplier ATR para stop

//@version=5
indicator('RSI SMA Filter', overlay=true)

rsiPeriod = input.int(14, 'rsiPeriod', minval=10, maxval=21, step=1)
smaPeriod = input.int(200, 'smaPeriod', minval=100, maxval=250, step=50)
oversold = input.int(30, 'oversold', minval=20, maxval=35, step=5)
overbought = input.int(70, 'overbought', minval=65, maxval=80, step=5)
atrMultiplier = input.float(2, 'atrMultiplier', minval=1.5, maxval=3, step=0.5)

rsi = ta.rsi(close, rsiPeriod)
sma = ta.sma(close, smaPeriod)
atr = ta.atr(14)
atrVal = atr

volSma20 = ta.sma(volume, 20)

longEntry = (rsi < oversold and close > sma)
shortEntry = (rsi > overbought and close < sma)

confBase = 70
confBonus0 = rsi < 25 ? 10 : 0
confBonus1 = volume > ta.sma(volume, 20) ? 5 : 0
confValue = math.min(confBase + confBonus0 + confBonus1, 90)

exitLong = rsi > 50
exitShort = rsi < 50

sig = longEntry ? 1 : shortEntry ? -1 : 0
sl = longEntry ? close - atrVal * 0.6 : shortEntry ? close + atrVal * 0.6 : na
tp = longEntry ? close + math.abs(close - (close - atrVal * 0.6)) * 2 : shortEntry ? close - math.abs((close + atrVal * 0.6) - close) * 2 : na
conf = longEntry or shortEntry ? confValue : 0
exitSig = exitLong ? 1 : exitShort ? -1 : 0

plot(sig, 'signal', display=display.none)
plot(sl, 'stopLoss', display=display.none)
plot(tp, 'takeProfit', display=display.none)
plot(conf, 'confidence', display=display.none)
plot(exitSig, 'exitSignal', display=display.none)
