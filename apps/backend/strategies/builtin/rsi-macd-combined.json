{
  "id": "rsi-macd-combined",
  "name": "RSI + MACD Combined",
  "version": "1.0.0",
  "description": "Estratégia combinando RSI e MACD para confirmação dupla. Backtestada com até 77% win rate quando ambos alinham. MACD para direção, RSI para momentum.",
  "author": "MarketMind",
  "tags": [
    "momentum",
    "rsi",
    "macd",
    "confirmation",
    "multi-indicator"
  ],
  "source": "Gate.com - RSI MACD Combined Strategy",
  "status": "active",
  "backtestSummary": {
    "referenceWinRate": 77,
    "notes": "Multi-indicator confirmation increases win rate",
    "source": "Gate.com Research"
  },
  "recommendedTimeframes": {
    "primary": "4h",
    "secondary": [
      "1h",
      "1d"
    ],
    "avoid": [
      "1m",
      "5m"
    ],
    "notes": "Multi-indicator works best on 4h"
  },
  "parameters": {
    "rsiPeriod": {
      "default": 14,
      "min": 10,
      "max": 21,
      "step": 1,
      "description": "Período do RSI"
    },
    "rsiBullish": {
      "default": 50,
      "min": 45,
      "max": 55,
      "step": 5,
      "description": "RSI threshold bullish"
    },
    "macdFast": {
      "default": 12,
      "min": 8,
      "max": 15,
      "step": 1,
      "description": "MACD EMA rápida"
    },
    "macdSlow": {
      "default": 26,
      "min": 20,
      "max": 30,
      "step": 2,
      "description": "MACD EMA lenta"
    },
    "macdSignal": {
      "default": 9,
      "min": 7,
      "max": 12,
      "step": 1,
      "description": "MACD Signal"
    },
    "atrMultiplier": {
      "default": 2,
      "min": 1.5,
      "max": 3,
      "step": 0.5,
      "description": "ATR multiplier"
    }
  },
  "indicators": {
    "rsi": {
      "type": "rsi",
      "params": {
        "period": "$rsiPeriod"
      }
    },
    "macd": {
      "type": "macd",
      "params": {
        "fastPeriod": "$macdFast",
        "slowPeriod": "$macdSlow",
        "signalPeriod": "$macdSignal"
      }
    },
    "atr": {
      "type": "atr",
      "params": {
        "period": 14
      }
    }
  },
  "entry": {
    "long": {
      "operator": "AND",
      "conditions": [
        {
          "left": "macd.line",
          "op": "crossover",
          "right": "macd.signal"
        },
        {
          "left": "rsi",
          "op": ">",
          "right": "$rsiBullish"
        }
      ]
    },
    "short": {
      "operator": "AND",
      "conditions": [
        {
          "left": "macd.line",
          "op": "crossunder",
          "right": "macd.signal"
        },
        {
          "left": "rsi",
          "op": "<",
          "right": "$rsiBullish"
        }
      ]
    }
  },
  "exit": {
    "stopLoss": {
      "type": "swingHighLow",
      "buffer": 0.6,
      "indicator": "atr"
    },
    "takeProfit": {
      "type": "riskReward",
      "multiplier": 2.5
    },
    "trailingStop": {
      "enabled": true,
      "type": "atr",
      "initialMultiplier": 2,
      "trailMultiplier": 2.5,
      "breakEvenAfterR": 1.5
    }
  },
  "confidence": {
    "base": 75,
    "bonuses": [
      {
        "condition": {
          "left": "volume",
          "op": ">",
          "right": "volume.sma20"
        },
        "bonus": 10,
        "description": "Volume confirms"
      },
      {
        "condition": {
          "left": "macd.histogram",
          "op": ">",
          "right": "macd.histogram.prev"
        },
        "bonus": 5,
        "description": "Histogram rising"
      }
    ],
    "max": 95
  },
  "filters": {
    "minConfidence": 70,
    "minRiskReward": 2
  }
}
