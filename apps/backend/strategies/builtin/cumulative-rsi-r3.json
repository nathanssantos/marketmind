{
  "id": "cumulative-rsi-r3",
  "name": "Cumulative RSI R3",
  "version": "1.0.0",
  "description": "Larry Connors' R3 strategy using Cumulative RSI. Entry when: (1) RSI(2) drops 3 consecutive days, (2) first drop from below 60, (3) current RSI(2) < 10. Research shows 83% win rate with 2-day average hold.",
  "author": "MarketMind",
  "tags": [
    "mean-reversion",
    "connors",
    "rsi",
    "r3",
    "proven"
  ],
  "status": "active",
  "optimizedParams": {
    "maxPositionSize": 75,
    "useAlgorithmicLevels": true,
    "onlyWithTrend": false,
    "minConfidence": 70,
    "commission": 0.001
  },
  "recommendedTimeframes": {
    "primary": "1d",
    "secondary": [
      "4h"
    ],
    "avoid": [
      "1m",
      "5m",
      "15m",
      "30m"
    ],
    "notes": "R3 strategy requires daily bars. Short holding period (1-3 days) with high win rate."
  },
  "parameters": {
    "rsiPeriod": {
      "default": 2,
      "min": 2,
      "max": 3,
      "step": 1,
      "description": "RSI period (2 is original)"
    },
    "cumulativeThreshold": {
      "default": 10,
      "min": 5,
      "max": 15,
      "step": 5,
      "description": "Cumulative RSI entry threshold"
    },
    "smaTrend": {
      "default": 200,
      "min": 100,
      "max": 250,
      "step": 50,
      "description": "Trend filter SMA period"
    },
    "smaExit": {
      "default": 5,
      "min": 3,
      "max": 10,
      "step": 1,
      "description": "Exit when close > this SMA"
    },
    "atrPeriod": {
      "default": 14,
      "min": 10,
      "max": 20,
      "step": 2,
      "description": "ATR for stop loss"
    },
    "slMultiplier": {
      "default": 2.5,
      "min": 1.5,
      "max": 4,
      "step": 0.5,
      "description": "Stop loss ATR multiplier"
    }
  },
  "indicators": {
    "cumulativeRsi": {
      "type": "cumulativeRsi",
      "params": {
        "rsiPeriod": "$rsiPeriod",
        "sumPeriod": 2
      }
    },
    "rsi2": {
      "type": "rsi",
      "params": {
        "period": "$rsiPeriod"
      }
    },
    "sma200": {
      "type": "sma",
      "params": {
        "period": "$smaTrend"
      }
    },
    "sma5": {
      "type": "sma",
      "params": {
        "period": "$smaExit"
      }
    },
    "atr": {
      "type": "atr",
      "params": {
        "period": "$atrPeriod"
      }
    }
  },
  "entry": {
    "long": {
      "operator": "AND",
      "conditions": [
        {
          "left": "cumulativeRsi.cumulative",
          "op": "<",
          "right": "$cumulativeThreshold"
        },
        {
          "left": "close",
          "op": ">",
          "right": "sma200"
        }
      ]
    }
  },
  "exit": {
    "stopLoss": {
      "type": "swingHighLow",
      "buffer": 0.6,
      "indicator": "atr"
    },
    "takeProfit": {
      "type": "riskReward",
      "multiplier": 2
    },
    "trailingStop": {
      "enabled": true,
      "type": "atr",
      "initialMultiplier": 2,
      "trailMultiplier": 1.5,
      "breakEvenAfterR": 1
    }
  },
  "confidence": {
    "base": 75,
    "bonuses": [
      {
        "condition": {
          "left": "cumulativeRsi.cumulative",
          "op": "<",
          "right": 5
        },
        "bonus": 10,
        "description": "Extreme oversold cumulative RSI < 5"
      },
      {
        "condition": {
          "left": "rsi2",
          "op": "<",
          "right": 5
        },
        "bonus": 8,
        "description": "RSI(2) < 5"
      },
      {
        "condition": {
          "left": "volume",
          "op": ">",
          "right": "volume.sma20"
        },
        "bonus": 5,
        "description": "Volume confirmation"
      }
    ],
    "max": 95
  },
  "filters": {
    "minConfidence": 70,
    "minRiskReward": 1.5
  }
}