{
  "id": "mean-reversion-extreme",
  "name": "Mean Reversion Extreme",
  "version": "1.0.0",
  "description": "Mean reversion em condições extremas. RSI < 10 ou > 90 com Bollinger Bands. Entry em extremos para reversão à média.",
  "author": "MarketMind",
  "tags": [
    "mean-reversion",
    "extreme",
    "rsi",
    "bollinger"
  ],
  "source": "Statistical Trading",
  "status": "active",
  "recommendedTimeframes": {
    "primary": "1d",
    "secondary": [
      "4h"
    ],
    "avoid": [
      "1m",
      "5m",
      "15m"
    ],
    "notes": "Extreme conditions on daily"
  },
  "parameters": {
    "rsiPeriod": {
      "default": 2,
      "min": 2,
      "max": 5,
      "step": 1,
      "description": "RSI curto"
    },
    "bbPeriod": {
      "default": 20,
      "min": 15,
      "max": 25,
      "step": 5,
      "description": "BB período"
    },
    "bbStdDev": {
      "default": 2.5,
      "min": 2,
      "max": 3,
      "step": 0.25,
      "description": "BB desvio padrão"
    },
    "extremeOversold": {
      "default": 10,
      "min": 5,
      "max": 15,
      "step": 5,
      "description": "RSI extreme oversold"
    },
    "extremeOverbought": {
      "default": 90,
      "min": 85,
      "max": 95,
      "step": 5,
      "description": "RSI extreme overbought"
    },
    "atrMultiplier": {
      "default": 2.5,
      "min": 2,
      "max": 3.5,
      "step": 0.5,
      "description": "ATR stop"
    }
  },
  "indicators": {
    "rsi": {
      "type": "rsi",
      "params": {
        "period": "$rsiPeriod"
      }
    },
    "bb": {
      "type": "bollingerBands",
      "params": {
        "period": "$bbPeriod",
        "stdDev": "$bbStdDev"
      }
    },
    "atr": {
      "type": "atr",
      "params": {
        "period": 14
      }
    }
  },
  "entry": {
    "long": {
      "operator": "AND",
      "conditions": [
        {
          "left": "rsi",
          "op": "<",
          "right": "$extremeOversold"
        },
        {
          "left": "close",
          "op": "<",
          "right": "bb.lower"
        }
      ]
    },
    "short": {
      "operator": "AND",
      "conditions": [
        {
          "left": "rsi",
          "op": ">",
          "right": "$extremeOverbought"
        },
        {
          "left": "close",
          "op": ">",
          "right": "bb.upper"
        }
      ]
    }
  },
  "exit": {
    "stopLoss": {
      "type": "swingHighLow",
      "buffer": 0.6,
      "indicator": "atr"
    },
    "takeProfit": {
      "type": "indicator",
      "indicator": "bb.middle"
    },
    "conditions": {
      "long": {
        "operator": "OR",
        "conditions": [
          {
            "left": "close",
            "op": ">=",
            "right": "bb.middle"
          }
        ]
      },
      "short": {
        "operator": "OR",
        "conditions": [
          {
            "left": "close",
            "op": "<=",
            "right": "bb.middle"
          }
        ]
      }
    },
    "trailingStop": {
      "enabled": true,
      "type": "atr",
      "initialMultiplier": 2,
      "trailMultiplier": 1.5,
      "breakEvenAfterR": 1
    }
  },
  "confidence": {
    "base": 75,
    "bonuses": [
      {
        "condition": {
          "left": "rsi",
          "op": "<",
          "right": 5
        },
        "bonus": 10,
        "description": "Ultra extreme"
      },
      {
        "condition": {
          "left": "volume",
          "op": ">",
          "right": "volume.sma20"
        },
        "bonus": 5,
        "description": "Capitulation volume"
      }
    ],
    "max": 95
  },
  "filters": {
    "minConfidence": 75,
    "minRiskReward": 1
  }
}
