{
  "id": "breakout-retest",
  "name": "Breakout Retest",
  "version": "1.0.0",
  "description": "Breakout of key support/resistance level followed by successful retest. Entry after price breaks level, retests it as new support/resistance, and continues in breakout direction.",
  "author": "MarketMind",
  "tags": ["breakout", "retest", "support-resistance", "trend-continuation"],

  "status": "experimental",
  "optimizedParams": {
    "maxPositionSize": 50,
    "useAlgorithmicLevels": true,
    "onlyWithTrend": true,
    "minConfidence": 70,
    "commission": 0.001
  },
  "recommendedTimeframes": {
    "primary": "4h",
    "secondary": ["1h", "1d"],
    "avoid": ["1m", "5m", "15m"],
    "notes": "Best on 4h and daily for clear breakout/retest patterns"
  },

  "parameters": {
    "lookbackPeriod": { "default": 30, "min": 15, "max": 60, "step": 5, "description": "Period to identify support/resistance" },
    "emaPeriod": { "default": 20, "min": 10, "max": 50, "step": 5, "description": "EMA period for trend confirmation" },
    "volumeMultiplier": { "default": 1.4, "min": 1.0, "max": 2.0, "step": 0.1, "description": "Volume multiplier for breakout confirmation" },
    "retestTolerance": { "default": 0.5, "min": 0.2, "max": 1.0, "step": 0.1, "description": "Tolerance % for valid retest" },
    "atrPeriod": { "default": 14, "min": 7, "max": 21, "step": 1, "description": "ATR period for stop calculation" }
  },

  "indicators": {
    "ema": {
      "type": "ema",
      "params": { "period": "$emaPeriod" }
    },
    "atr": {
      "type": "atr",
      "params": { "period": "$atrPeriod" }
    },
    "ema200": {
      "type": "ema",
      "params": { "period": 200 }
    }
  },

  "entry": {
    "long": {
      "operator": "AND",
      "conditions": [
        { "left": "close", "op": ">", "right": "high.prev2" },
        { "left": "low.prev", "op": "<=", "right": "high.prev2" },
        { "left": "close", "op": ">", "right": "ema" }
      ]
    },
    "short": {
      "operator": "AND",
      "conditions": [
        { "left": "close", "op": "<", "right": "low.prev2" },
        { "left": "high.prev", "op": ">=", "right": "low.prev2" },
        { "left": "close", "op": "<", "right": "ema" }
      ]
    }
  },

  "exit": {
    "stopLoss": {
      "type": "atr",
      "multiplier": 1.5,
      "indicator": "atr"
    },
    "takeProfit": {
      "type": "riskReward",
      "multiplier": 2.5
    }
  },

  "confidence": {
    "base": 65,
    "bonuses": [
      { "condition": { "left": "volume", "op": ">", "right": "volume.sma20" }, "bonus": 15, "description": "Volume confirmation on continuation" },
      { "condition": { "left": "close", "op": ">", "right": "ema200" }, "bonus": 8, "description": "Aligned with major trend (LONG)" },
      { "condition": { "left": "close", "op": "<", "right": "ema200" }, "bonus": 8, "description": "Aligned with major trend (SHORT)" }
    ],
    "max": 95
  },

  "filters": {
    "minConfidence": 70,
    "minRiskReward": 2.0,
    "trendFilter": {
      "enabled": true,
      "indicator": "ema",
      "period": 200,
      "allowCounterTrend": false
    }
  }
}
