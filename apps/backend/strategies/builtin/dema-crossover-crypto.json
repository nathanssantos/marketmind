{
  "id": "dema-crossover-crypto",
  "name": "DEMA Crossover Crypto",
  "version": "1.0.0",
  "description": "Double EMA (DEMA) crossover strategy. DEMA reage mais rápido que EMA tradicional. Entry quando DEMA rápida cruza DEMA lenta.",
  "author": "MarketMind",
  "tags": [
    "trend-following",
    "dema",
    "crossover",
    "momentum"
  ],
  "source": "TradingView - DEMA Studies",
  "status": "unprofitable",
  "recommendedTimeframes": {
    "primary": "4h",
    "secondary": [
      "1h",
      "1d"
    ],
    "avoid": [
      "1m",
      "5m"
    ],
    "notes": "DEMA works well on 4h for crypto"
  },
  "parameters": {
    "fastPeriod": {
      "default": 12,
      "min": 8,
      "max": 15,
      "step": 1,
      "description": "Período DEMA rápida"
    },
    "slowPeriod": {
      "default": 26,
      "min": 20,
      "max": 35,
      "step": 5,
      "description": "Período DEMA lenta"
    },
    "atrMultiplier": {
      "default": 2,
      "min": 1.5,
      "max": 3,
      "step": 0.5,
      "description": "ATR para stop"
    }
  },
  "indicators": {
    "demaFast": {
      "type": "dema",
      "params": {
        "period": "$fastPeriod"
      }
    },
    "demaSlow": {
      "type": "dema",
      "params": {
        "period": "$slowPeriod"
      }
    },
    "atr": {
      "type": "atr",
      "params": {
        "period": 14
      }
    }
  },
  "entry": {
    "long": {
      "operator": "AND",
      "conditions": [
        {
          "left": "demaFast",
          "op": "crossover",
          "right": "demaSlow"
        }
      ]
    },
    "short": {
      "operator": "AND",
      "conditions": [
        {
          "left": "demaFast",
          "op": "crossunder",
          "right": "demaSlow"
        }
      ]
    }
  },
  "exit": {
    "stopLoss": {
      "type": "swingHighLow",
      "buffer": 0.6,
      "indicator": "atr"
    },
    "takeProfit": {
      "type": "riskReward",
      "multiplier": 2.5
    },
    "trailingStop": {
      "enabled": false,
      "type": "atr",
      "initialMultiplier": 2,
      "trailMultiplier": 2.5,
      "breakEvenAfterR": 1.5
    },
    "conditions": {
      "long": {
        "operator": "OR",
        "conditions": [
          {
            "left": "demaFast",
            "op": "crossunder",
            "right": "demaSlow"
          }
        ]
      },
      "short": {
        "operator": "OR",
        "conditions": [
          {
            "left": "demaFast",
            "op": "crossover",
            "right": "demaSlow"
          }
        ]
      }
    }
  },
  "confidence": {
    "base": 65,
    "bonuses": [
      {
        "condition": {
          "left": "volume",
          "op": ">",
          "right": "volume.sma20"
        },
        "bonus": 10,
        "description": "Volume confirms"
      },
      {
        "condition": {
          "left": "atr",
          "op": ">",
          "right": "atr.prev"
        },
        "bonus": 5,
        "description": "Volatility expanding"
      }
    ],
    "max": 85
  },
  "filters": {
    "minConfidence": 65,
    "minRiskReward": 2,
    "volumeType": "BREAKOUT",
    "strategyType": "TREND_FOLLOWING",
    "momentumType": "BREAKOUT"
  }
}
