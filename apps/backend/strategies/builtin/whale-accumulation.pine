// @id whale-accumulation
// @name Whale Accumulation
// @version 1.0.0
// @description Detecta acumulação de whales via large volume bars. Entry quando volume extremo aparece em consolidação com price estável.
// @author MarketMind
// @tags whale,accumulation,volume,smart-money
// @strategyType ANY
// @momentumType ANY
// @param volumeMultiplier Volume > média * mult
// @param priceChangeMax Max price change % (baixa vol)
// @param atrMultiplier ATR stop

//@version=5
indicator('Whale Accumulation', overlay=true)

volumeMultiplier = input.float(3, 'volumeMultiplier', minval=2, maxval=5, step=0.5)
priceChangeMax = input.float(2, 'priceChangeMax', minval=1, maxval=3, step=0.5)
atrMultiplier = input.float(2, 'atrMultiplier', minval=1.5, maxval=3, step=0.5)

volumeSma = ta.sma(volume, 20)
priceChange = ta.roc(close, 1)
ema50 = ta.ema(close, 50)
atr = ta.atr(14)
atrVal = atr

volSma20 = ta.sma(volume, 20)

longEntry = (volume > (volumeSma * volumeMultiplier) and (math.abs(priceChange)) < priceChangeMax and close > open)
shortEntry = (volume > (volumeSma * volumeMultiplier) and (math.abs(priceChange)) < priceChangeMax and close < open)

confBase = 70
confBonus0 = volume > (volumeSma * 5) ? 15 : 0
confValue = math.min(confBase + confBonus0, 90)

exitLong = false
exitShort = false

sig = longEntry ? 1 : shortEntry ? -1 : 0
sl = longEntry ? close - atrVal * 0.6 : shortEntry ? close + atrVal * 0.6 : na
tp = longEntry ? close + math.abs(close - (close - atrVal * 0.6)) * 2.5 : shortEntry ? close - math.abs((close + atrVal * 0.6) - close) * 2.5 : na
conf = longEntry or shortEntry ? confValue : 0
exitSig = exitLong ? 1 : exitShort ? -1 : 0

plot(sig, 'signal', display=display.none)
plot(sl, 'stopLoss', display=display.none)
plot(tp, 'takeProfit', display=display.none)
plot(conf, 'confidence', display=display.none)
plot(exitSig, 'exitSignal', display=display.none)
