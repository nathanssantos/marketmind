{
  "id": "larry-williams-9-4",
  "name": "Larry Williams 9.4 (Continuation)",
  "version": "1.0.0",
  "description": "Larry Williams Setup 9.4 - EMA9 failure continuation. Entry when EMA9 temporarily fails (turns against trend) but resumes original direction without losing structure (low not broken for LONG, high not broken for SHORT).",
  "author": "Larry Williams / MarketMind",
  "tags": [
    "larry-williams",
    "ema",
    "continuation",
    "failure-pattern"
  ],
  "status": "active",
  "optimizedParams": {
    "maxPositionSize": 40,
    "useAlgorithmicLevels": true,
    "onlyWithTrend": true,
    "minConfidence": 60,
    "commission": 0.001
  },
  "recommendedTimeframes": {
    "primary": "1d",
    "secondary": [
      "4h"
    ],
    "avoid": [
      "1m",
      "5m",
      "15m"
    ],
    "notes": "Best on daily charts. Requires clear trend structure."
  },
  "parameters": {
    "emaPeriod": {
      "default": 9,
      "min": 5,
      "max": 15,
      "step": 1,
      "description": "EMA period (Larry Williams uses 9)"
    },
    "atrPeriod": {
      "default": 14,
      "min": 7,
      "max": 21,
      "step": 1,
      "description": "ATR period for stop/target"
    },
    "atrStopMultiplier": {
      "default": 1.5,
      "min": 1.0,
      "max": 3.0,
      "step": 0.25,
      "description": "ATR multiplier for stop loss"
    },
    "atrTargetMultiplier": {
      "default": 2.5,
      "min": 1.5,
      "max": 4.0,
      "step": 0.5,
      "description": "ATR multiplier for take profit"
    },
    "volumeMultiplier": {
      "default": 1.0,
      "min": 0.5,
      "max": 2.0,
      "step": 0.25,
      "description": "Minimum volume as multiplier of average"
    }
  },
  "indicators": {
    "ema9": {
      "type": "ema",
      "params": {
        "period": "$emaPeriod"
      }
    },
    "atr": {
      "type": "atr",
      "params": {
        "period": "$atrPeriod"
      }
    },
    "ema200": {
      "type": "ema",
      "params": {
        "period": 200
      }
    }
  },
  "entry": {
    "long": {
      "operator": "AND",
      "conditions": [
        {
          "left": "ema9.prev3",
          "op": "<",
          "right": "ema9.prev2"
        },
        {
          "left": "ema9.prev2",
          "op": ">",
          "right": "ema9.prev"
        },
        {
          "left": "ema9.prev",
          "op": "<",
          "right": "ema9"
        },
        {
          "left": "low.prev",
          "op": ">=",
          "right": "low.prev2"
        },
        {
          "left": "volume",
          "op": ">",
          "right": "volume.sma20"
        }
      ]
    },
    "short": {
      "operator": "AND",
      "conditions": [
        {
          "left": "ema9.prev3",
          "op": ">",
          "right": "ema9.prev2"
        },
        {
          "left": "ema9.prev2",
          "op": "<",
          "right": "ema9.prev"
        },
        {
          "left": "ema9.prev",
          "op": ">",
          "right": "ema9"
        },
        {
          "left": "high.prev",
          "op": "<=",
          "right": "high.prev2"
        },
        {
          "left": "volume",
          "op": ">",
          "right": "volume.sma20"
        }
      ]
    }
  },
  "exit": {
    "stopLoss": {
      "type": "swingHighLow",
      "lookback": 3,
      "buffer": 0.1,
      "indicator": "atr"
    },
    "takeProfit": {
      "type": "riskReward",
      "multiplier": "$atrTargetMultiplier"
    },
    "trailingStop": {
      "enabled": true,
      "type": "atr",
      "initialMultiplier": 2,
      "trailMultiplier": 1.5,
      "breakEvenAfterR": 1
    }
  },
  "confidence": {
    "base": 55,
    "bonuses": [
      {
        "condition": {
          "left": "volume",
          "op": ">",
          "right": "volume.sma20"
        },
        "bonus": 20,
        "description": "Volume confirmation"
      },
      {
        "condition": {
          "left": "close",
          "op": ">",
          "right": "ema200"
        },
        "bonus": 10,
        "description": "Above EMA200 (bullish context)"
      },
      {
        "condition": {
          "left": "close",
          "op": "<",
          "right": "ema200"
        },
        "bonus": 10,
        "description": "Below EMA200 (bearish context)"
      }
    ],
    "max": 100
  },
  "filters": {
    "minConfidence": 60,
    "minRiskReward": 1.5,
    "trendFilter": {
      "enabled": true,
      "indicator": "ema",
      "period": 200,
      "allowCounterTrend": false
    }
  }
}
