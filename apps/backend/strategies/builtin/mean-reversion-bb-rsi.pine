// @id mean-reversion-bb-rsi
// @name Mean Reversion (Bollinger + RSI)
// @version 1.0.0
// @description Long quando preço toca banda inferior do Bollinger + RSI oversold. Short quando toca banda superior + RSI overbought.
// @author MarketMind
// @tags mean-reversion,bollinger-bands,rsi,momentum
// @strategyType MEAN_REVERSION
// @momentumType BREAKOUT
// @param bbPeriod Período das Bollinger Bands
// @param bbStdDev Desvio padrão das bandas
// @param rsiPeriod Período do RSI
// @param rsiOversold Nível de oversold do RSI
// @param rsiOverbought Nível de overbought do RSI
// @param atrMultiplier Multiplicador do ATR para stop loss

//@version=5
indicator('Mean Reversion (Bollinger + RSI)', overlay=true)

bbPeriod = input.int(20, 'bbPeriod', minval=10, maxval=50, step=5)
bbStdDev = input.float(2, 'bbStdDev', minval=1.5, maxval=3, step=0.5)
rsiPeriod = input.int(14, 'rsiPeriod', minval=7, maxval=21, step=1)
rsiOversold = input.int(30, 'rsiOversold', minval=20, maxval=40, step=5)
rsiOverbought = input.int(70, 'rsiOverbought', minval=60, maxval=80, step=5)
atrMultiplier = input.float(2, 'atrMultiplier', minval=1, maxval=4, step=0.5)

[bb_middle, bb_upper, bb_lower] = ta.bb(close, bbPeriod, bbStdDev)
bb_bandwidth = (bb_upper - bb_lower) / bb_middle
rsi = ta.rsi(close, rsiPeriod)
atr = ta.atr(14)
atrVal = atr

volSma20 = ta.sma(volume, 20)

longEntry = (close <= bb_lower and rsi <= rsiOversold)
shortEntry = (close >= bb_upper and rsi >= rsiOverbought)

confBase = 60
confBonus0 = rsi < 25 ? 10 : 0
confBonus1 = rsi > 75 ? 10 : 0
confBonus2 = volume > ta.sma(volume, 20) ? 10 : 0
confValue = math.min(confBase + confBonus0 + confBonus1 + confBonus2, 95)

exitLong = false
exitShort = false

sig = longEntry ? 1 : shortEntry ? -1 : 0
sl = longEntry ? close - atrVal * 0.6 : shortEntry ? close + atrVal * 0.6 : na
tp = longEntry ? close + atrVal * 4 : shortEntry ? close - atrVal * 4 : na
conf = longEntry or shortEntry ? confValue : 0
exitSig = exitLong ? 1 : exitShort ? -1 : 0

plot(sig, 'signal', display=display.none)
plot(sl, 'stopLoss', display=display.none)
plot(tp, 'takeProfit', display=display.none)
plot(conf, 'confidence', display=display.none)
plot(exitSig, 'exitSignal', display=display.none)
