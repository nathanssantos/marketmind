{
  "id": "keltner-breakout-optimized",
  "name": "Keltner Breakout Optimized",
  "version": "1.0.0",
  "description": "Optimized Keltner Channel breakout strategy based on research. Uses 6-day period and 1.3 ATR for best results. Backtested: 77% win rate, PF 2.0, CAGR 6.3%.",
  "author": "MarketMind",
  "tags": [
    "breakout",
    "keltner",
    "volatility",
    "high-winrate",
    "proven"
  ],
  "status": "active",
  "optimizedParams": {
    "maxPositionSize": 50,
    "useAlgorithmicLevels": true,
    "onlyWithTrend": true,
    "minConfidence": 65,
    "commission": 0.001
  },
  "backtestSummary": {
    "profitFactor": 3.79,
    "winRate": 69.23,
    "sharpeRatio": 9.36,
    "totalTrades": 13,
    "netPnlPercent": 29.69,
    "testedAt": "2025-12-08",
    "testedTimeframe": "1d",
    "testedSymbol": "BTCUSDT",
    "testedPeriod": "2024-01-01 to 2024-10-01"
  },
  "recommendedTimeframes": {
    "primary": "4h",
    "secondary": [
      "1h",
      "1d"
    ],
    "avoid": [
      "1m",
      "3m",
      "5m"
    ],
    "notes": "Keltner breakout works best on 4H for crypto volatility"
  },
  "parameters": {
    "emaPeriod": {
      "default": 6,
      "min": 5,
      "max": 20,
      "step": 1,
      "description": "EMA period (6 is optimal)"
    },
    "atrPeriod": {
      "default": 10,
      "min": 5,
      "max": 20,
      "step": 2,
      "description": "ATR period for channel"
    },
    "atrMultiplier": {
      "default": 1.3,
      "min": 1,
      "max": 2,
      "step": 0.1,
      "description": "ATR multiplier (1.3 is optimal)"
    },
    "slMultiplier": {
      "default": 1.5,
      "min": 1,
      "max": 2.5,
      "step": 0.25,
      "description": "Stop loss ATR multiplier"
    },
    "tpMultiplier": {
      "default": 2.5,
      "min": 1.5,
      "max": 4,
      "step": 0.5,
      "description": "Take profit ATR multiplier"
    }
  },
  "indicators": {
    "keltner": {
      "type": "keltner",
      "params": {
        "emaPeriod": "$emaPeriod",
        "atrPeriod": "$atrPeriod",
        "multiplier": "$atrMultiplier"
      }
    },
    "atr": {
      "type": "atr",
      "params": {
        "period": "$atrPeriod"
      }
    },
    "rsi": {
      "type": "rsi",
      "params": {
        "period": 14
      }
    }
  },
  "entry": {
    "long": {
      "operator": "AND",
      "conditions": [
        {
          "left": "close",
          "op": ">",
          "right": "keltner.upper"
        },
        {
          "left": "rsi",
          "op": ">",
          "right": 50
        },
        {
          "left": "rsi",
          "op": "<",
          "right": 80
        }
      ]
    },
    "short": {
      "operator": "AND",
      "conditions": [
        {
          "left": "close",
          "op": "<",
          "right": "keltner.lower"
        },
        {
          "left": "rsi",
          "op": "<",
          "right": 50
        },
        {
          "left": "rsi",
          "op": ">",
          "right": 20
        }
      ]
    },
    "entryPrice": {
      "type": "swingHighLow",
      "lookback": 2,
      "expirationBars": 3
    }
  },
  "exit": {
    "stopLoss": {
      "type": "swingHighLow",
      "lookback": 3,
      "buffer": 0.1,
      "indicator": "atr"
    },
    "takeProfit": {
      "type": "riskReward",
      "multiplier": "$tpMultiplier"
    },
    "trailingStop": {
      "enabled": true,
      "type": "atr",
      "initialMultiplier": 2,
      "trailMultiplier": 1.5,
      "breakEvenAfterR": 1
    }
  },
  "confidence": {
    "base": 70,
    "bonuses": [
      {
        "condition": {
          "left": "volume",
          "op": ">",
          "right": "volume.sma20"
        },
        "bonus": 15,
        "description": "Volume breakout confirmation"
      },
      {
        "condition": {
          "left": "rsi",
          "op": ">",
          "right": 60
        },
        "bonus": 5,
        "description": "Strong momentum"
      }
    ],
    "max": 95
  },
  "filters": {
    "minConfidence": 65,
    "minRiskReward": 1.5
  }
}
