{
  "id": "rsi2-extreme-reversal",
  "name": "RSI 2 Extreme Reversal",
  "version": "1.0.0",
  "description": "Extreme mean-reversion strategy using RSI(2) at extreme levels. LONG when RSI(2) < 5 (extreme oversold), SHORT when RSI(2) > 95 (extreme overbought). Stop below/above previous swing low/high, target at previous swing high/low.",
  "author": "MarketMind",
  "tags": [
    "mean-reversion",
    "rsi2",
    "extreme",
    "bidirectional"
  ],
  "status": "unprofitable",
  "recommendedTimeframes": {
    "primary": "1d",
    "secondary": [
      "4h",
      "1h"
    ],
    "avoid": [
      "1m",
      "5m"
    ],
    "notes": "RSI(2) extreme reversal works best on higher timeframes where moves are more significant"
  },
  "parameters": {
    "rsiPeriod": {
      "default": 2,
      "min": 2,
      "max": 3,
      "step": 1,
      "description": "RSI period (2 is standard)"
    },
    "rsiOversold": {
      "default": 5,
      "min": 2,
      "max": 10,
      "step": 1,
      "description": "RSI oversold threshold for LONG entry"
    },
    "rsiOverbought": {
      "default": 95,
      "min": 90,
      "max": 98,
      "step": 1,
      "description": "RSI overbought threshold for SHORT entry"
    },
    "swingLookback": {
      "default": 10,
      "min": 5,
      "max": 20,
      "step": 1,
      "description": "Lookback period for swing high/low detection"
    },
    "atrPeriod": {
      "default": 14,
      "min": 10,
      "max": 20,
      "step": 2,
      "description": "ATR period for buffer calculation"
    },
    "slBuffer": {
      "default": 0.3,
      "min": 0.1,
      "max": 1,
      "step": 0.1,
      "description": "ATR buffer below/above swing for stop loss"
    }
  },
  "indicators": {
    "rsi2": {
      "type": "rsi",
      "params": {
        "period": "$rsiPeriod"
      }
    },
    "atr": {
      "type": "atr",
      "params": {
        "period": "$atrPeriod"
      }
    }
  },
  "entry": {
    "long": {
      "operator": "AND",
      "conditions": [
        {
          "left": "rsi2",
          "op": "<",
          "right": "$rsiOversold"
        }
      ]
    },
    "short": {
      "operator": "AND",
      "conditions": [
        {
          "left": "rsi2",
          "op": ">",
          "right": "$rsiOverbought"
        }
      ]
    }
  },
  "exit": {
    "stopLoss": {
      "type": "swingHighLow",
      "buffer": "$slBuffer",
      "indicator": "atr",
      "lookback": "$swingLookback"
    },
    "takeProfit": {
      "type": "swingHighLow",
      "lookback": "$swingLookback"
    },
    "maxBarsInTrade": 15
  },
  "confidence": {
    "base": 80,
    "bonuses": [
      {
        "condition": {
          "left": "rsi2",
          "op": "<",
          "right": 2
        },
        "bonus": 10,
        "description": "Ultra extreme oversold (RSI < 2)"
      },
      {
        "condition": {
          "left": "rsi2",
          "op": ">",
          "right": 98
        },
        "bonus": 10,
        "description": "Ultra extreme overbought (RSI > 98)"
      },
      {
        "condition": {
          "left": "volume",
          "op": ">",
          "right": "volume.sma20"
        },
        "bonus": 5,
        "description": "Volume confirmation"
      }
    ],
    "max": 95
  },
  "filters": {
    "minConfidence": 70,
    "minRiskReward": 1
  }
}
