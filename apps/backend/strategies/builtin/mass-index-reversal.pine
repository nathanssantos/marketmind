// @id mass-index-reversal
// @name Mass Index Reversal
// @version 1.0.0
// @description Mass Index para prever reversões. Mede range expansion/contraction. Entry quando Mass Index > 27 e depois cai abaixo de 26.5 (reversal bulge).
// @author MarketMind
// @tags reversal,mass-index,volatility,range
// @strategyType ANY
// @momentumType REVERSAL
// @param emaPeriod Período EMA para Mass Index
// @param sumPeriod Período de soma
// @param bulgeThreshold Threshold para bulge
// @param atrMultiplier ATR para stop

//@version=5
indicator('Mass Index Reversal', overlay=true)

emaPeriod = input.int(9, 'emaPeriod', minval=7, maxval=12, step=1)
sumPeriod = input.int(25, 'sumPeriod', minval=20, maxval=30, step=5)
bulgeThreshold = input.float(27, 'bulgeThreshold', minval=26, maxval=28, step=0.5)
atrMultiplier = input.float(2, 'atrMultiplier', minval=1.5, maxval=3, step=0.5)

massIndex_e1 = ta.ema(high - low, emaPeriod)
massIndex_e2 = ta.ema(massIndex_e1, emaPeriod)
massIndex_ratio = massIndex_e1 / math.max(massIndex_e2, 0.0001)
massIndex = math.sum(massIndex_ratio, sumPeriod)
ema9 = ta.ema(close, 9)
atr = ta.atr(14)
atrVal = atr

volSma20 = ta.sma(volume, 20)

longEntry = (massIndex[1] > bulgeThreshold and massIndex < 26.5 and close < ema9)
shortEntry = (massIndex[1] > bulgeThreshold and massIndex < 26.5 and close > ema9)

confBase = 70
confBonus0 = volume > ta.sma(volume, 20) ? 10 : 0
confValue = math.min(confBase + confBonus0, 85)

exitLong = false
exitShort = false

sig = longEntry ? 1 : shortEntry ? -1 : 0
sl = longEntry ? close - atrVal * 0.6 : shortEntry ? close + atrVal * 0.6 : na
tp = longEntry ? close + math.abs(close - (close - atrVal * 0.6)) * 2 : shortEntry ? close - math.abs((close + atrVal * 0.6) - close) * 2 : na
conf = longEntry or shortEntry ? confValue : 0
exitSig = exitLong ? 1 : exitShort ? -1 : 0

plot(sig, 'signal', display=display.none)
plot(sl, 'stopLoss', display=display.none)
plot(tp, 'takeProfit', display=display.none)
plot(conf, 'confidence', display=display.none)
plot(exitSig, 'exitSignal', display=display.none)
