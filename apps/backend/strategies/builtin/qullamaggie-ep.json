{
  "id": "qullamaggie-ep",
  "name": "Qullamaggie Episodic Pivot",
  "version": "1.0.0",
  "description": "Kristjan Kullamägi's Episodic Pivot (EP) setup. Detects gap ups of 5%+ with extreme volume on catalysts (earnings, news). Entry above opening range highs. One of his 3 'timeless' setups.",
  "author": "Kristjan Kullamägi / MarketMind",
  "tags": [
    "qullamaggie",
    "episodic-pivot",
    "gap",
    "momentum",
    "catalyst"
  ],
  "status": "active",
  "optimizedParams": {
    "maxPositionSize": 100,
    "useAlgorithmicLevels": true,
    "onlyWithTrend": false,
    "minConfidence": 65,
    "commission": 0.001,
    "maxConcurrentPositions": 2,
    "maxTotalExposure": 60,
    "trailingATRMultiplier": 2,
    "breakEvenAfterR": 1
  },
  "recommendedTimeframes": {
    "primary": "1d",
    "secondary": [
      "4h",
      "1h"
    ],
    "avoid": [
      "1m",
      "5m"
    ],
    "notes": "Best on daily for swing trades. Can use 1h for intraday entry timing after gap."
  },
  "parameters": {
    "minGapPercent": {
      "default": 5,
      "min": 3,
      "max": 15,
      "step": 1,
      "description": "Minimum gap up % (5% for crypto, 10% for stocks)"
    },
    "volumeMultiplier": {
      "default": 2,
      "min": 1.5,
      "max": 4,
      "step": 0.5,
      "description": "Minimum volume as multiplier of 20-period average"
    },
    "atrPeriod": {
      "default": 14,
      "min": 7,
      "max": 21,
      "step": 1,
      "description": "ATR period for stop/target calculation"
    },
    "ema10Period": {
      "default": 10,
      "min": 8,
      "max": 12,
      "step": 1,
      "description": "Fast EMA for trailing stop"
    },
    "ema20Period": {
      "default": 20,
      "min": 18,
      "max": 22,
      "step": 1,
      "description": "Slow EMA for trailing stop"
    },
    "priorMoveCheck": {
      "default": 60,
      "min": 30,
      "max": 90,
      "step": 10,
      "description": "Bars to check that stock hasn't rallied substantially"
    },
    "maxPriorGain": {
      "default": 30,
      "min": 20,
      "max": 50,
      "step": 5,
      "description": "Max % gain in prior period (to ensure fresh catalyst)"
    }
  },
  "indicators": {
    "ema10": {
      "type": "ema",
      "params": {
        "period": "$ema10Period"
      }
    },
    "ema20": {
      "type": "ema",
      "params": {
        "period": "$ema20Period"
      }
    },
    "ema200": {
      "type": "ema",
      "params": {
        "period": 200
      }
    },
    "atr": {
      "type": "atr",
      "params": {
        "period": "$atrPeriod"
      }
    },
    "highestHigh60": {
      "type": "highest",
      "params": {
        "period": "$priorMoveCheck",
        "source": "high"
      }
    },
    "lowestLow60": {
      "type": "lowest",
      "params": {
        "period": "$priorMoveCheck",
        "source": "low"
      }
    }
  },
  "entry": {
    "long": {
      "operator": "AND",
      "conditions": [
        {
          "left": {
            "calc": "(open - close.prev) / close.prev * 100"
          },
          "op": ">=",
          "right": "$minGapPercent"
        },
        {
          "left": "volume",
          "op": ">",
          "right": {
            "calc": "volume.sma20 * $volumeMultiplier"
          }
        },
        {
          "left": "close",
          "op": ">",
          "right": "open"
        },
        {
          "left": "close",
          "op": ">",
          "right": "high.prev"
        },
        {
          "left": {
            "calc": "(highestHigh60.prev - lowestLow60.prev) / lowestLow60.prev * 100"
          },
          "op": "<=",
          "right": "$maxPriorGain"
        }
      ]
    },
    "short": {
      "operator": "AND",
      "conditions": [
        {
          "left": {
            "calc": "(close.prev - open) / close.prev * 100"
          },
          "op": ">=",
          "right": "$minGapPercent"
        },
        {
          "left": "volume",
          "op": ">",
          "right": {
            "calc": "volume.sma20 * $volumeMultiplier"
          }
        },
        {
          "left": "close",
          "op": "<",
          "right": "open"
        },
        {
          "left": "close",
          "op": "<",
          "right": "low.prev"
        },
        {
          "left": {
            "calc": "(highestHigh60.prev - lowestLow60.prev) / highestHigh60.prev * 100"
          },
          "op": "<=",
          "right": "$maxPriorGain"
        }
      ]
    }
  },
  "exit": {
    "stopLoss": {
      "type": "swingHighLow",
      "lookback": 1,
      "buffer": 0.3,
      "indicator": "atr"
    },
    "takeProfit": {
      "type": "riskReward",
      "multiplier": 3
    },
    "trailingStop": {
      "enabled": true,
      "type": "indicator",
      "indicator": "ema10",
      "initialMultiplier": 1.5,
      "trailMultiplier": 1,
      "breakEvenAfterR": 1
    }
  },
  "confidence": {
    "base": 55,
    "bonuses": [
      {
        "condition": {
          "left": {
            "calc": "(open - close.prev) / close.prev * 100"
          },
          "op": ">=",
          "right": 10
        },
        "bonus": 15,
        "description": "Large gap (10%+ - very strong catalyst)"
      },
      {
        "condition": {
          "left": "volume",
          "op": ">",
          "right": {
            "calc": "volume.sma20 * 3"
          }
        },
        "bonus": 15,
        "description": "Extreme volume (3x+ average)"
      },
      {
        "condition": {
          "left": "close",
          "op": ">",
          "right": "ema200"
        },
        "bonus": 10,
        "description": "Above EMA200 (macro trend aligned)"
      },
      {
        "condition": {
          "left": {
            "calc": "(close - open) / open * 100"
          },
          "op": ">=",
          "right": 3
        },
        "bonus": 5,
        "description": "Strong close (gap held and extended)"
      }
    ],
    "max": 100
  },
  "filters": {
    "minConfidence": 60,
    "minRiskReward": 1.5,
    "trendFilter": {
      "enabled": false,
      "indicator": "ema",
      "period": 200,
      "allowCounterTrend": true
    }
  },
  "education": {
    "origin": "Kristjan Kullamägi (Qullamaggie) - 'Episodic Pivots are my bread and butter'",
    "createdYear": 2015,
    "candlePattern": {
      "lookback": 3,
      "candles": [
        { "offset": -2, "role": "prior_close", "descriptionKey": "strategies.qullamEp.candleMinus2" },
        { "offset": -1, "role": "gap_reference", "descriptionKey": "strategies.qullamEp.candleMinus1" },
        { "offset": 0, "role": "gap_day", "descriptionKey": "strategies.qullamEp.candleTrigger" }
      ],
      "indicatorsToShow": ["ema10", "ema20", "volume"]
    },
    "howItWorks": {
      "summaryKey": "strategies.qullamEp.summary",
      "entryKey": "strategies.qullamEp.entry",
      "exitKey": "strategies.qullamEp.exit"
    }
  }
}
