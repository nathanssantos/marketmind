// @id awesome-oscillator-crypto
// @name Awesome Oscillator Crypto
// @version 1.0.0
// @description Bill Williams Awesome Oscillator strategy. Mede momentum do mercado com diferença SMA(5)-SMA(34) de HL/2. Entry em saucer patterns.
// @author MarketMind
// @tags momentum,awesome-oscillator,bill-williams
// @strategyType ANY
// @momentumType BREAKOUT
// @param fastPeriod Período SMA rápida
// @param slowPeriod Período SMA lenta
// @param atrMultiplier ATR para stop

//@version=5
indicator('Awesome Oscillator Crypto', overlay=true)

fastPeriod = input.int(5, 'fastPeriod', minval=3, maxval=7, step=1)
slowPeriod = input.int(34, 'slowPeriod', minval=30, maxval=40, step=2)
atrMultiplier = input.float(2, 'atrMultiplier', minval=1.5, maxval=3, step=0.5)

ao = ta.sma(hl2, fastPeriod) - ta.sma(hl2, slowPeriod)
atr = ta.atr(14)
atrVal = atr

volSma20 = ta.sma(volume, 20)

longEntry = ta.crossover(ao, 0)
shortEntry = ta.crossunder(ao, 0)

confBase = 65
confBonus0 = ao > ao[1] ? 5 : 0
confBonus1 = volume > ta.sma(volume, 20) ? 10 : 0
confValue = math.min(confBase + confBonus0 + confBonus1, 85)

exitLong = ta.crossunder(ao, 0)
exitShort = ta.crossover(ao, 0)

sig = longEntry ? 1 : shortEntry ? -1 : 0
sl = longEntry ? close - atrVal * 0.6 : shortEntry ? close + atrVal * 0.6 : na
tp = longEntry ? close + math.abs(close - (close - atrVal * 0.6)) * 2 : shortEntry ? close - math.abs((close + atrVal * 0.6) - close) * 2 : na
conf = longEntry or shortEntry ? confValue : 0
exitSig = exitLong ? 1 : exitShort ? -1 : 0

plot(sig, 'signal', display=display.none)
plot(sl, 'stopLoss', display=display.none)
plot(tp, 'takeProfit', display=display.none)
plot(conf, 'confidence', display=display.none)
plot(exitSig, 'exitSignal', display=display.none)
