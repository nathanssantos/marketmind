{
  "id": "klinger-oscillator",
  "name": "Klinger Oscillator",
  "version": "1.0.0",
  "description": "Klinger Volume Oscillator para detectar fluxo de dinheiro long-term. Combina price movement com volume para confirmar tend\u00eancias.",
  "author": "MarketMind",
  "tags": [
    "volume",
    "klinger",
    "money-flow",
    "trend"
  ],
  "source": "Stephen Klinger - KVO Creator",
  "status": "active",
  "optimizedParams": {
    "maxPositionSize": 70,
    "maxConcurrentPositions": 2,
    "maxTotalExposure": 80,
    "useAlgorithmicLevels": true,
    "useTrailingStop": false,
    "onlyWithTrend": false,
    "minConfidence": 70,
    "commission": 0.001
  },
  "recommendedTimeframes": {
    "primary": "1d",
    "secondary": [
      "4h"
    ],
    "avoid": [
      "1m",
      "5m"
    ],
    "notes": "Klinger works best on daily"
  },
  "parameters": {
    "fastPeriod": {
      "default": 34,
      "min": 30,
      "max": 40,
      "step": 2,
      "description": "Per\u00edodo EMA r\u00e1pida"
    },
    "slowPeriod": {
      "default": 55,
      "min": 50,
      "max": 60,
      "step": 5,
      "description": "Per\u00edodo EMA lenta"
    },
    "signalPeriod": {
      "default": 13,
      "min": 10,
      "max": 18,
      "step": 1,
      "description": "Per\u00edodo signal line"
    },
    "atrMultiplier": {
      "default": 2,
      "min": 1.5,
      "max": 3,
      "step": 0.5,
      "description": "ATR para stop"
    }
  },
  "indicators": {
    "klinger": {
      "type": "klinger",
      "params": {
        "fastPeriod": "$fastPeriod",
        "slowPeriod": "$slowPeriod",
        "signalPeriod": "$signalPeriod"
      }
    },
    "atr": {
      "type": "atr",
      "params": {
        "period": 14
      }
    }
  },
  "entry": {
    "long": {
      "operator": "AND",
      "conditions": [
        {
          "left": "klinger.kvo",
          "op": "crossover",
          "right": "klinger.signal"
        }
      ]
    },
    "short": {
      "operator": "AND",
      "conditions": [
        {
          "left": "klinger.kvo",
          "op": "crossunder",
          "right": "klinger.signal"
        }
      ]
    }
  },
  "exit": {
    "stopLoss": {
      "type": "swingHighLow",
      "lookback": 3,
      "buffer": 0.6,
      "indicator": "atr"
    },
    "takeProfit": {
      "type": "riskReward",
      "multiplier": 2
    },
    "conditions": {
      "long": {
        "operator": "OR",
        "conditions": [
          {
            "left": "klinger.kvo",
            "op": "crossunder",
            "right": "klinger.signal"
          }
        ]
      },
      "short": {
        "operator": "OR",
        "conditions": [
          {
            "left": "klinger.kvo",
            "op": "crossover",
            "right": "klinger.signal"
          }
        ]
      }
    },
    "trailingStop": {
      "enabled": true,
      "type": "atr",
      "initialMultiplier": 2,
      "trailMultiplier": 1.5,
      "breakEvenAfterR": 1
    }
  },
  "confidence": {
    "base": 70,
    "bonuses": [
      {
        "condition": {
          "left": "klinger.kvo",
          "op": ">",
          "right": 0
        },
        "bonus": 5,
        "description": "KVO positive"
      },
      {
        "condition": {
          "left": "volume",
          "op": ">",
          "right": "volume.sma20"
        },
        "bonus": 10,
        "description": "Volume confirms"
      }
    ],
    "max": 90
  },
  "filters": {
    "minConfidence": 70,
    "minRiskReward": 1.5
  }
}