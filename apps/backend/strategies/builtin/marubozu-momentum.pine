// @id marubozu-momentum
// @name Marubozu Momentum
// @version 1.0.0
// @description Marubozu candlestick pattern (sem sombras). Indica forte convicção direcional. Entry na direção do Marubozu com confirmação.
// @author MarketMind
// @tags momentum,candlestick,marubozu,trend-continuation
// @strategyType TREND_FOLLOWING
// @momentumType BREAKOUT
// @param wickTolerance Tolerância máxima para wicks (%)
// @param atrMultiplier ATR para stop

//@version=5
indicator('Marubozu Momentum', overlay=true)

wickTolerance = input.float(0.1, 'wickTolerance', minval=0.05, maxval=0.2, step=0.05)
atrMultiplier = input.float(2, 'atrMultiplier', minval=1.5, maxval=3, step=0.5)

atr = ta.atr(14)
atrVal = atr

volSma20 = ta.sma(volume, 20)

longEntry = (close > open and ((high - close) / (high - low)) < wickTolerance and ((open - low) / (high - low)) < wickTolerance)
shortEntry = (close < open and ((high - open) / (high - low)) < wickTolerance and ((close - low) / (high - low)) < wickTolerance)

confBase = 70
confBonus0 = volume > ta.sma(volume, 20) ? 15 : 0
confValue = math.min(confBase + confBonus0, 90)

exitLong = false
exitShort = false

sig = longEntry ? 1 : shortEntry ? -1 : 0
sl = longEntry ? close - atrVal * 0.6 : shortEntry ? close + atrVal * 0.6 : na
tp = longEntry ? close + math.abs(close - (close - atrVal * 0.6)) * 2 : shortEntry ? close - math.abs((close + atrVal * 0.6) - close) * 2 : na
conf = longEntry or shortEntry ? confValue : 0
exitSig = exitLong ? 1 : exitShort ? -1 : 0

plot(sig, 'signal', display=display.none)
plot(sl, 'stopLoss', display=display.none)
plot(tp, 'takeProfit', display=display.none)
plot(conf, 'confidence', display=display.none)
plot(exitSig, 'exitSignal', display=display.none)
