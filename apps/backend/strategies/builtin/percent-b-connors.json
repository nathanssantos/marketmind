{
  "id": "percent-b-connors",
  "name": "Percent B Connors",
  "version": "1.0.0",
  "description": "Larry Connors' %b strategy from 'Short-Term Trading Strategies That Work'. Buy when %b < 0.2 for 3+ consecutive days while above 200 SMA. Research shows 87% win rate with average hold of 4 days.",
  "author": "MarketMind",
  "tags": [
    "mean-reversion",
    "connors",
    "bollinger",
    "classic",
    "proven"
  ],
  "status": "active",
  "enabled": false,
  "group": "reversal",
  "recommendedTimeframes": {
    "primary": "1d",
    "secondary": [
      "4h"
    ],
    "avoid": [
      "1m",
      "5m",
      "15m",
      "30m"
    ],
    "notes": "Best on daily timeframe. Strategy requires 3 consecutive days below threshold."
  },
  "parameters": {
    "bbPeriod": {
      "default": 20,
      "min": 15,
      "max": 25,
      "step": 5,
      "description": "Bollinger Bands period"
    },
    "bbStdDev": {
      "default": 2,
      "min": 1.5,
      "max": 2.5,
      "step": 0.5,
      "description": "Bollinger Bands std dev"
    },
    "percentBEntry": {
      "default": 0.2,
      "min": 0.1,
      "max": 0.3,
      "step": 0.05,
      "description": "%b entry threshold"
    },
    "percentBExit": {
      "default": 0.8,
      "min": 0.7,
      "max": 0.9,
      "step": 0.05,
      "description": "%b exit threshold"
    },
    "smaTrend": {
      "default": 200,
      "min": 100,
      "max": 250,
      "step": 50,
      "description": "Trend filter SMA period"
    },
    "atrPeriod": {
      "default": 14,
      "min": 10,
      "max": 20,
      "step": 2,
      "description": "ATR for stop loss"
    },
    "slMultiplier": {
      "default": 2.5,
      "min": 1.5,
      "max": 4,
      "step": 0.5,
      "description": "Stop loss ATR multiplier"
    }
  },
  "indicators": {
    "percentB": {
      "type": "percentB",
      "params": {
        "period": "$bbPeriod",
        "stdDev": "$bbStdDev"
      }
    },
    "sma200": {
      "type": "sma",
      "params": {
        "period": "$smaTrend"
      }
    },
    "atr": {
      "type": "atr",
      "params": {
        "period": "$atrPeriod"
      }
    }
  },
  "entry": {
    "long": {
      "operator": "AND",
      "conditions": [
        {
          "left": "percentB",
          "op": "<",
          "right": "$percentBEntry"
        },
        {
          "left": "close",
          "op": ">",
          "right": "sma200"
        }
      ]
    }
  },
  "exit": {
    "stopLoss": {
      "type": "swingHighLow",
      "buffer": 0.6,
      "indicator": "atr"
    },
    "takeProfit": {
      "type": "riskReward",
      "multiplier": 2
    },
    "trailingStop": {
      "enabled": false,
      "type": "atr",
      "initialMultiplier": 2,
      "trailMultiplier": 1.5,
      "breakEvenAfterR": 1
    }
  },
  "confidence": {
    "base": 72,
    "bonuses": [
      {
        "condition": {
          "left": "percentB",
          "op": "<",
          "right": 0.1
        },
        "bonus": 12,
        "description": "Extreme oversold %b < 0.1"
      },
      {
        "condition": {
          "left": "percentB",
          "op": "<",
          "right": 0
        },
        "bonus": 8,
        "description": "Below lower band %b < 0"
      },
      {
        "condition": {
          "left": "volume",
          "op": ">",
          "right": "volume.sma20"
        },
        "bonus": 5,
        "description": "Volume confirmation"
      }
    ],
    "max": 95
  },
  "filters": {
    "minConfidence": 70,
    "minRiskReward": 1,
    "trendFilter": {
      "enabled": false,
      "indicator": "ema",
      "period": 200,
      "allowCounterTrend": true
    }
  },
  "education": {
    "origin": "Larry Connors - 'Short-Term Trading Strategies That Work' (2008)",
    "createdYear": 2008,
    "candlePattern": {
      "lookback": 1,
      "candles": [
        {
          "offset": 0,
          "role": "trigger",
          "descriptionKey": "strategies.percentB.candleTrigger"
        }
      ],
      "indicatorsToShow": [
        "percentB",
        "sma200",
        "atr"
      ]
    },
    "howItWorks": {
      "summaryKey": "strategies.percentB.summary",
      "entryKey": "strategies.percentB.entry",
      "exitKey": "strategies.percentB.exit"
    }
  }
}
