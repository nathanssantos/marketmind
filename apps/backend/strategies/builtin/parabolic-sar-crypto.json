{
  "id": "parabolic-sar-crypto",
  "name": "Parabolic SAR Crypto",
  "version": "1.0.0",
  "description": "Parabolic SAR stop and reverse strategy. SAR segue preço e acelera em tendências. Entry quando SAR flip de acima para abaixo ou vice-versa.",
  "author": "MarketMind",
  "tags": [
    "trend-following",
    "parabolic-sar",
    "stop-reverse"
  ],
  "source": "J. Welles Wilder - New Concepts",
  "status": "active",
  "optimizedParams": {
    "maxPositionSize": 80,
    "maxConcurrentPositions": 2,
    "maxTotalExposure": 80,
    "useAlgorithmicLevels": true,
    "useTrailingStop": false,
    "onlyWithTrend": false,
    "minConfidence": 65,
    "commission": 0.001
  },
  "recommendedTimeframes": {
    "primary": "4h",
    "secondary": [
      "1h",
      "1d"
    ],
    "avoid": [
      "1m",
      "5m"
    ],
    "notes": "PSAR works on 4h for crypto"
  },
  "parameters": {
    "sarStart": {
      "default": 0.02,
      "min": 0.01,
      "max": 0.03,
      "step": 0.005,
      "description": "SAR acceleration start"
    },
    "sarIncrement": {
      "default": 0.02,
      "min": 0.01,
      "max": 0.03,
      "step": 0.005,
      "description": "SAR acceleration increment"
    },
    "sarMax": {
      "default": 0.2,
      "min": 0.1,
      "max": 0.3,
      "step": 0.05,
      "description": "SAR max acceleration"
    },
    "atrMultiplier": {
      "default": 1.5,
      "min": 1,
      "max": 2.5,
      "step": 0.5,
      "description": "ATR backup stop"
    }
  },
  "indicators": {
    "sar": {
      "type": "parabolicSar",
      "params": {
        "start": "$sarStart",
        "increment": "$sarIncrement",
        "max": "$sarMax"
      }
    },
    "atr": {
      "type": "atr",
      "params": {
        "period": 14
      }
    }
  },
  "entry": {
    "long": {
      "operator": "AND",
      "conditions": [
        {
          "left": "close",
          "op": ">",
          "right": "sar"
        },
        {
          "left": "close.prev",
          "op": "<=",
          "right": "sar.prev"
        }
      ]
    },
    "short": {
      "operator": "AND",
      "conditions": [
        {
          "left": "close",
          "op": "<",
          "right": "sar"
        },
        {
          "left": "close.prev",
          "op": ">=",
          "right": "sar.prev"
        }
      ]
    },
    "entryPrice": {
      "type": "swingHighLow",
      "expirationBars": 3
    }
  },
  "exit": {
    "stopLoss": {
      "type": "swingHighLow",
      "buffer": 0.6,
      "indicator": "atr"
    },
    "takeProfit": {
      "type": "riskReward",
      "multiplier": 2
    },
    "conditions": {
      "long": {
        "operator": "OR",
        "conditions": [
          {
            "left": "close",
            "op": "<",
            "right": "sar"
          }
        ]
      },
      "short": {
        "operator": "OR",
        "conditions": [
          {
            "left": "close",
            "op": ">",
            "right": "sar"
          }
        ]
      }
    }
  },
  "confidence": {
    "base": 65,
    "bonuses": [
      {
        "condition": {
          "left": "volume",
          "op": ">",
          "right": "volume.sma20"
        },
        "bonus": 10,
        "description": "Volume confirms"
      },
      {
        "condition": {
          "left": "atr",
          "op": ">",
          "right": "atr.prev"
        },
        "bonus": 5,
        "description": "Volatility expansion"
      }
    ],
    "max": 85
  },
  "filters": {
    "minConfidence": 65,
    "minRiskReward": 1.0,
    "trendFilter": {
      "enabled": true,
      "indicator": "ema",
      "period": 200,
      "allowCounterTrend": false
    }
  }
}
