{
  "id": "fair-value-gap",
  "name": "Fair Value Gap",
  "version": "1.0.0",
  "description": "Trading em Fair Value Gaps (FVG/imbalances). Entry quando pre\u00e7o retorna a FVGs n\u00e3o preenchidos. Smart Money Concept.",
  "author": "MarketMind",
  "tags": [
    "price-action",
    "fvg",
    "imbalance",
    "smart-money"
  ],
  "source": "ICT Smart Money Concepts",
  "status": "active",
  "optimizedParams": {
    "maxPositionSize": 70,
    "maxConcurrentPositions": 2,
    "maxTotalExposure": 80,
    "useAlgorithmicLevels": true,
    "useTrailingStop": true,
    "trailingATRMultiplier": 2,
    "breakEvenAfterR": 1,
    "onlyWithTrend": true,
    "minConfidence": 70,
    "commission": 0.001
  },
  "recommendedTimeframes": {
    "primary": "4h",
    "secondary": [
      "1h",
      "1d"
    ],
    "avoid": [
      "1m",
      "5m"
    ],
    "notes": "FVG on 4h"
  },
  "parameters": {
    "minGapSize": {
      "default": 0.5,
      "min": 0.25,
      "max": 1,
      "step": 0.25,
      "description": "Gap m\u00ednimo %"
    },
    "maxAge": {
      "default": 20,
      "min": 10,
      "max": 50,
      "step": 10,
      "description": "Idade m\u00e1xima do FVG em candles"
    },
    "atrMultiplier": {
      "default": 2,
      "min": 1.5,
      "max": 3,
      "step": 0.5,
      "description": "ATR stop"
    }
  },
  "indicators": {
    "fvg": {
      "type": "fvg",
      "params": {
        "minSize": "$minGapSize",
        "maxAge": "$maxAge"
      }
    },
    "ema50": {
      "type": "ema",
      "params": {
        "period": 50
      }
    },
    "atr": {
      "type": "atr",
      "params": {
        "period": 14
      }
    }
  },
  "entry": {
    "long": {
      "operator": "AND",
      "conditions": [
        {
          "left": "close",
          "op": ">",
          "right": "ema50"
        },
        {
          "left": "low",
          "op": "<=",
          "right": "fvg.bullishTop"
        },
        {
          "left": "close",
          "op": ">",
          "right": "fvg.bullishBottom"
        }
      ]
    },
    "short": {
      "operator": "AND",
      "conditions": [
        {
          "left": "close",
          "op": "<",
          "right": "ema50"
        },
        {
          "left": "high",
          "op": ">=",
          "right": "fvg.bearishBottom"
        },
        {
          "left": "close",
          "op": "<",
          "right": "fvg.bearishTop"
        }
      ]
    }
  },
  "exit": {
    "stopLoss": {
      "type": "swingHighLow",
      "buffer": 0.6,
      "indicator": "atr"
    },
    "takeProfit": {
      "type": "riskReward",
      "multiplier": 2
    },
    "trailingStop": {
      "enabled": true,
      "type": "atr",
      "initialMultiplier": 2,
      "trailMultiplier": 2,
      "breakEvenAfterR": 1
    }
  },
  "confidence": {
    "base": 70,
    "bonuses": [
      {
        "condition": {
          "left": "volume",
          "op": ">",
          "right": "volume.sma20"
        },
        "bonus": 10,
        "description": "Volume at FVG"
      }
    ],
    "max": 85
  },
  "filters": {
    "minConfidence": 70,
    "minRiskReward": 1.5
  }
}