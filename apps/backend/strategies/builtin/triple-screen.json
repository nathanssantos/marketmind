{
  "id": "triple-screen",
  "name": "Triple Screen",
  "version": "1.0.0",
  "description": "Sistema Triple Screen de Elder. Tr\u00eas timeframes: weekly para tend\u00eancia, daily para entry, 4h para timing. Filtragem multi-n\u00edvel.",
  "author": "MarketMind",
  "tags": [
    "multi-timeframe",
    "triple-screen",
    "elder",
    "trend-filter"
  ],
  "source": "Dr. Alexander Elder",
  "status": "active",
  "optimizedParams": {
    "maxPositionSize": 80,
    "maxConcurrentPositions": 2,
    "maxTotalExposure": 90,
    "useAlgorithmicLevels": true,
    "useTrailingStop": true,
    "trailingATRMultiplier": 2.5,
    "breakEvenAfterR": 1.5,
    "onlyWithTrend": true,
    "minConfidence": 75,
    "commission": 0.001
  },
  "recommendedTimeframes": {
    "primary": "1d",
    "secondary": [
      "4h",
      "1w"
    ],
    "avoid": [
      "1m",
      "5m"
    ],
    "notes": "Triple screen system with multi-TF"
  },
  "parameters": {
    "trendEma": {
      "default": 26,
      "min": 20,
      "max": 30,
      "step": 2,
      "description": "EMA para tend\u00eancia (weekly)"
    },
    "entryOscillator": {
      "default": 14,
      "min": 10,
      "max": 21,
      "step": 1,
      "description": "RSI para entry (daily)"
    },
    "atrMultiplier": {
      "default": 2,
      "min": 1.5,
      "max": 3,
      "step": 0.5,
      "description": "ATR stop"
    }
  },
  "indicators": {
    "emaWeekly": {
      "type": "ema",
      "params": {
        "period": "$trendEma"
      },
      "timeframe": "1w"
    },
    "macdWeekly": {
      "type": "macd",
      "params": {
        "fastPeriod": 12,
        "slowPeriod": 26,
        "signalPeriod": 9
      },
      "timeframe": "1w"
    },
    "rsiDaily": {
      "type": "rsi",
      "params": {
        "period": "$entryOscillator"
      }
    },
    "atr": {
      "type": "atr",
      "params": {
        "period": 14
      }
    }
  },
  "entry": {
    "long": {
      "operator": "AND",
      "conditions": [
        {
          "left": "macdWeekly.histogram",
          "op": ">",
          "right": 0
        },
        {
          "left": "rsiDaily",
          "op": "crossover",
          "right": 30
        }
      ]
    },
    "short": {
      "operator": "AND",
      "conditions": [
        {
          "left": "macdWeekly.histogram",
          "op": "<",
          "right": 0
        },
        {
          "left": "rsiDaily",
          "op": "crossunder",
          "right": 70
        }
      ]
    }
  },
  "exit": {
    "stopLoss": {
      "type": "swingHighLow",
      "lookback": 3,
      "buffer": 0.1,
      "indicator": "atr"
    },
    "takeProfit": {
      "type": "riskReward",
      "multiplier": 3
    },
    "trailingStop": {
      "enabled": true,
      "type": "atr",
      "initialMultiplier": 2,
      "trailMultiplier": 2.5,
      "breakEvenAfterR": 1.5
    }
  },
  "confidence": {
    "base": 75,
    "bonuses": [
      {
        "condition": {
          "left": "close",
          "op": ">",
          "right": "emaWeekly"
        },
        "bonus": 10,
        "description": "Above weekly EMA"
      }
    ],
    "max": 90
  },
  "filters": {
    "minConfidence": 75,
    "minRiskReward": 2.5
  }
}