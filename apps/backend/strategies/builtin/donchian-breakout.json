{
  "id": "donchian-breakout",
  "name": "Donchian Channel Breakout",
  "version": "1.0.0",
  "description": "Classic breakout strategy using Donchian Channels. Long when price breaks above upper channel, short when price breaks below lower channel. Filtered by ADX for trending markets.",
  "author": "MarketMind",
  "tags": [
    "breakout",
    "donchian",
    "trend-following",
    "adx"
  ],
  "status": "active",
  "enabled": false,
  "backtestSummary": {
    "profitFactor": 1.8,
    "winRate": 41.4,
    "sharpeRatio": 2.4,
    "maxDrawdownPercent": 16.8,
    "totalTrades": 29,
    "netPnlPercent": 32.64,
    "testedAt": "2024-12-09",
    "testedPeriod": "2024-01-01 to 2024-10-01",
    "testedTimeframe": "4h",
    "testedSymbol": "BTCUSDT"
  },
  "recommendedTimeframes": {
    "primary": "1d",
    "secondary": [
      "4h"
    ],
    "avoid": [
      "1m",
      "5m",
      "15m"
    ],
    "notes": "Donchian breakout works best on daily for trend confirmation"
  },
  "parameters": {
    "donchianPeriod": {
      "default": 20,
      "min": 10,
      "max": 50,
      "step": 5,
      "description": "Donchian Channel period"
    },
    "adxPeriod": {
      "default": 14,
      "min": 10,
      "max": 20,
      "step": 2,
      "description": "ADX period"
    },
    "adxThreshold": {
      "default": 20,
      "min": 15,
      "max": 35,
      "step": 5,
      "description": "Minimum ADX for trend confirmation"
    },
    "atrMultiplier": {
      "default": 2,
      "min": 1,
      "max": 3,
      "step": 0.5,
      "description": "ATR multiplier for stop loss"
    },
    "rrMultiplier": {
      "default": 2,
      "min": 1.5,
      "max": 3,
      "step": 0.5,
      "description": "Risk-reward multiplier"
    }
  },
  "indicators": {
    "donchian": {
      "type": "donchian",
      "params": {
        "period": "$donchianPeriod"
      }
    },
    "adx": {
      "type": "adx",
      "params": {
        "period": "$adxPeriod"
      }
    },
    "atr": {
      "type": "atr",
      "params": {
        "period": 14
      }
    }
  },
  "entry": {
    "long": {
      "operator": "AND",
      "conditions": [
        {
          "left": "high",
          "op": ">",
          "right": "donchian.upper.prev"
        },
        {
          "left": "close",
          "op": ">",
          "right": "donchian.middle"
        },
        {
          "left": "adx.adx",
          "op": ">",
          "right": "$adxThreshold"
        }
      ]
    },
    "short": {
      "operator": "AND",
      "conditions": [
        {
          "left": "low",
          "op": "<",
          "right": "donchian.lower.prev"
        },
        {
          "left": "close",
          "op": "<",
          "right": "donchian.middle"
        },
        {
          "left": "adx.adx",
          "op": ">",
          "right": "$adxThreshold"
        }
      ]
    }
  },
  "exit": {
    "stopLoss": {
      "type": "swingHighLow",
      "buffer": 0.6,
      "indicator": "atr"
    },
    "takeProfit": {
      "type": "riskReward",
      "multiplier": "$rrMultiplier"
    },
    "trailingStop": {
      "enabled": false,
      "type": "atr",
      "initialMultiplier": 2,
      "trailMultiplier": 1.5,
      "breakEvenAfterR": 1
    }
  },
  "confidence": {
    "base": 60,
    "bonuses": [
      {
        "condition": {
          "left": "adx.adx",
          "op": ">",
          "right": 30
        },
        "bonus": 10,
        "description": "Strong trend (ADX > 30)"
      },
      {
        "condition": {
          "left": "volume",
          "op": ">",
          "right": "volume.sma20"
        },
        "bonus": 10,
        "description": "Volume above average"
      },
      {
        "condition": {
          "left": "adx.plusDI",
          "op": ">",
          "right": "adx.minusDI"
        },
        "bonus": 5,
        "description": "Bullish DI alignment (for longs)"
      }
    ],
    "max": 90
  },
  "filters": {
    "minConfidence": 60,
    "minRiskReward": 1,
    "volumeType": "BREAKOUT",
    "strategyType": "TREND_FOLLOWING",
    "momentumType": "BREAKOUT"
  }
}
