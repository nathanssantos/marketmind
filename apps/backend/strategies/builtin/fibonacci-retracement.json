{
  "id": "fibonacci-retracement",
  "name": "Fibonacci Retracement",
  "version": "1.0.0",
  "description": "Entry em n\u00edveis Fibonacci de retracement (38.2%, 50%, 61.8%). Espera pullback em tend\u00eancia para n\u00edveis cl\u00e1ssicos de Fibonacci.",
  "author": "MarketMind",
  "tags": [
    "fibonacci",
    "retracement",
    "support-resistance",
    "pullback"
  ],
  "source": "Leonardo Fibonacci - Classic",
  "status": "active",
  "optimizedParams": {
    "maxPositionSize": 70,
    "maxConcurrentPositions": 2,
    "maxTotalExposure": 80,
    "useAlgorithmicLevels": true,
    "useTrailingStop": true,
    "trailingATRMultiplier": 2.5,
    "breakEvenAfterR": 1.5,
    "onlyWithTrend": true,
    "minConfidence": 70,
    "commission": 0.001
  },
  "recommendedTimeframes": {
    "primary": "4h",
    "secondary": [
      "1h",
      "1d"
    ],
    "avoid": [
      "1m",
      "5m"
    ],
    "notes": "Fibonacci works well on 4h"
  },
  "parameters": {
    "lookbackPeriod": {
      "default": 50,
      "min": 30,
      "max": 100,
      "step": 10,
      "description": "Per\u00edodo lookback para swing high/low"
    },
    "fibLevel": {
      "default": 0.618,
      "min": 0.382,
      "max": 0.786,
      "step": 0.118,
      "description": "N\u00edvel Fibonacci target"
    },
    "atrMultiplier": {
      "default": 2,
      "min": 1.5,
      "max": 3,
      "step": 0.5,
      "description": "ATR para stop"
    }
  },
  "indicators": {
    "fib": {
      "type": "fibonacci",
      "params": {
        "lookback": "$lookbackPeriod"
      }
    },
    "ema50": {
      "type": "ema",
      "params": {
        "period": 50
      }
    },
    "atr": {
      "type": "atr",
      "params": {
        "period": 14
      }
    }
  },
  "entry": {
    "long": {
      "operator": "AND",
      "conditions": [
        {
          "left": "close",
          "op": ">",
          "right": "ema50"
        },
        {
          "left": "low",
          "op": "<=",
          "right": "fib.level618"
        },
        {
          "left": "close",
          "op": ">",
          "right": "fib.level618"
        }
      ]
    },
    "short": {
      "operator": "AND",
      "conditions": [
        {
          "left": "close",
          "op": "<",
          "right": "ema50"
        },
        {
          "left": "high",
          "op": ">=",
          "right": "fib.level618"
        },
        {
          "left": "close",
          "op": "<",
          "right": "fib.level618"
        }
      ]
    }
  },
  "exit": {
    "stopLoss": {
      "type": "swingHighLow",
      "lookback": 3,
      "buffer": 0.6,
      "indicator": "atr"
    },
    "takeProfit": {
      "type": "riskReward",
      "multiplier": 2.5
    },
    "trailingStop": {
      "enabled": true,
      "type": "atr",
      "initialMultiplier": 2,
      "trailMultiplier": 2.5,
      "breakEvenAfterR": 1.5
    }
  },
  "confidence": {
    "base": 70,
    "bonuses": [
      {
        "condition": {
          "left": "volume",
          "op": ">",
          "right": "volume.sma20"
        },
        "bonus": 10,
        "description": "Volume at Fib level"
      }
    ],
    "max": 90
  },
  "filters": {
    "minConfidence": 70,
    "minRiskReward": 2
  }
}