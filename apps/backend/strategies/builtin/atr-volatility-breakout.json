{
  "id": "atr-volatility-breakout",
  "name": "ATR Volatility Breakout",
  "version": "1.0.0",
  "description": "Estratégia de breakout baseada em ATR: entry quando preço move mais de 2x ATR da abertura. Stop loss em 1.5x ATR. Captura movimentos explosivos.",
  "author": "MarketMind",
  "tags": [
    "breakout",
    "atr",
    "volatility",
    "momentum"
  ],
  "source": "TastyCrypto - Best Technical Indicators",
  "status": "active",
  "recommendedTimeframes": {
    "primary": "4h",
    "secondary": [
      "1h",
      "1d"
    ],
    "avoid": [
      "1m",
      "5m"
    ],
    "notes": "ATR breakout works well on 4h for crypto"
  },
  "parameters": {
    "atrPeriod": {
      "default": 14,
      "min": 10,
      "max": 21,
      "step": 1,
      "description": "Período do ATR"
    },
    "breakoutMultiplier": {
      "default": 2,
      "min": 1.5,
      "max": 3,
      "step": 0.5,
      "description": "Multiplicador ATR para breakout"
    },
    "stopMultiplier": {
      "default": 1.5,
      "min": 1,
      "max": 2.5,
      "step": 0.5,
      "description": "Multiplicador ATR para stop"
    }
  },
  "indicators": {
    "atr": {
      "type": "atr",
      "params": {
        "period": "$atrPeriod"
      }
    }
  },
  "entry": {
    "long": {
      "operator": "AND",
      "conditions": [
        {
          "left": "close",
          "op": ">",
          "right": {
            "calc": "open + (atr * $breakoutMultiplier)"
          }
        }
      ]
    },
    "short": {
      "operator": "AND",
      "conditions": [
        {
          "left": "close",
          "op": "<",
          "right": {
            "calc": "open - (atr * $breakoutMultiplier)"
          }
        }
      ]
    }
  },
  "exit": {
    "stopLoss": {
      "type": "swingHighLow",
      "buffer": 0.6,
      "indicator": "atr"
    },
    "takeProfit": {
      "type": "riskReward",
      "multiplier": 2
    },
    "trailingStop": {
      "enabled": true,
      "type": "atr",
      "initialMultiplier": 1.5,
      "trailMultiplier": 2,
      "breakEvenAfterR": 1
    }
  },
  "confidence": {
    "base": 65,
    "bonuses": [
      {
        "condition": {
          "left": "volume",
          "op": ">",
          "right": {
            "calc": "volume.sma20 * 1.5"
          }
        },
        "bonus": 15,
        "description": "Volume spike"
      },
      {
        "condition": {
          "left": "atr",
          "op": ">",
          "right": "atr.prev"
        },
        "bonus": 5,
        "description": "Volatility expanding"
      }
    ],
    "max": 90
  },
  "filters": {
    "minConfidence": 65,
    "minRiskReward": 1
  }
}
