{
  "id": "whale-accumulation",
  "name": "Whale Accumulation",
  "version": "1.0.0",
  "description": "Detecta acumula\u00e7\u00e3o de whales via large volume bars. Entry quando volume extremo aparece em consolida\u00e7\u00e3o com price est\u00e1vel.",
  "author": "MarketMind",
  "tags": [
    "whale",
    "accumulation",
    "volume",
    "smart-money"
  ],
  "source": "On-Chain Analysis",
  "status": "active",
  "optimizedParams": {
    "maxPositionSize": 70,
    "maxConcurrentPositions": 2,
    "maxTotalExposure": 80,
    "useAlgorithmicLevels": true,
    "useTrailingStop": true,
    "trailingATRMultiplier": 2.5,
    "breakEvenAfterR": 1.5,
    "onlyWithTrend": false,
    "minConfidence": 70,
    "commission": 0.001
  },
  "recommendedTimeframes": {
    "primary": "4h",
    "secondary": [
      "1h",
      "1d"
    ],
    "avoid": [
      "1m",
      "5m"
    ],
    "notes": "Whale detection on 4h"
  },
  "parameters": {
    "volumeMultiplier": {
      "default": 3,
      "min": 2,
      "max": 5,
      "step": 0.5,
      "description": "Volume > m\u00e9dia * mult"
    },
    "priceChangeMax": {
      "default": 2,
      "min": 1,
      "max": 3,
      "step": 0.5,
      "description": "Max price change % (baixa vol)"
    },
    "atrMultiplier": {
      "default": 2,
      "min": 1.5,
      "max": 3,
      "step": 0.5,
      "description": "ATR stop"
    }
  },
  "indicators": {
    "volumeSma": {
      "type": "sma",
      "params": {
        "period": 20,
        "source": "volume"
      }
    },
    "priceChange": {
      "type": "roc",
      "params": {
        "period": 1
      }
    },
    "ema50": {
      "type": "ema",
      "params": {
        "period": 50
      }
    },
    "atr": {
      "type": "atr",
      "params": {
        "period": 14
      }
    }
  },
  "entry": {
    "long": {
      "operator": "AND",
      "conditions": [
        {
          "left": "volume",
          "op": ">",
          "right": {
            "calc": "volumeSma * $volumeMultiplier"
          }
        },
        {
          "left": {
            "calc": "abs(priceChange)"
          },
          "op": "<",
          "right": "$priceChangeMax"
        },
        {
          "left": "close",
          "op": ">",
          "right": "open"
        }
      ]
    },
    "short": {
      "operator": "AND",
      "conditions": [
        {
          "left": "volume",
          "op": ">",
          "right": {
            "calc": "volumeSma * $volumeMultiplier"
          }
        },
        {
          "left": {
            "calc": "abs(priceChange)"
          },
          "op": "<",
          "right": "$priceChangeMax"
        },
        {
          "left": "close",
          "op": "<",
          "right": "open"
        }
      ]
    }
  },
  "exit": {
    "stopLoss": {
      "type": "swingHighLow",
      "buffer": 0.6,
      "indicator": "atr"
    },
    "takeProfit": {
      "type": "riskReward",
      "multiplier": 2.5
    },
    "trailingStop": {
      "enabled": true,
      "type": "atr",
      "initialMultiplier": 2,
      "trailMultiplier": 2.5,
      "breakEvenAfterR": 1.5
    }
  },
  "confidence": {
    "base": 70,
    "bonuses": [
      {
        "condition": {
          "left": "volume",
          "op": ">",
          "right": {
            "calc": "volumeSma * 5"
          }
        },
        "bonus": 15,
        "description": "Massive volume"
      }
    ],
    "max": 90
  },
  "filters": {
    "minConfidence": 70,
    "minRiskReward": 2
  }
}