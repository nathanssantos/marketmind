// @id funding-rate-arbitrage
// @name Funding Rate Arbitrage
// @version 1.0.0
// @description Estratégia baseada em funding rates de futuros. Entry contra posições extremas de funding. Mean reversion de sentiment.
// @author MarketMind
// @tags funding-rate,sentiment,futures,mean-reversion
// @strategyType MEAN_REVERSION
// @momentumType REVERSAL
// @param extremeFunding Funding rate extreme %
// @param atrMultiplier ATR stop

//@version=5
indicator('Funding Rate Arbitrage', overlay=true)

extremeFunding = input.float(0.1, 'extremeFunding', minval=0.05, maxval=0.2, step=0.025)
atrMultiplier = input.float(2.5, 'atrMultiplier', minval=2, maxval=3.5, step=0.5)

fundingRate = 0.0
ema20 = ta.ema(close, 20)
atr = ta.atr(14)
atrVal = atr

volSma20 = ta.sma(volume, 20)

longEntry = fundingRate < (-1 * extremeFunding)
shortEntry = fundingRate > extremeFunding

confBase = 70
confBonus0 = fundingRate < -0.15 ? 15 : 0
confValue = math.min(confBase + confBonus0, 90)

exitLong = fundingRate > 0
exitShort = fundingRate < 0

sig = longEntry ? 1 : shortEntry ? -1 : 0
sl = longEntry ? close - atrVal * 0.6 : shortEntry ? close + atrVal * 0.6 : na
tp = longEntry ? close + math.abs(close - (close - atrVal * 0.6)) * 2 : shortEntry ? close - math.abs((close + atrVal * 0.6) - close) * 2 : na
conf = longEntry or shortEntry ? confValue : 0
exitSig = exitLong ? 1 : exitShort ? -1 : 0

plot(sig, 'signal', display=display.none)
plot(sl, 'stopLoss', display=display.none)
plot(tp, 'takeProfit', display=display.none)
plot(conf, 'confidence', display=display.none)
plot(exitSig, 'exitSignal', display=display.none)
