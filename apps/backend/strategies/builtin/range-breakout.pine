// @id range-breakout
// @name Range Breakout
// @version 1.0.0
// @description Breakout de range consolidado. Identifica consolidações e entra no breakout. Stop dentro do range, target na extensão.
// @author MarketMind
// @tags breakout,range,consolidation,volatility
// @strategyType TREND_FOLLOWING
// @momentumType BREAKOUT
// @param rangePeriod Período para identificar range
// @param rangeThreshold Range max % para consolidação
// @param atrMultiplier ATR stop

//@version=5
indicator('Range Breakout', overlay=true)

rangePeriod = input.int(20, 'rangePeriod', minval=10, maxval=30, step=5)
rangeThreshold = input.int(5, 'rangeThreshold', minval=3, maxval=10, step=1)
atrMultiplier = input.float(1.5, 'atrMultiplier', minval=1, maxval=2.5, step=0.5)

range_high = ta.highest(high, rangePeriod)
range_low = ta.lowest(low, rangePeriod)
range_isNDayHigh = high >= range_high
range_isNDayLow = low <= range_low
atr = ta.atr(14)
atrVal = atr

volSma20 = ta.sma(volume, 20)

longEntry = ((((range_high - range_low) / range_low) * 100) < rangeThreshold and close > range_high)
shortEntry = ((((range_high - range_low) / range_low) * 100) < rangeThreshold and close < range_low)

confBase = 70
confBonus0 = volume > (ta.sma(volume, 20) * 1.5) ? 15 : 0
confValue = math.min(confBase + confBonus0, 90)

exitLong = false
exitShort = false

sig = longEntry ? 1 : shortEntry ? -1 : 0
sl = longEntry ? close - atrVal * 0.6 : shortEntry ? close + atrVal * 0.6 : na
tp = longEntry ? close + math.abs(close - (close - atrVal * 0.6)) * 2 : shortEntry ? close - math.abs((close + atrVal * 0.6) - close) * 2 : na
conf = longEntry or shortEntry ? confValue : 0
exitSig = exitLong ? 1 : exitShort ? -1 : 0

plot(sig, 'signal', display=display.none)
plot(sl, 'stopLoss', display=display.none)
plot(tp, 'takeProfit', display=display.none)
plot(conf, 'confidence', display=display.none)
plot(exitSig, 'exitSignal', display=display.none)
