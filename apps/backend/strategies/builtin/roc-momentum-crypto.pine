// @id roc-momentum-crypto
// @name ROC Momentum Crypto
// @version 1.0.0
// @description Rate of Change momentum strategy para crypto. ROC mede velocidade de mudança de preço. Entry quando ROC cruza zero ou níveis extremos.
// @author MarketMind
// @tags momentum,roc,rate-of-change,velocity
// @strategyType ANY
// @momentumType BREAKOUT
// @param rocPeriod Período do ROC
// @param atrMultiplier ATR para stop

//@version=5
indicator('ROC Momentum Crypto', overlay=true)

rocPeriod = input.int(12, 'rocPeriod', minval=8, maxval=20, step=2)
atrMultiplier = input.float(2, 'atrMultiplier', minval=1.5, maxval=3, step=0.5)

roc = ta.roc(close, rocPeriod)
atr = ta.atr(14)
atrVal = atr

volSma20 = ta.sma(volume, 20)

longEntry = ta.crossover(roc, 0)
shortEntry = ta.crossunder(roc, 0)

confBase = 65
confBonus0 = roc > 5 ? 10 : 0
confBonus1 = volume > ta.sma(volume, 20) ? 5 : 0
confValue = math.min(confBase + confBonus0 + confBonus1, 85)

exitLong = ta.crossunder(roc, 0)
exitShort = ta.crossover(roc, 0)

sig = longEntry ? 1 : shortEntry ? -1 : 0
sl = longEntry ? close - atrVal * 0.6 : shortEntry ? close + atrVal * 0.6 : na
tp = longEntry ? close + math.abs(close - (close - atrVal * 0.6)) * 2 : shortEntry ? close - math.abs((close + atrVal * 0.6) - close) * 2 : na
conf = longEntry or shortEntry ? confValue : 0
exitSig = exitLong ? 1 : exitShort ? -1 : 0

plot(sig, 'signal', display=display.none)
plot(sl, 'stopLoss', display=display.none)
plot(tp, 'takeProfit', display=display.none)
plot(conf, 'confidence', display=display.none)
plot(exitSig, 'exitSignal', display=display.none)
