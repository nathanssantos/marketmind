    },
    "emaSlow": {
      "default": 55,
      "min": 40,
      "max": 100,
      "step": 10,
      "description": "Slow EMA period"
    },
    "atrPeriod": {
      "default": 14,
      "min": 10,
      "max": 20,
      "step": 2,
      "description": "ATR period"
    },
    "slMultiplier": {
      "default": 1.5,
      "min": 1,
      "max": 2.5,
      "step": 0.25,
      "description": "SL ATR multiplier"
    },
    "tpMultiplier": {
      "default": 3,
      "min": 2,
      "max": 4,
      "step": 0.5,
      "description": "TP ATR multiplier"
    }
  },
  "indicators": {
    "emaFast": {
      "type": "ema",
      "params": {
        "period": "$emaFast"
      }
    },
    "emaMid": {
      "type": "ema",
      "params": {
        "period": "$emaMid"
      }
    },
    "emaSlow": {
      "type": "ema",
      "params": {
        "period": "$emaSlow"
      }
    },
    "atr": {
      "type": "atr",
      "params": {
        "period": "$atrPeriod"
      }
    }
  },
  "entry": {
    "long": {
      "operator": "AND",
      "conditions": [
        {
          "left": "emaFast",
          "op": ">",
          "right": "emaMid"
        },
        {
          "left": "emaMid",
          "op": ">",
          "right": "emaSlow"
        },
        {
          "left": "close",
          "op": "crossover",
          "right": "emaFast"
        }
      ]
    },
    "short": {
      "operator": "AND",
      "conditions": [
        {
          "left": "emaFast",
          "op": "<",
          "right": "emaMid"
        },
        {
          "left": "emaMid",
          "op": "<",
          "right": "emaSlow"
        },
        {
          "left": "close",
          "op": "crossunder",
          "right": "emaFast"
        }
      ]
    }
  },
  "exit": {
    "stopLoss": {
      "type": "swingHighLow",
      "buffer": 0.6,
      "indicator": "atr"
    },
    "takeProfit": {
      "type": "riskReward",
      "multiplier": "$tpMultiplier"
    },
    "trailingStop": {
      "enabled": true,
      "type": "atr",
      "initialMultiplier": 2,
      "trailMultiplier": 1.5,
      "breakEvenAfterR": 1
