// @id golden-cross-sma
// @name Golden Cross SMA 50/200
// @version 1.0.0
// @description Estratégia clássica de Golden Cross: SMA 50 cruza acima da SMA 200 (buy), Death Cross quando cruza abaixo (sell). Backtestada com 1030% retorno cumulativo em 10 anos, Sharpe 1.19.
// @author MarketMind
// @tags trend-following,sma,crossover,golden-cross,long-term
// @strategyType TREND_FOLLOWING
// @momentumType ANY
// @param fastPeriod Período da SMA rápida
// @param slowPeriod Período da SMA lenta
// @param atrMultiplier Multiplicador ATR para stop

//@version=5
indicator('Golden Cross SMA 50/200', overlay=true)

fastPeriod = input.int(50, 'fastPeriod', minval=30, maxval=70, step=10)
slowPeriod = input.int(200, 'slowPeriod', minval=150, maxval=250, step=25)
atrMultiplier = input.float(3, 'atrMultiplier', minval=2, maxval=5, step=0.5)

smaFast = ta.sma(close, fastPeriod)
smaSlow = ta.sma(close, slowPeriod)
atr = ta.atr(14)
atrVal = atr

volSma20 = ta.sma(volume, 20)

longEntry = ta.crossover(smaFast, smaSlow)
shortEntry = ta.crossunder(smaFast, smaSlow)

confBase = 70
confBonus0 = volume > ta.sma(volume, 20) ? 10 : 0
confValue = math.min(confBase + confBonus0, 90)

exitLong = ta.crossunder(smaFast, smaSlow)
exitShort = ta.crossover(smaFast, smaSlow)

sig = longEntry ? 1 : shortEntry ? -1 : 0
sl = longEntry ? close - atrVal * 0.6 : shortEntry ? close + atrVal * 0.6 : na
tp = longEntry ? close + math.abs(close - (close - atrVal * 0.6)) * 4 : shortEntry ? close - math.abs((close + atrVal * 0.6) - close) * 4 : na
conf = longEntry or shortEntry ? confValue : 0
exitSig = exitLong ? 1 : exitShort ? -1 : 0

plot(sig, 'signal', display=display.none)
plot(sl, 'stopLoss', display=display.none)
plot(tp, 'takeProfit', display=display.none)
plot(conf, 'confidence', display=display.none)
plot(exitSig, 'exitSignal', display=display.none)
