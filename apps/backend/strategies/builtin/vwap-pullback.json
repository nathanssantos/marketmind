{
  "id": "vwap-pullback",
  "name": "VWAP Pullback Strategy",
  "version": "1.0.0",
  "description": "VWAP pullback strategy (LONG ONLY). Enters when price is above VWAP with RSI pullback. Best on intraday timeframes (5-15m).",
  "author": "Institutional Trading",
  "source": "VWAP - Volume Weighted Average Price (Institutional benchmark)",
  "tags": [
    "vwap",
    "pullback",
    "intraday",
    "trend-following",
    "2025"
  ],
  "status": "active",
  "enabled": false,
  "backtestSummary": {
    "profitFactor": 0.92,
    "winRate": 36,
    "totalTrades": 25,
    "netPnlPercent": -1.89,
    "testedAt": "2025-12-07",
    "testedTimeframe": "15m",
    "testedSymbol": "BTCUSDT"
  },
  "recommendedTimeframes": {
    "primary": "15m",
    "secondary": [
      "5m",
      "30m"
    ],
    "avoid": [
      "1d",
      "1w"
    ],
    "notes": "VWAP pullback is an intraday strategy - best on 5-30 minute timeframes"
  },
  "parameters": {
    "rsiPeriod": {
      "default": 7,
      "min": 5,
      "max": 14,
      "step": 2,
      "description": "RSI period"
    },
    "rsiOversold": {
      "default": 45,
      "min": 35,
      "max": 55,
      "step": 5,
      "description": "RSI oversold for long (relaxed)"
    },
    "rsiOverbought": {
      "default": 60,
      "min": 50,
      "max": 70,
      "step": 5,
      "description": "RSI overbought for short"
    },
    "emaTrend": {
      "default": 21,
      "min": 15,
      "max": 50,
      "step": 5,
      "description": "Trend EMA"
    },
    "atrPeriod": {
      "default": 14,
      "min": 10,
      "max": 20,
      "step": 2,
      "description": "ATR period"
    },
    "slMultiplier": {
      "default": 1.2,
      "min": 0.8,
      "max": 2,
      "step": 0.2,
      "description": "SL ATR multiplier"
    },
    "tpMultiplier": {
      "default": 2,
      "min": 1.5,
      "max": 3,
      "step": 0.5,
      "description": "TP ATR multiplier"
    }
  },
  "indicators": {
    "vwap": {
      "type": "vwap",
      "params": {}
    },
    "rsi": {
      "type": "rsi",
      "params": {
        "period": "$rsiPeriod"
      }
    },
    "emaTrend": {
      "type": "ema",
      "params": {
        "period": "$emaTrend"
      }
    },
    "atr": {
      "type": "atr",
      "params": {
        "period": "$atrPeriod"
      }
    }
  },
  "entry": {
    "long": {
      "operator": "AND",
      "conditions": [
        {
          "left": "close",
          "op": ">",
          "right": "vwap"
        },
        {
          "left": "rsi",
          "op": "<",
          "right": "$rsiOversold"
        }
      ]
    }
  },
  "exit": {
    "stopLoss": {
      "type": "swingHighLow",
      "buffer": 0.6,
      "indicator": "atr"
    },
    "takeProfit": {
      "type": "riskReward",
      "multiplier": "$tpMultiplier"
    },
    "trailingStop": {
      "enabled": false,
      "type": "atr",
      "initialMultiplier": 2,
      "trailMultiplier": 1.5,
      "breakEvenAfterR": 1
    }
  },
  "confidence": {
    "base": 65,
    "bonuses": [
      {
        "condition": {
          "left": "volume",
          "op": ">",
          "right": "volume.sma20"
        },
        "bonus": 10,
        "description": "Volume above average"
      },
      {
        "condition": {
          "left": "close",
          "op": ">",
          "right": "open"
        },
        "bonus": 5,
        "description": "Bullish candle"
      }
    ],
    "max": 90
  },
  "filters": {
    "minConfidence": 60,
    "minRiskReward": 1,
    "volumeType": "PULLBACK",
    "strategyType": "TREND_FOLLOWING",
    "momentumType": "PULLBACK"
  },
  "education": {
    "origin": "Institutional Trading - VWAP as institutional price benchmark",
    "createdYear": 1988,
    "candlePattern": {
      "lookback": 2,
      "candles": [
        {
          "offset": -1,
          "role": "reference",
          "descriptionKey": "strategies.vwap.candleMinus1"
        },
        {
          "offset": 0,
          "role": "trigger",
          "descriptionKey": "strategies.vwap.candleTrigger"
        }
      ],
      "indicatorsToShow": [
        "vwap",
        "rsi",
        "emaTrend",
        "atr"
      ]
    },
    "howItWorks": {
      "summaryKey": "strategies.vwap.summary",
      "entryKey": "strategies.vwap.entry",
      "exitKey": "strategies.vwap.exit"
    }
  }
}
