// @id liquidation-cascade
// @name Liquidation Cascade
// @version 1.0.0
// @description Entry após cascatas de liquidação. Liquidações massivas criam oportunidades de reversão. Entry contra o movimento extremo.
// @author MarketMind
// @tags liquidation,reversal,futures,extreme
// @strategyType ANY
// @momentumType REVERSAL
// @param liquidationThreshold Liquidação mínima (milhões USD)
// @param priceDropPercent Queda mínima de preço %
// @param atrMultiplier ATR stop

//@version=5
indicator('Liquidation Cascade', overlay=true)

liquidationThreshold = input.int(50, 'liquidationThreshold', minval=20, maxval=100, step=10)
priceDropPercent = input.int(5, 'priceDropPercent', minval=3, maxval=10, step=1)
atrMultiplier = input.float(2.5, 'atrMultiplier', minval=2, maxval=3.5, step=0.5)

liquidations_longLiquidations = 0.0
liquidations_shortLiquidations = 0.0
priceChange = ta.roc(close, 6)
rsi = ta.rsi(close, 7)
atr = ta.atr(14)
atrVal = atr

volSma20 = ta.sma(volume, 20)

longEntry = (liquidations_longLiquidations > liquidationThreshold and priceChange < (-1 * priceDropPercent) and rsi < 25)
shortEntry = (liquidations_shortLiquidations > liquidationThreshold and priceChange > priceDropPercent and rsi > 75)

confBase = 75
confBonus0 = liquidations_longLiquidations > 100 ? 15 : 0
confValue = math.min(confBase + confBonus0, 95)

exitLong = rsi > 50
exitShort = rsi < 50

sig = longEntry ? 1 : shortEntry ? -1 : 0
sl = longEntry ? close - atrVal * 0.6 : shortEntry ? close + atrVal * 0.6 : na
tp = longEntry ? close + math.abs(close - (close - atrVal * 0.6)) * 2 : shortEntry ? close - math.abs((close + atrVal * 0.6) - close) * 2 : na
conf = longEntry or shortEntry ? confValue : 0
exitSig = exitLong ? 1 : exitShort ? -1 : 0

plot(sig, 'signal', display=display.none)
plot(sl, 'stopLoss', display=display.none)
plot(tp, 'takeProfit', display=display.none)
plot(conf, 'confidence', display=display.none)
plot(exitSig, 'exitSignal', display=display.none)
