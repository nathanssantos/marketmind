{
  "id": "volume-price-breakout",
  "name": "Volume Price Breakout",
  "version": "1.0.0",
  "description": "Estratégia de breakout com confirmação de volume: entry quando preço quebra high de N dias COM volume > 150% da média. Volume confirma força do breakout.",
  "author": "MarketMind",
  "tags": [
    "breakout",
    "volume",
    "price-action",
    "confirmation"
  ],
  "source": "BitDegree - Best Crypto Indicators",
  "status": "active",
  "recommendedTimeframes": {
    "primary": "4h",
    "secondary": [
      "1h",
      "1d"
    ],
    "avoid": [
      "1m",
      "5m"
    ],
    "notes": "Volume breakout works well on 4h"
  },
  "parameters": {
    "lookbackPeriod": {
      "default": 10,
      "min": 5,
      "max": 20,
      "step": 5,
      "description": "Período de lookback para high/low"
    },
    "volumeMultiplier": {
      "default": 1.5,
      "min": 1.2,
      "max": 2,
      "step": 0.1,
      "description": "Multiplicador de volume mínimo"
    },
    "atrMultiplier": {
      "default": 2,
      "min": 1.5,
      "max": 3,
      "step": 0.5,
      "description": "Multiplicador ATR para stop"
    }
  },
  "indicators": {
    "range": {
      "type": "nDayHighLow",
      "params": {
        "period": "$lookbackPeriod"
      }
    },
    "volumeSma": {
      "type": "sma",
      "params": {
        "period": 20,
        "source": "volume"
      }
    },
    "atr": {
      "type": "atr",
      "params": {
        "period": 14
      }
    }
  },
  "entry": {
    "long": {
      "operator": "AND",
      "conditions": [
        {
          "left": "close",
          "op": ">",
          "right": "range.high"
        },
        {
          "left": "volume",
          "op": ">",
          "right": {
            "calc": "volumeSma * $volumeMultiplier"
          }
        }
      ]
    },
    "short": {
      "operator": "AND",
      "conditions": [
        {
          "left": "close",
          "op": "<",
          "right": "range.low"
        },
        {
          "left": "volume",
          "op": ">",
          "right": {
            "calc": "volumeSma * $volumeMultiplier"
          }
        }
      ]
    }
  },
  "exit": {
    "stopLoss": {
      "type": "swingHighLow",
      "buffer": 0.6,
      "indicator": "atr"
    },
    "takeProfit": {
      "type": "riskReward",
      "multiplier": 2.5
    },
    "trailingStop": {
      "enabled": true,
      "type": "atr",
      "initialMultiplier": 2,
      "trailMultiplier": 2.5,
      "breakEvenAfterR": 1.5
    }
  },
  "confidence": {
    "base": 70,
    "bonuses": [
      {
        "condition": {
          "left": "volume",
          "op": ">",
          "right": {
            "calc": "volumeSma * 2"
          }
        },
        "bonus": 10,
        "description": "Very high volume"
      }
    ],
    "max": 90
  },
  "filters": {
    "minConfidence": 70,
    "minRiskReward": 2
  }
}
