// @id atr-volatility-breakout
// @name ATR Volatility Breakout
// @version 1.0.0
// @description Estratégia de breakout baseada em ATR: entry quando preço move mais de 2x ATR da abertura. Stop loss em 1.5x ATR. Captura movimentos explosivos.
// @author MarketMind
// @tags breakout,atr,volatility,momentum
// @strategyType TREND_FOLLOWING
// @momentumType BREAKOUT
// @param atrPeriod Período do ATR
// @param breakoutMultiplier Multiplicador ATR para breakout
// @param stopMultiplier Multiplicador ATR para stop

//@version=5
indicator('ATR Volatility Breakout', overlay=true)

atrPeriod = input.int(14, 'atrPeriod', minval=10, maxval=21, step=1)
breakoutMultiplier = input.float(2, 'breakoutMultiplier', minval=1.5, maxval=3, step=0.5)
stopMultiplier = input.float(1.5, 'stopMultiplier', minval=1, maxval=2.5, step=0.5)

atr = ta.atr(atrPeriod)
atrVal = atr

volSma20 = ta.sma(volume, 20)

longEntry = close > (open + (atr * breakoutMultiplier))
shortEntry = close < (open - (atr * breakoutMultiplier))

confBase = 65
confBonus0 = volume > (ta.sma(volume, 20) * 1.5) ? 15 : 0
confBonus1 = atr > atr[1] ? 5 : 0
confValue = math.min(confBase + confBonus0 + confBonus1, 90)

exitLong = false
exitShort = false

sig = longEntry ? 1 : shortEntry ? -1 : 0
sl = longEntry ? close - atrVal * 0.6 : shortEntry ? close + atrVal * 0.6 : na
tp = longEntry ? close + math.abs(close - (close - atrVal * 0.6)) * 2 : shortEntry ? close - math.abs((close + atrVal * 0.6) - close) * 2 : na
conf = longEntry or shortEntry ? confValue : 0
exitSig = exitLong ? 1 : exitShort ? -1 : 0

plot(sig, 'signal', display=display.none)
plot(sl, 'stopLoss', display=display.none)
plot(tp, 'takeProfit', display=display.none)
plot(conf, 'confidence', display=display.none)
plot(exitSig, 'exitSignal', display=display.none)
