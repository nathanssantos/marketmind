{
  "id": "open-interest-divergence",
  "name": "Open Interest Divergence",
  "version": "1.0.0",
  "description": "Detecta divergências entre preço e open interest. OI crescente + preço caindo = acumulação. OI caindo + preço subindo = distribuição.",
  "author": "MarketMind",
  "tags": [
    "open-interest",
    "divergence",
    "futures",
    "smart-money"
  ],
  "source": "Derivatives Market Analysis",
  "status": "active",
  "optimizedParams": {
    "maxPositionSize": 70,
    "maxConcurrentPositions": 2,
    "maxTotalExposure": 80,
    "useAlgorithmicLevels": true,
    "useTrailingStop": true,
    "trailingATRMultiplier": 2,
    "breakEvenAfterR": 1,
    "onlyWithTrend": false,
    "minConfidence": 70,
    "commission": 0.001
  },
  "recommendedTimeframes": {
    "primary": "4h",
    "secondary": [
      "1h",
      "1d"
    ],
    "avoid": [
      "1m",
      "5m",
      "15m"
    ],
    "notes": "OI divergence on 4h"
  },
  "parameters": {
    "lookback": {
      "default": 10,
      "min": 5,
      "max": 20,
      "step": 5,
      "description": "Lookback para divergência"
    },
    "minOiChange": {
      "default": 5,
      "min": 2,
      "max": 10,
      "step": 1,
      "description": "Mudança mínima OI %"
    },
    "atrMultiplier": {
      "default": 2,
      "min": 1.5,
      "max": 3,
      "step": 0.5,
      "description": "ATR stop"
    }
  },
  "indicators": {
    "openInterest": {
      "type": "openInterest",
      "params": {
        "period": "$lookback"
      }
    },
    "priceChange": {
      "type": "roc",
      "params": {
        "period": "$lookback"
      }
    },
    "atr": {
      "type": "atr",
      "params": {
        "period": 14
      }
    }
  },
  "entry": {
    "long": {
      "operator": "AND",
      "conditions": [
        {
          "left": "openInterest.change",
          "op": ">",
          "right": "$minOiChange"
        },
        {
          "left": "priceChange",
          "op": "<",
          "right": 0
        }
      ]
    },
    "short": {
      "operator": "AND",
      "conditions": [
        {
          "left": "openInterest.change",
          "op": "<",
          "right": {
            "calc": "-1 * $minOiChange"
          }
        },
        {
          "left": "priceChange",
          "op": ">",
          "right": 0
        }
      ]
    }
  },
  "exit": {
    "stopLoss": {
      "type": "atr",
      "multiplier": "$atrMultiplier",
      "indicator": "atr"
    },
    "takeProfit": {
      "type": "riskReward",
      "multiplier": 2
    },
    "trailingStop": {
      "enabled": true,
      "type": "atr",
      "initialMultiplier": 2,
      "trailMultiplier": 2,
      "breakEvenAfterR": 1
    }
  },
  "confidence": {
    "base": 70,
    "bonuses": [
      {
        "condition": {
          "left": "openInterest.change",
          "op": ">",
          "right": 10
        },
        "bonus": 15,
        "description": "Large OI increase"
      }
    ],
    "max": 90
  },
  "filters": {
    "minConfidence": 70,
    "minRiskReward": 1.5
  }
}
