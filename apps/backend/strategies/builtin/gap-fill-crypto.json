{
  "id": "gap-fill-crypto",
  "name": "Gap Fill Crypto",
  "version": "1.0.0",
  "description": "Estratégia para preencher gaps em crypto. Gaps de abertura tendem a ser preenchidos. Entry quando gap > 2% do preço.",
  "author": "MarketMind",
  "tags": ["gap", "mean-reversion", "intraday"],
  "source": "Gap Trading Studies",

  "status": "active",
  "optimizedParams": {
    "maxPositionSize": 60,
    "maxConcurrentPositions": 2,
    "maxTotalExposure": 70,
    "useAlgorithmicLevels": true,
    "useTrailingStop": false,
    "onlyWithTrend": false,
    "minConfidence": 70,
    "commission": 0.001
  },
  "recommendedTimeframes": {
    "primary": "1h",
    "secondary": ["15m", "4h"],
    "avoid": ["1m"],
    "notes": "Gap fill works on hourly"
  },

  "parameters": {
    "minGapPercent": { "default": 2, "min": 1, "max": 5, "step": 0.5, "description": "Gap mínimo em %" },
    "atrMultiplier": { "default": 1.5, "min": 1, "max": 2.5, "step": 0.5, "description": "ATR para stop" }
  },

  "indicators": {
    "gap": { "type": "gap", "params": { "minPercent": "$minGapPercent" } },
    "atr": { "type": "atr", "params": { "period": 14 } }
  },

  "entry": {
    "long": {
      "operator": "AND",
      "conditions": [
        { "left": "gap.percent", "op": "<", "right": { "calc": "-1 * $minGapPercent" } }
      ]
    },
    "short": {
      "operator": "AND",
      "conditions": [
        { "left": "gap.percent", "op": ">", "right": "$minGapPercent" }
      ]
    }
  },

  "exit": {
    "stopLoss": { "type": "atr", "multiplier": "$atrMultiplier", "indicator": "atr" },
    "takeProfit": { "type": "indicator", "indicator": "gap.fillLevel" },
    "conditions": {
      "long": { "operator": "OR", "conditions": [{ "left": "close", "op": ">=", "right": "gap.fillLevel" }] },
      "short": { "operator": "OR", "conditions": [{ "left": "close", "op": "<=", "right": "gap.fillLevel" }] }
    }
  },

  "confidence": {
    "base": 70,
    "bonuses": [
      { "condition": { "left": "gap.percent", "op": ">", "right": 4 }, "bonus": 10, "description": "Large gap" },
      { "condition": { "left": "volume", "op": ">", "right": "volume.sma20" }, "bonus": 5, "description": "Volume spike" }
    ],
    "max": 90
  },

  "filters": { "minConfidence": 70, "minRiskReward": 1.5 }
}
