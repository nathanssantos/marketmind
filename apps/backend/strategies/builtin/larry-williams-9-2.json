{
  "id": "larry-williams-9-2",
  "name": "Larry Williams 9.2 (EMA Pullback)",
  "version": "1.0.0",
  "description": "Larry Williams Setup 9.2 - Single kline EMA9 pullback. Entry when price closes below previous low (LONG) or above previous high (SHORT) during EMA9 uptrend/downtrend. Aggressive counter-trend pullback entry.",
  "author": "Larry Williams / MarketMind",
  "tags": ["larry-williams", "ema", "pullback", "counter-trend"],

  "status": "experimental",
  "optimizedParams": {
    "maxPositionSize": 40,
    "useAlgorithmicLevels": true,
    "onlyWithTrend": true,
    "minConfidence": 65,
    "commission": 0.1
  },
  "recommendedTimeframes": {
    "primary": "1d",
    "secondary": ["4h"],
    "avoid": ["1m", "5m", "15m"],
    "notes": "Best on daily charts. Requires EMA9 to be trending."
  },

  "parameters": {
    "emaPeriod": { "default": 9, "min": 5, "max": 15, "step": 1, "description": "EMA period (Larry Williams uses 9)" },
    "atrPeriod": { "default": 14, "min": 7, "max": 21, "step": 1, "description": "ATR period for stop/target" },
    "atrStopMultiplier": { "default": 1.5, "min": 1.0, "max": 3.0, "step": 0.25, "description": "ATR multiplier for stop loss" },
    "atrTargetMultiplier": { "default": 2.5, "min": 1.5, "max": 4.0, "step": 0.5, "description": "ATR multiplier for take profit" },
    "volumeMultiplier": { "default": 1.0, "min": 0.5, "max": 2.0, "step": 0.25, "description": "Minimum volume as multiplier of average" }
  },

  "indicators": {
    "ema9": {
      "type": "ema",
      "params": { "period": "$emaPeriod" }
    },
    "atr": {
      "type": "atr",
      "params": { "period": "$atrPeriod" }
    },
    "ema200": {
      "type": "ema",
      "params": { "period": 200 }
    }
  },

  "entry": {
    "long": {
      "operator": "AND",
      "conditions": [
        { "left": "ema9", "op": ">", "right": "ema9.prev" },
        { "left": "close", "op": "<", "right": "low.prev" },
        { "left": "volume", "op": ">", "right": "volume.sma20" }
      ]
    },
    "short": {
      "operator": "AND",
      "conditions": [
        { "left": "ema9", "op": "<", "right": "ema9.prev" },
        { "left": "close", "op": ">", "right": "high.prev" },
        { "left": "volume", "op": ">", "right": "volume.sma20" }
      ]
    }
  },

  "exit": {
    "stopLoss": {
      "type": "atr",
      "multiplier": "$atrStopMultiplier",
      "indicator": "atr"
    },
    "takeProfit": {
      "type": "atr",
      "multiplier": "$atrTargetMultiplier",
      "indicator": "atr"
    }
  },

  "confidence": {
    "base": 60,
    "bonuses": [
      { "condition": { "left": "volume", "op": ">", "right": "volume.sma20" }, "bonus": 20, "description": "Volume confirmation" },
      { "condition": { "left": "close", "op": ">", "right": "ema200" }, "bonus": 10, "description": "Above EMA200 (bullish context)" },
      { "condition": { "left": "close", "op": "<", "right": "ema200" }, "bonus": 10, "description": "Below EMA200 (bearish context)" }
    ],
    "max": 100
  },

  "filters": {
    "minConfidence": 65,
    "minRiskReward": 1.5,
    "trendFilter": {
      "enabled": true,
      "indicator": "ema",
      "period": 200,
      "allowCounterTrend": false
    }
  }
}
