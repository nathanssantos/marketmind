{
  "id": "fvg-rejection",
  "name": "FVG Rejection",
  "version": "1.0.0",
  "description": "Trades the rejection from a Fair Value Gap zone. Signal fires when a candle's range (wick or body) touches an active FVG zone and the candle closes on the correct side — confirming the FVG as support (LONG) or resistance (SHORT).",
  "author": "MarketMind",
  "tags": [
    "price-action",
    "fvg",
    "imbalance",
    "smart-money",
    "rejection"
  ],
  "source": "ICT Smart Money Concepts",
  "status": "active",
  "recommendedTimeframes": {
    "primary": "30m",
    "secondary": [
      "15m",
      "1h"
    ],
    "avoid": [
      "1m",
      "5m"
    ],
    "notes": "FVG rejection works best on 15m–1h. Lower timeframes produce too many false signals."
  },
  "parameters": {
    "atrMultiplier": {
      "default": 1.5,
      "min": 1,
      "max": 3,
      "step": 0.5,
      "description": "ATR multiplier for stop loss"
    }
  },
  "indicators": {
    "fvg": {
      "type": "fvg",
      "params": {}
    },
    "atr": {
      "type": "atr",
      "params": {
        "period": 14
      }
    }
  },
  "entry": {
    "long": {
      "operator": "AND",
      "conditions": [
        {
          "left": "low",
          "op": "<=",
          "right": "fvg.bullishTop"
        },
        {
          "left": "close",
          "op": ">",
          "right": "fvg.bullishBottom"
        }
      ]
    },
    "short": {
      "operator": "AND",
      "conditions": [
        {
          "left": "high",
          "op": ">=",
          "right": "fvg.bearishBottom"
        },
        {
          "left": "close",
          "op": "<",
          "right": "fvg.bearishTop"
        }
      ]
    }
  },
  "exit": {
    "stopLoss": {
      "type": "swingHighLow",
      "buffer": 0.3,
      "indicator": "atr"
    },
    "takeProfit": {
      "type": "riskReward",
      "multiplier": 2
    },
    "trailingStop": {
      "enabled": false,
      "type": "atr",
      "initialMultiplier": 2,
      "trailMultiplier": 1.5,
      "breakEvenAfterR": 1
    }
  },
  "confidence": {
    "base": 65,
    "bonuses": [
      {
        "condition": {
          "left": "volume",
          "op": ">",
          "right": "volume.sma20"
        },
        "bonus": 10,
        "description": "Volume confirmation at FVG zone"
      }
    ],
    "max": 80
  },
  "filters": {
    "minConfidence": 65,
    "minRiskReward": 1.5,
    "volumeType": "ANY",
    "strategyType": "ANY",
    "momentumType": "ANY"
  }
}
