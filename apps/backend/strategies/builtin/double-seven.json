{
  "id": "double-seven",
  "name": "Double Seven",
  "version": "1.0.0",
  "description": "Larry Connors' Double Seven strategy - buy at 7-day low close, sell at 7-day high close. From 'Short-Term Trading Strategies That Work'. Research shows consistent 80%+ win rate since 1995.",
  "author": "MarketMind",
  "tags": ["mean-reversion", "connors", "classic", "proven", "swing"],

  "status": "experimental",
  "optimizedParams": {
    "maxPositionSize": 75,
    "useAlgorithmicLevels": true,
    "onlyWithTrend": false,
    "minConfidence": 65,
    "commission": 0.1
  },
  "recommendedTimeframes": {
    "primary": "1d",
    "secondary": ["4h"],
    "avoid": ["1m", "5m", "15m", "30m"],
    "notes": "Works best on daily charts. Strategy designed for swing trading with 3-10 day holding periods."
  },

  "parameters": {
    "lookbackPeriod": { "default": 7, "min": 5, "max": 10, "step": 1, "description": "Days for high/low detection" },
    "smaTrend": { "default": 200, "min": 100, "max": 250, "step": 50, "description": "Trend filter SMA period" },
    "atrPeriod": { "default": 14, "min": 10, "max": 20, "step": 2, "description": "ATR for stop loss" },
    "slMultiplier": { "default": 2.5, "min": 1.5, "max": 4, "step": 0.5, "description": "Stop loss ATR multiplier" }
  },

  "indicators": {
    "nDayHighLow": {
      "type": "nDayHighLow",
      "params": { "period": "$lookbackPeriod" }
    },
    "sma200": {
      "type": "sma",
      "params": { "period": "$smaTrend" }
    },
    "atr": {
      "type": "atr",
      "params": { "period": "$atrPeriod" }
    }
  },

  "entry": {
    "long": {
      "operator": "AND",
      "conditions": [
        { "left": "nDayHighLow.isNDayLow", "op": "==", "right": 1 },
        { "left": "close", "op": ">", "right": "sma200" }
      ]
    },
    "short": {
      "operator": "AND",
      "conditions": [
        { "left": "nDayHighLow.isNDayHigh", "op": "==", "right": 1 },
        { "left": "close", "op": "<", "right": "sma200" }
      ]
    }
  },

  "exit": {
    "stopLoss": {
      "type": "atr",
      "multiplier": "$slMultiplier",
      "indicator": "atr"
    },
    "takeProfit": {
      "type": "riskReward",
      "multiplier": 2
    }
  },

  "confidence": {
    "base": 70,
    "bonuses": [
      { "condition": { "left": "close", "op": ">", "right": "sma200" }, "bonus": 10, "description": "With trend (above 200 SMA)" },
      { "condition": { "left": "volume", "op": ">", "right": "volume.sma20" }, "bonus": 5, "description": "Volume confirmation" }
    ],
    "max": 90
  },

  "filters": {
    "minConfidence": 65,
    "minRiskReward": 1.5
  }
}
