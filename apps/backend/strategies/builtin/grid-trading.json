{
  "id": "grid-trading",
  "name": "Grid Trading",
  "version": "1.0.0",
  "description": "Grid trading strategy placing multiple orders at predetermined price levels. Buys below fair value (EMA), sells above. Best in ranging/sideways markets.",
  "author": "MarketMind",
  "tags": ["grid", "ranging", "mean-reversion", "market-making"],

  "status": "experimental",
  "optimizedParams": {
    "maxPositionSize": 30,
    "useAlgorithmicLevels": true,
    "onlyWithTrend": false,
    "minConfidence": 60,
    "commission": 0.1
  },
  "recommendedTimeframes": {
    "primary": "1h",
    "secondary": ["4h", "1d"],
    "avoid": ["1m", "3m", "5m"],
    "notes": "Grid trading works best in ranging markets on 1h-4h timeframes"
  },

  "parameters": {
    "emaPeriod": { "default": 20, "min": 10, "max": 50, "step": 5, "description": "EMA period for fair value calculation" },
    "atrPeriod": { "default": 14, "min": 7, "max": 21, "step": 1, "description": "ATR period for grid spacing" },
    "gridSpacingATR": { "default": 1.0, "min": 0.5, "max": 2.0, "step": 0.25, "description": "ATR multiplier for grid spacing" },
    "minGridSpacing": { "default": 0.5, "min": 0.25, "max": 1.0, "step": 0.25, "description": "Minimum grid spacing as % of price" },
    "maxGridSpacing": { "default": 2.0, "min": 1.0, "max": 4.0, "step": 0.5, "description": "Maximum grid spacing as % of price" }
  },

  "indicators": {
    "ema": {
      "type": "ema",
      "params": { "period": "$emaPeriod" }
    },
    "atr": {
      "type": "atr",
      "params": { "period": "$atrPeriod" }
    },
    "ema200": {
      "type": "ema",
      "params": { "period": 200 }
    }
  },

  "entry": {
    "long": {
      "operator": "AND",
      "conditions": [
        { "left": "close", "op": "<", "right": "ema" }
      ]
    },
    "short": {
      "operator": "AND",
      "conditions": [
        { "left": "close", "op": ">", "right": "ema" }
      ]
    }
  },

  "exit": {
    "stopLoss": {
      "type": "atr",
      "multiplier": 1.5,
      "indicator": "atr"
    },
    "takeProfit": {
      "type": "indicator",
      "value": "ema"
    }
  },

  "confidence": {
    "base": 65,
    "bonuses": [
      { "condition": { "left": "close", "op": "<", "right": "ema" }, "bonus": 10, "description": "Price below fair value (EMA)" },
      { "condition": { "left": "volume", "op": ">", "right": "volume.sma20" }, "bonus": 5, "description": "Volume above average" }
    ],
    "max": 90
  },

  "filters": {
    "minConfidence": 60,
    "minRiskReward": 1.0
  }
}
