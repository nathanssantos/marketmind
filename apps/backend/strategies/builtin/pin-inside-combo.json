{
  "id": "pin-inside-combo",
  "name": "Pin Bar + Inside Bar Combo",
  "version": "1.0.0",
  "description": "Powerful price action combo: Pin bar (long wick rejecting level) followed by inside bar (consolidation). Entry on breakout of inside bar in pin bar direction at support/resistance.",
  "author": "MarketMind",
  "tags": [
    "price-action",
    "pin-bar",
    "inside-bar",
    "reversal"
  ],
  "status": "active",
  "recommendedTimeframes": {
    "primary": "1d",
    "secondary": [
      "4h"
    ],
    "avoid": [
      "1m",
      "5m",
      "15m",
      "30m"
    ],
    "notes": "Best on daily and 4h for reliable pin bars at key levels"
  },
  "parameters": {
    "pinBarRatio": {
      "default": 2,
      "min": 1.5,
      "max": 3,
      "step": 0.5,
      "description": "Wick to body ratio for valid pin bar"
    },
    "srTolerance": {
      "default": 1,
      "min": 0.5,
      "max": 2,
      "step": 0.25,
      "description": "Support/Resistance tolerance %"
    },
    "targetMultiplier": {
      "default": 2,
      "min": 1.5,
      "max": 3,
      "step": 0.5,
      "description": "Risk:Reward target"
    },
    "lookbackPeriod": {
      "default": 50,
      "min": 20,
      "max": 100,
      "step": 10,
      "description": "Lookback for S/R levels"
    },
    "atrPeriod": {
      "default": 14,
      "min": 7,
      "max": 21,
      "step": 1,
      "description": "ATR for stop calculation"
    }
  },
  "indicators": {
    "atr": {
      "type": "atr",
      "params": {
        "period": "$atrPeriod"
      }
    },
    "ema200": {
      "type": "ema",
      "params": {
        "period": 200
      }
    }
  },
  "entry": {
    "long": {
      "operator": "AND",
      "conditions": [
        {
          "left": "high",
          "op": "<=",
          "right": "high.prev"
        },
        {
          "left": "low",
          "op": ">=",
          "right": "low.prev"
        },
        {
          "left": "close.prev",
          "op": ">",
          "right": "open.prev"
        }
      ]
    },
    "short": {
      "operator": "AND",
      "conditions": [
        {
          "left": "high",
          "op": "<=",
          "right": "high.prev"
        },
        {
          "left": "low",
          "op": ">=",
          "right": "low.prev"
        },
        {
          "left": "close.prev",
          "op": "<",
          "right": "open.prev"
        }
      ]
    }
  },
  "exit": {
    "stopLoss": {
      "type": "swingHighLow",
      "buffer": 0.6,
      "indicator": "atr"
    },
    "takeProfit": {
      "type": "riskReward",
      "multiplier": "$targetMultiplier"
    },
    "trailingStop": {
      "enabled": true,
      "type": "atr",
      "initialMultiplier": 2,
      "trailMultiplier": 1.5,
      "breakEvenAfterR": 1
    }
  },
  "confidence": {
    "base": 70,
    "bonuses": [
      {
        "condition": {
          "left": "volume.prev",
          "op": ">",
          "right": "volume.sma20"
        },
        "bonus": 10,
        "description": "High volume on pin bar"
      },
      {
        "condition": {
          "left": "close",
          "op": ">",
          "right": "ema200"
        },
        "bonus": 5,
        "description": "Above major trend (LONG)"
      },
      {
        "condition": {
          "left": "close",
          "op": "<",
          "right": "ema200"
        },
        "bonus": 5,
        "description": "Below major trend (SHORT)"
      }
    ],
    "max": 95
  },
  "filters": {
    "minConfidence": 75,
    "minRiskReward": 2
  }
}
