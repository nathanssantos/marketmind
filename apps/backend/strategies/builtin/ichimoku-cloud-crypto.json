{
  "id": "ichimoku-cloud-crypto",
  "name": "Ichimoku Cloud Crypto",
  "version": "1.0.0",
  "description": "Estratégia Ichimoku adaptada para crypto: entry quando preço cruza acima da cloud E Tenkan cruza Kijun. Sistema completo de suporte, resistência e momentum.",
  "author": "MarketMind",
  "tags": ["trend-following", "ichimoku", "cloud", "momentum", "support-resistance"],
  "source": "YouHodler - Technical Indicators",

  "status": "disabled",
  "optimizedParams": {
    "maxPositionSize": 80,
    "maxConcurrentPositions": 1,
    "maxTotalExposure": 80,
    "useAlgorithmicLevels": true,
    "useTrailingStop": true,
    "trailingATRMultiplier": 3,
    "breakEvenAfterR": 2,
    "onlyWithTrend": false,
    "minConfidence": 70,
    "commission": 0.001
  },
  "recommendedTimeframes": {
    "primary": "4h",
    "secondary": ["1d"],
    "avoid": ["1m", "5m", "15m"],
    "notes": "Ichimoku works best on 4h and daily"
  },

  "parameters": {
    "tenkanPeriod": { "default": 9, "min": 7, "max": 12, "step": 1, "description": "Tenkan-sen (conversion line)" },
    "kijunPeriod": { "default": 26, "min": 20, "max": 30, "step": 2, "description": "Kijun-sen (base line)" },
    "senkouBPeriod": { "default": 52, "min": 40, "max": 60, "step": 4, "description": "Senkou Span B period" },
    "atrMultiplier": { "default": 2.5, "min": 2, "max": 4, "step": 0.5, "description": "ATR multiplier for stop" }
  },

  "indicators": {
    "ichimoku": {
      "type": "ichimoku",
      "params": { "tenkanPeriod": "$tenkanPeriod", "kijunPeriod": "$kijunPeriod", "senkouBPeriod": "$senkouBPeriod" }
    },
    "atr": { "type": "atr", "params": { "period": 14 } }
  },

  "entry": {
    "long": {
      "operator": "AND",
      "conditions": [
        { "left": "close", "op": ">", "right": "ichimoku.senkouA" },
        { "left": "close", "op": ">", "right": "ichimoku.senkouB" },
        { "left": "ichimoku.tenkan", "op": "crossover", "right": "ichimoku.kijun" }
      ]
    },
    "short": {
      "operator": "AND",
      "conditions": [
        { "left": "close", "op": "<", "right": "ichimoku.senkouA" },
        { "left": "close", "op": "<", "right": "ichimoku.senkouB" },
        { "left": "ichimoku.tenkan", "op": "crossunder", "right": "ichimoku.kijun" }
      ]
    }
  },

  "exit": {
    "stopLoss": { "type": "atr", "multiplier": "$atrMultiplier", "indicator": "atr" },
    "takeProfit": { "type": "riskReward", "multiplier": 3 },
    "trailingStop": { "enabled": true, "type": "atr", "initialMultiplier": 2.5, "trailMultiplier": 3, "breakEvenAfterR": 2 },
    "conditions": {
      "long": { "operator": "OR", "conditions": [{ "left": "ichimoku.tenkan", "op": "crossunder", "right": "ichimoku.kijun" }] },
      "short": { "operator": "OR", "conditions": [{ "left": "ichimoku.tenkan", "op": "crossover", "right": "ichimoku.kijun" }] }
    }
  },

  "confidence": {
    "base": 70,
    "bonuses": [
      { "condition": { "left": "ichimoku.chikou", "op": ">", "right": "close[26]" }, "bonus": 10, "description": "Chikou confirms" },
      { "condition": { "left": "volume", "op": ">", "right": "volume.sma20" }, "bonus": 5, "description": "Volume confirms" }
    ],
    "max": 90
  },

  "filters": { "minConfidence": 70, "minRiskReward": 2 }
}
