{
  "id": "volatility-contraction",
  "name": "Volatility Contraction",
  "version": "1.0.0",
  "description": "Entry após contração de volatilidade (squeeze). ATR/BB contraction precede expansão. Entry no início da expansão.",
  "author": "MarketMind",
  "tags": ["volatility", "squeeze", "contraction", "expansion"],
  "source": "TTM Squeeze Concept",

  "status": "active",
  "optimizedParams": {
    "maxPositionSize": 70,
    "maxConcurrentPositions": 2,
    "maxTotalExposure": 80,
    "useAlgorithmicLevels": true,
    "useTrailingStop": true,
    "trailingATRMultiplier": 2,
    "breakEvenAfterR": 1,
    "onlyWithTrend": false,
    "minConfidence": 70,
    "commission": 0.001
  },
  "recommendedTimeframes": {
    "primary": "4h",
    "secondary": ["1h", "1d"],
    "avoid": ["1m", "5m"],
    "notes": "Volatility contraction on 4h"
  },

  "parameters": {
    "bbPeriod": { "default": 20, "min": 15, "max": 25, "step": 5, "description": "BB período" },
    "keltnerPeriod": { "default": 20, "min": 15, "max": 25, "step": 5, "description": "Keltner período" },
    "keltnerMult": { "default": 1.5, "min": 1, "max": 2, "step": 0.25, "description": "Keltner multiplicador" },
    "atrMultiplier": { "default": 2, "min": 1.5, "max": 3, "step": 0.5, "description": "ATR stop" }
  },

  "indicators": {
    "bb": { "type": "bollingerBands", "params": { "period": "$bbPeriod", "stdDev": 2 } },
    "keltner": { "type": "keltner", "params": { "period": "$keltnerPeriod", "multiplier": "$keltnerMult" } },
    "momentum": { "type": "roc", "params": { "period": 12 } },
    "atr": { "type": "atr", "params": { "period": 14 } }
  },

  "entry": {
    "long": {
      "operator": "AND",
      "conditions": [
        { "left": "bb.lower.prev", "op": ">", "right": "keltner.lower.prev" },
        { "left": "bb.lower", "op": "<", "right": "keltner.lower" },
        { "left": "momentum", "op": ">", "right": 0 }
      ]
    },
    "short": {
      "operator": "AND",
      "conditions": [
        { "left": "bb.upper.prev", "op": "<", "right": "keltner.upper.prev" },
        { "left": "bb.upper", "op": ">", "right": "keltner.upper" },
        { "left": "momentum", "op": "<", "right": 0 }
      ]
    }
  },

  "exit": {
    "stopLoss": { "type": "atr", "multiplier": "$atrMultiplier", "indicator": "atr" },
    "takeProfit": { "type": "riskReward", "multiplier": 2.5 },
    "trailingStop": { "enabled": true, "type": "atr", "initialMultiplier": 2, "trailMultiplier": 2, "breakEvenAfterR": 1 }
  },

  "confidence": {
    "base": 70,
    "bonuses": [
      { "condition": { "left": "volume", "op": ">", "right": "volume.sma20" }, "bonus": 15, "description": "Volume on expansion" }
    ],
    "max": 90
  },

  "filters": { "minConfidence": 70, "minRiskReward": 2 }
}
