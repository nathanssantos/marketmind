{
  "enabled": true,
  "id": "chaikin-money-flow",
  "name": "Chaikin Money Flow",
  "version": "1.0.0",
  "description": "Chaikin Money Flow (CMF) para medir acumulação/distribuição. Entry quando CMF cruza zero indicando mudança no fluxo de dinheiro.",
  "author": "MarketMind",
  "tags": [
    "volume",
    "cmf",
    "chaikin",
    "accumulation-distribution"
  ],
  "source": "Marc Chaikin",
  "status": "active",
  "recommendedTimeframes": {
    "primary": "1d",
    "secondary": [
      "4h"
    ],
    "avoid": [
      "1m",
      "5m"
    ],
    "notes": "CMF works best on daily"
  },
  "parameters": {
    "cmfPeriod": {
      "default": 20,
      "min": 14,
      "max": 30,
      "step": 2,
      "description": "Período do CMF"
    },
    "threshold": {
      "default": 0.05,
      "min": 0,
      "max": 0.1,
      "step": 0.025,
      "description": "Threshold para confirmação"
    },
    "atrMultiplier": {
      "default": 2,
      "min": 1.5,
      "max": 3,
      "step": 0.5,
      "description": "ATR para stop"
    }
  },
  "indicators": {
    "cmf": {
      "type": "cmf",
      "params": {
        "period": "$cmfPeriod"
      }
    },
    "atr": {
      "type": "atr",
      "params": {
        "period": 14
      }
    }
  },
  "entry": {
    "long": {
      "operator": "AND",
      "conditions": [
        {
          "left": "cmf",
          "op": "crossover",
          "right": "$threshold"
        }
      ]
    },
    "short": {
      "operator": "AND",
      "conditions": [
        {
          "left": "cmf",
          "op": "crossunder",
          "right": {
            "calc": "-1 * $threshold"
          }
        }
      ]
    }
  },
  "exit": {
    "stopLoss": {
      "type": "swingHighLow",
      "buffer": 0.6,
      "indicator": "atr"
    },
    "takeProfit": {
      "type": "riskReward",
      "multiplier": 2
    },
    "conditions": {
      "long": {
        "operator": "OR",
        "conditions": [
          {
            "left": "cmf",
            "op": "<",
            "right": 0
          }
        ]
      },
      "short": {
        "operator": "OR",
        "conditions": [
          {
            "left": "cmf",
            "op": ">",
            "right": 0
          }
        ]
      }
    },
    "trailingStop": {
      "enabled": true,
      "type": "atr",
      "initialMultiplier": 2,
      "trailMultiplier": 1.5,
      "breakEvenAfterR": 1
    }
  },
  "confidence": {
    "base": 70,
    "bonuses": [
      {
        "condition": {
          "left": "cmf",
          "op": ">",
          "right": 0.15
        },
        "bonus": 10,
        "description": "Strong accumulation"
      },
      {
        "condition": {
          "left": "volume",
          "op": ">",
          "right": "volume.sma20"
        },
        "bonus": 5,
        "description": "Volume spike"
      }
    ],
    "max": 90
  },
  "filters": {
    "minConfidence": 70,
    "minRiskReward": 1,
    "volumeType": "ANY",
    "strategyType": "ANY",
    "momentumType": "ANY"
  },
  "education": {
    "origin": "Marc Chaikin - Accumulation/Distribution concept (1980s)",
    "createdYear": 1980,
    "candlePattern": {
      "lookback": 2,
      "candles": [
        {
          "offset": -1,
          "role": "reference",
          "descriptionKey": "strategies.chaikinMoneyFlow.candleMinus1"
        },
        {
          "offset": 0,
          "role": "trigger",
          "descriptionKey": "strategies.chaikinMoneyFlow.candleTrigger"
        }
      ],
      "indicatorsToShow": [
        "cmf",
        "volume",
        "atr"
      ]
    },
    "howItWorks": {
      "summaryKey": "strategies.chaikinMoneyFlow.summary",
      "entryKey": "strategies.chaikinMoneyFlow.entry",
      "exitKey": "strategies.chaikinMoneyFlow.exit"
    }
  }
}
