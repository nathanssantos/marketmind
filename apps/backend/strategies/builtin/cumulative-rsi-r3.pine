// @id cumulative-rsi-r3
// @name Cumulative RSI R3
// @version 1.0.0
// @description Larry Connors' R3 strategy using Cumulative RSI. Entry when: (1) RSI(2) drops 3 consecutive days, (2) first drop from below 60, (3) current RSI(2) < 10. Research shows 83% win rate with 2-day average hold.
// @author MarketMind
// @tags mean-reversion,connors,rsi,r3,proven
// @strategyType MEAN_REVERSION
// @momentumType REVERSAL
// @param rsiPeriod RSI period (2 is original)
// @param cumulativeThreshold Cumulative RSI entry threshold
// @param smaTrend Trend filter SMA period
// @param smaExit Exit when close > this SMA
// @param atrPeriod ATR for stop loss
// @param slMultiplier Stop loss ATR multiplier

//@version=5
indicator('Cumulative RSI R3', overlay=true)

rsiPeriod = input.int(2, 'rsiPeriod', minval=2, maxval=3, step=1)
cumulativeThreshold = input.int(10, 'cumulativeThreshold', minval=5, maxval=15, step=5)
smaTrend = input.int(200, 'smaTrend', minval=100, maxval=250, step=50)
smaExit = input.int(5, 'smaExit', minval=3, maxval=10, step=1)
atrPeriod = input.int(14, 'atrPeriod', minval=10, maxval=20, step=2)
slMultiplier = input.float(2.5, 'slMultiplier', minval=1.5, maxval=4, step=0.5)

cumulativeRsi_rsi = ta.rsi(close, rsiPeriod)
cumulativeRsi_cumulative = math.sum(cumulativeRsi_rsi, 2)
rsi2 = ta.rsi(close, rsiPeriod)
sma200 = ta.sma(close, smaTrend)
sma5 = ta.sma(close, smaExit)
atr = ta.atr(atrPeriod)
atrVal = atr

volSma20 = ta.sma(volume, 20)

longEntry = (cumulativeRsi_cumulative < cumulativeThreshold and close > sma200)
shortEntry = (cumulativeRsi_cumulative > 90 and close < sma200)

confBase = 75
confBonus0 = cumulativeRsi_cumulative < 5 ? 10 : 0
confBonus1 = rsi2 < 5 ? 8 : 0
confBonus2 = volume > ta.sma(volume, 20) ? 5 : 0
confValue = math.min(confBase + confBonus0 + confBonus1 + confBonus2, 95)

exitLong = false
exitShort = false

sig = longEntry ? 1 : shortEntry ? -1 : 0
sl = longEntry ? close - atrVal * 0.6 : shortEntry ? close + atrVal * 0.6 : na
tp = longEntry ? close + math.abs(close - (close - atrVal * 0.6)) * 2 : shortEntry ? close - math.abs((close + atrVal * 0.6) - close) * 2 : na
conf = longEntry or shortEntry ? confValue : 0
exitSig = exitLong ? 1 : exitShort ? -1 : 0

plot(sig, 'signal', display=display.none)
plot(sl, 'stopLoss', display=display.none)
plot(tp, 'takeProfit', display=display.none)
plot(conf, 'confidence', display=display.none)
plot(exitSig, 'exitSignal', display=display.none)
