{
  "id": "ibs-mean-reversion",
  "name": "IBS Mean Reversion",
  "version": "1.0.0",
  "description": "Internal Bar Strength (IBS) mean-reversion strategy. IBS = (Close - Low) / (High - Low). Buy when IBS < 0.2 (close near low), sell when IBS > 0.8 (close near high). Research shows 4-6% annual return with 60%+ win rate.",
  "author": "MarketMind",
  "tags": ["mean-reversion", "ibs", "short-term", "daily"],

  "status": "experimental",
  "optimizedParams": {
    "maxPositionSize": 50,
    "useAlgorithmicLevels": true,
    "onlyWithTrend": true,
    "minConfidence": 60,
    "commission": 0.001
  },
  "recommendedTimeframes": {
    "primary": "1d",
    "secondary": ["4h", "12h"],
    "avoid": ["1m", "5m", "15m"],
    "notes": "IBS works best on daily bars where close position within range has meaning."
  },

  "parameters": {
    "ibsOversold": { "default": 0.2, "min": 0.1, "max": 0.3, "step": 0.05, "description": "IBS oversold threshold" },
    "ibsOverbought": { "default": 0.8, "min": 0.7, "max": 0.9, "step": 0.05, "description": "IBS overbought threshold" },
    "smaTrend": { "default": 200, "min": 100, "max": 250, "step": 50, "description": "Trend filter SMA period" },
    "atrPeriod": { "default": 14, "min": 10, "max": 20, "step": 2, "description": "ATR for stop loss" },
    "slMultiplier": { "default": 2, "min": 1.5, "max": 3, "step": 0.5, "description": "Stop loss ATR multiplier" }
  },

  "indicators": {
    "ibs": {
      "type": "ibs",
      "params": {}
    },
    "sma200": {
      "type": "sma",
      "params": { "period": "$smaTrend" }
    },
    "atr": {
      "type": "atr",
      "params": { "period": "$atrPeriod" }
    }
  },

  "entry": {
    "long": {
      "operator": "AND",
      "conditions": [
        { "left": "ibs", "op": "<", "right": "$ibsOversold" },
        { "left": "close", "op": ">", "right": "sma200" }
      ]
    },
    "short": {
      "operator": "AND",
      "conditions": [
        { "left": "ibs", "op": ">", "right": "$ibsOverbought" },
        { "left": "close", "op": "<", "right": "sma200" }
      ]
    }
  },

  "exit": {
    "stopLoss": {
      "type": "atr",
      "multiplier": "$slMultiplier",
      "indicator": "atr"
    },
    "takeProfit": {
      "type": "riskReward",
      "multiplier": 2
    }
  },

  "confidence": {
    "base": 65,
    "bonuses": [
      { "condition": { "left": "ibs", "op": "<", "right": 0.1 }, "bonus": 15, "description": "Extreme oversold IBS < 0.1" },
      { "condition": { "left": "ibs", "op": ">", "right": 0.9 }, "bonus": 15, "description": "Extreme overbought IBS > 0.9" },
      { "condition": { "left": "volume", "op": ">", "right": "volume.sma20" }, "bonus": 5, "description": "Volume confirmation" }
    ],
    "max": 90
  },

  "filters": {
    "minConfidence": 60,
    "minRiskReward": 1.5
  }
}
