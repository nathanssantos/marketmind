// @id open-interest-divergence
// @name Open Interest Divergence
// @version 1.0.0
// @description Detecta divergências entre preço e open interest. OI crescente + preço caindo = acumulação. OI caindo + preço subindo = distribuição.
// @author MarketMind
// @tags open-interest,divergence,futures,smart-money
// @strategyType ANY
// @momentumType REVERSAL
// @param lookback Lookback para divergência
// @param minOiChange Mudança mínima OI %
// @param atrMultiplier ATR stop

//@version=5
indicator('Open Interest Divergence', overlay=true)

lookback = input.int(10, 'lookback', minval=5, maxval=20, step=5)
minOiChange = input.int(5, 'minOiChange', minval=2, maxval=10, step=1)
atrMultiplier = input.float(2, 'atrMultiplier', minval=1.5, maxval=3, step=0.5)

openInterest_change = 0.0
openInterest_sma = 0.0
priceChange = ta.roc(close, lookback)
atr = ta.atr(14)
atrVal = atr

volSma20 = ta.sma(volume, 20)

longEntry = (openInterest_change > minOiChange and priceChange < 0)
shortEntry = (openInterest_change < (-1 * minOiChange) and priceChange > 0)

confBase = 70
confBonus0 = openInterest_change > 10 ? 15 : 0
confValue = math.min(confBase + confBonus0, 90)

exitLong = false
exitShort = false

sig = longEntry ? 1 : shortEntry ? -1 : 0
sl = longEntry ? close - atrVal * 0.6 : shortEntry ? close + atrVal * 0.6 : na
tp = longEntry ? close + math.abs(close - (close - atrVal * 0.6)) * 2 : shortEntry ? close - math.abs((close + atrVal * 0.6) - close) * 2 : na
conf = longEntry or shortEntry ? confValue : 0
exitSig = exitLong ? 1 : exitShort ? -1 : 0

plot(sig, 'signal', display=display.none)
plot(sl, 'stopLoss', display=display.none)
plot(tp, 'takeProfit', display=display.none)
plot(conf, 'confidence', display=display.none)
plot(exitSig, 'exitSignal', display=display.none)
