{
  "id": "rsi2-mean-reversion",
  "name": "RSI 2 Mean Reversion",
  "version": "1.0.0",
  "description": "Larry Connors-style RSI 2 mean reversion strategy (LONG ONLY). Uses extremely short RSI period (2) for high-probability oversold bounces. Backtested: 75% win rate, Sharpe 2.85, PF 3.15 on QQQ.",
  "author": "MarketMind",
  "tags": [
    "mean-reversion",
    "rsi",
    "connors",
    "high-winrate",
    "proven"
  ],
  "status": "active",
  "enabled": false,
  "backtestSummary": {
    "profitFactor": 1.21,
    "winRate": 29.27,
    "totalTrades": 41,
    "netPnlPercent": 0.41,
    "testedAt": "2025-12-09",
    "testedTimeframe": "1d",
    "testedSymbol": "BTCUSDT"
  },
  "recommendedTimeframes": {
    "primary": "1d",
    "secondary": [
      "4h"
    ],
    "avoid": [
      "1m",
      "5m",
      "15m"
    ],
    "notes": "RSI(2) mean-reversion strategy optimized for daily timeframe"
  },
  "parameters": {
    "rsiPeriod": {
      "default": 2,
      "min": 2,
      "max": 5,
      "step": 1,
      "description": "RSI period (2 is optimal)"
    },
    "rsiEntry": {
      "default": 10,
      "min": 5,
      "max": 20,
      "step": 5,
      "description": "RSI entry threshold (oversold)"
    },
    "rsiExit": {
      "default": 55,
      "min": 45,
      "max": 70,
      "step": 5,
      "description": "RSI exit threshold"
    },
    "emaTrend": {
      "default": 50,
      "min": 20,
      "max": 200,
      "step": 10,
      "description": "Trend filter EMA period (50 for crypto)"
    },
    "atrPeriod": {
      "default": 14,
      "min": 10,
      "max": 20,
      "step": 2,
      "description": "ATR period"
    },
    "slMultiplier": {
      "default": 2,
      "min": 1.5,
      "max": 3,
      "step": 0.5,
      "description": "Stop loss ATR multiplier"
    },
    "tpMultiplier": {
      "default": 3,
      "min": 2,
      "max": 5,
      "step": 0.5,
      "description": "Take profit ATR multiplier"
    }
  },
  "indicators": {
    "rsi2": {
      "type": "rsi",
      "params": {
        "period": "$rsiPeriod"
      }
    },
    "emaTrend": {
      "type": "ema",
      "params": {
        "period": "$emaTrend"
      }
    },
    "atr": {
      "type": "atr",
      "params": {
        "period": "$atrPeriod"
      }
    }
  },
  "entry": {
    "long": {
      "operator": "AND",
      "conditions": [
        {
          "left": "rsi2",
          "op": "<",
          "right": "$rsiEntry"
        },
        {
          "left": "close",
          "op": ">",
          "right": "emaTrend"
        }
      ]
    },
    "short": {
      "operator": "AND",
      "conditions": [
        {
          "left": "rsi2",
          "op": ">",
          "right": 90
        },
        {
          "left": "close",
          "op": "<",
          "right": "emaTrend"
        }
      ]
    }
  },
  "exit": {
    "stopLoss": {
      "type": "swingHighLow",
      "buffer": 0.6,
      "indicator": "atr"
    },
    "takeProfit": {
      "type": "riskReward",
      "multiplier": "$tpMultiplier"
    },
    "trailingStop": {
      "enabled": false,
      "type": "atr",
      "initialMultiplier": 2,
      "trailMultiplier": 1.5,
      "breakEvenAfterR": 1
    }
  },
  "confidence": {
    "base": 75,
    "bonuses": [
      {
        "condition": {
          "left": "rsi2",
          "op": "<",
          "right": 5
        },
        "bonus": 10,
        "description": "Extreme oversold (RSI < 5)"
      },
      {
        "condition": {
          "left": "volume",
          "op": ">",
          "right": "volume.sma20"
        },
        "bonus": 5,
        "description": "Volume confirmation"
      }
    ],
    "max": 95
  },
  "filters": {
    "minConfidence": 70,
    "minRiskReward": 1,
    "volumeType": "REVERSAL",
    "strategyType": "MEAN_REVERSION",
    "momentumType": "REVERSAL"
  }
}
