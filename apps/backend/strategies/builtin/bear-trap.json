{
  "id": "bear-trap",
  "name": "Bear Trap",
  "version": "1.0.0",
  "description": "False breakdown below support followed by rapid recovery. Entry LONG when price breaks below support then closes back above with volume confirmation.",
  "author": "Classic Technical Analysis",
  "source": "Market Microstructure - Trap Patterns",
  "tags": [
    "trap",
    "reversal",
    "false-breakdown",
    "counter-trend"
  ],
  "status": "active",
  "enabled": true,
  "recommendedTimeframes": {
    "primary": "1h",
    "secondary": [
      "4h",
      "1d"
    ],
    "avoid": [
      "1m",
      "5m",
      "15m"
    ],
    "notes": "Best on 1h-4h for intraday traps, daily for swing trades"
  },
  "parameters": {
    "lookbackPeriod": {
      "default": 20,
      "min": 10,
      "max": 50,
      "step": 5,
      "description": "Period to find support levels"
    },
    "emaPeriod": {
      "default": 20,
      "min": 10,
      "max": 50,
      "step": 5,
      "description": "EMA period for trend confirmation"
    },
    "volumeMultiplier": {
      "default": 1.3,
      "min": 1,
      "max": 2,
      "step": 0.1,
      "description": "Volume multiplier for confirmation"
    },
    "atrPeriod": {
      "default": 14,
      "min": 7,
      "max": 21,
      "step": 1,
      "description": "ATR period for stop calculation"
    }
  },
  "indicators": {
    "ema": {
      "type": "ema",
      "params": {
        "period": "$emaPeriod"
      }
    },
    "atr": {
      "type": "atr",
      "params": {
        "period": "$atrPeriod"
      }
    }
  },
  "entry": {
    "long": {
      "operator": "AND",
      "conditions": [
        {
          "left": "low.prev",
          "op": "<",
          "right": "low.prev2"
        },
        {
          "left": "close",
          "op": ">",
          "right": "low.prev2"
        },
        {
          "left": "close",
          "op": ">",
          "right": "ema"
        }
      ]
    },
    "short": {
      "operator": "AND",
      "conditions": [
        {
          "left": "high.prev",
          "op": ">",
          "right": "high.prev2"
        },
        {
          "left": "close",
          "op": "<",
          "right": "high.prev2"
        },
        {
          "left": "close",
          "op": "<",
          "right": "ema"
        }
      ]
    }
  },
  "exit": {
    "stopLoss": {
      "type": "swingHighLow",
      "buffer": 0.6,
      "indicator": "atr"
    },
    "takeProfit": {
      "type": "riskReward",
      "multiplier": 2.5
    },
    "trailingStop": {
      "enabled": false,
      "type": "atr",
      "initialMultiplier": 2,
      "trailMultiplier": 1.5,
      "breakEvenAfterR": 1
    }
  },
  "confidence": {
    "base": 60,
    "bonuses": [
      {
        "condition": {
          "left": "volume",
          "op": ">",
          "right": "volume.sma20"
        },
        "bonus": 15,
        "description": "Volume spike on recovery"
      },
      {
        "condition": {
          "left": "close",
          "op": ">",
          "right": "ema"
        },
        "bonus": 10,
        "description": "Above EMA after trap"
      }
    ],
    "max": 95
  },
  "filters": {
    "minConfidence": 70,
    "minRiskReward": 2,
    "volumeType": "REVERSAL",
    "strategyType": "MEAN_REVERSION",
    "momentumType": "REVERSAL"
  },
  "education": {
    "origin": "Classic Market Microstructure - False breakout patterns",
    "createdYear": 1980,
    "candlePattern": {
      "lookback": 3,
      "candles": [
        {
          "offset": -2,
          "role": "reference",
          "descriptionKey": "strategies.bearTrap.candleMinus2"
        },
        {
          "offset": -1,
          "role": "confirmation",
          "descriptionKey": "strategies.bearTrap.candleMinus1"
        },
        {
          "offset": 0,
          "role": "trigger",
          "descriptionKey": "strategies.bearTrap.candleTrigger"
        }
      ],
      "indicatorsToShow": ["ema", "atr", "volume"]
    },
    "howItWorks": {
      "summaryKey": "strategies.bearTrap.summary",
      "entryKey": "strategies.bearTrap.entry",
      "exitKey": "strategies.bearTrap.exit"
    }
  }
}
