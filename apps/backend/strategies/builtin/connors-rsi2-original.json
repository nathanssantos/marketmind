{
  "enabled": false,
  "id": "connors-rsi2-original",
  "name": "Connors RSI 2 Original",
  "version": "1.0.0",
  "description": "Larry Connors' RSI 2 mean-reversion strategy from 'Short-Term Trading Strategies That Work' (2008). Long: RSI(2) < 15 + above SMA. Short: RSI(2) > 85 + below SMA.",
  "author": "MarketMind",
  "tags": [
    "mean-reversion",
    "connors",
    "rsi2",
    "classic",
    "proven"
  ],
  "status": "active",
  "backtestSummary": {
    "profitFactor": 2.78,
    "winRate": 50,
    "totalTrades": 10,
    "netPnlPercent": 9.31,
    "testedAt": "2025-12-07",
    "testedTimeframe": "1d",
    "testedSymbol": "BTCUSDT"
  },
  "recommendedTimeframes": {
    "primary": "1d",
    "secondary": [
      "4h"
    ],
    "avoid": [
      "1m",
      "5m",
      "15m"
    ],
    "notes": "RSI(2) mean-reversion works best on daily timeframe per Connors research"
  },
  "parameters": {
    "rsiPeriod": {
      "default": 2,
      "min": 2,
      "max": 3,
      "step": 1,
      "description": "RSI period (2 is original)"
    },
    "rsiEntryLong": {
      "default": 15,
      "min": 5,
      "max": 25,
      "step": 1,
      "description": "RSI entry threshold for long (oversold)"
    },
    "rsiEntryShort": {
      "default": 85,
      "min": 75,
      "max": 95,
      "step": 1,
      "description": "RSI entry threshold for short (overbought)"
    },
    "smaTrend": {
      "default": 50,
      "min": 20,
      "max": 200,
      "step": 10,
      "description": "Trend filter SMA period (200 for stocks, 50 for crypto)"
    },
    "smaExit": {
      "default": 5,
      "min": 3,
      "max": 10,
      "step": 1,
      "description": "Exit SMA period"
    },
    "atrPeriod": {
      "default": 14,
      "min": 10,
      "max": 20,
      "step": 2,
      "description": "ATR for position sizing"
    },
    "slMultiplier": {
      "default": 3,
      "min": 2,
      "max": 5,
      "step": 0.5,
      "description": "Stop loss ATR (Connors uses none, but we add for safety)"
    }
  },
  "indicators": {
    "rsi2": {
      "type": "rsi",
      "params": {
        "period": "$rsiPeriod"
      }
    },
    "sma200": {
      "type": "sma",
      "params": {
        "period": "$smaTrend"
      }
    },
    "sma5": {
      "type": "sma",
      "params": {
        "period": "$smaExit"
      }
    },
    "atr": {
      "type": "atr",
      "params": {
        "period": "$atrPeriod"
      }
    }
  },
  "entry": {
    "long": {
      "operator": "AND",
      "conditions": [
        {
          "left": "rsi2",
          "op": "<",
          "right": "$rsiEntryLong"
        },
        {
          "left": "close",
          "op": ">",
          "right": "sma200"
        }
      ]
    },
    "short": {
      "operator": "AND",
      "conditions": [
        {
          "left": "rsi2",
          "op": ">",
          "right": "$rsiEntryShort"
        },
        {
          "left": "close",
          "op": "<",
          "right": "sma200"
        }
      ]
    }
  },
  "exit": {
    "conditions": {
      "long": {
        "operator": "AND",
        "conditions": [
          {
            "left": "close",
            "op": ">",
            "right": "sma5"
          }
        ]
      },
      "short": {
        "operator": "AND",
        "conditions": [
          {
            "left": "close",
            "op": "<",
            "right": "sma5"
          }
        ]
      }
    },
    "stopLoss": {
      "type": "swingHighLow",
      "buffer": 0.6,
      "indicator": "atr"
    },
    "takeProfit": {
      "type": "pivotBased",
      "lookback": 40,
      "fallback": {
        "type": "riskReward",
        "multiplier": 2
      }
    },
    "maxBarsInTrade": 10,
    "trailingStop": {
      "enabled": false,
      "type": "atr",
      "initialMultiplier": 2,
      "trailMultiplier": 1.5,
      "breakEvenAfterR": 1
    }
  },
  "confidence": {
    "base": 75,
    "bonuses": [
      {
        "condition": {
          "left": "rsi2",
          "op": "<",
          "right": 2
        },
        "bonus": 10,
        "description": "Extreme oversold (RSI < 2)"
      },
      {
        "condition": {
          "left": "volume",
          "op": ">",
          "right": "volume.sma20"
        },
        "bonus": 5,
        "description": "Volume confirmation"
      }
    ],
    "max": 95
  },
  "filters": {
    "minConfidence": 70,
    "minRiskReward": 1,
    "volumeType": "REVERSAL",
    "strategyType": "MEAN_REVERSION",
    "momentumType": "REVERSAL"
  },
  "education": {
    "origin": "Larry Connors & Cesar Alvarez - Short-Term Trading Strategies That Work (2008)",
    "createdYear": 2008,
    "candlePattern": {
      "lookback": 3,
      "candles": [
        {
          "offset": -2,
          "role": "context",
          "descriptionKey": "strategies.connorsRsi2.candleMinus2"
        },
        {
          "offset": -1,
          "role": "reference",
          "descriptionKey": "strategies.connorsRsi2.candleMinus1"
        },
        {
          "offset": 0,
          "role": "trigger",
          "descriptionKey": "strategies.connorsRsi2.candleTrigger"
        }
      ],
      "indicatorsToShow": [
        "rsi",
        "sma200",
        "atr"
      ]
    },
    "howItWorks": {
      "summaryKey": "strategies.connorsRsi2.summary",
      "entryKey": "strategies.connorsRsi2.entry",
      "exitKey": "strategies.connorsRsi2.exit"
    }
  }
}
