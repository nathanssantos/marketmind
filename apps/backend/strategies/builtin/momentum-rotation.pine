// @id momentum-rotation
// @name Momentum Rotation
// @version 1.0.0
// @description Momentum rotation strategy. Long: ROC > 5% and price > EMA50. Short: ROC < -5% and price < EMA50.
// @author MarketMind
// @tags momentum,rotation,relative-strength,ranking
// @strategyType ANY
// @momentumType BREAKOUT
// @param momentumPeriod Período momentum
// @param minMomentumLong Minimum positive momentum % for long
// @param minMomentumShort Maximum negative momentum % for short
// @param atrMultiplier ATR stop

//@version=5
indicator('Momentum Rotation', overlay=true)

momentumPeriod = input.int(20, 'momentumPeriod', minval=10, maxval=30, step=5)
minMomentumLong = input.float(5, 'minMomentumLong', minval=0, maxval=15, step=2.5)
minMomentumShort = input.float(-5, 'minMomentumShort', minval=-15, maxval=0, step=2.5)
atrMultiplier = input.float(2, 'atrMultiplier', minval=1.5, maxval=3, step=0.5)

roc = ta.roc(close, momentumPeriod)
ema50 = ta.ema(close, 50)
atr = ta.atr(14)
atrVal = atr

volSma20 = ta.sma(volume, 20)

longEntry = (roc > minMomentumLong and close > ema50)
shortEntry = (roc < minMomentumShort and close < ema50)

confBase = 65
confBonus0 = roc > 15 ? 15 : 0
confBonus1 = volume > ta.sma(volume, 20) ? 5 : 0
confValue = math.min(confBase + confBonus0 + confBonus1, 90)

exitLong = roc < 0
exitShort = roc > 0

sig = longEntry ? 1 : shortEntry ? -1 : 0
sl = longEntry ? close - atrVal * 0.6 : shortEntry ? close + atrVal * 0.6 : na
tp = longEntry ? close + math.abs(close - (close - atrVal * 0.6)) * 2.5 : shortEntry ? close - math.abs((close + atrVal * 0.6) - close) * 2.5 : na
conf = longEntry or shortEntry ? confValue : 0
exitSig = exitLong ? 1 : exitShort ? -1 : 0

plot(sig, 'signal', display=display.none)
plot(sl, 'stopLoss', display=display.none)
plot(tp, 'takeProfit', display=display.none)
plot(conf, 'confidence', display=display.none)
plot(exitSig, 'exitSignal', display=display.none)
