// @id enhanced-trend-following
// @name Enhanced Trend Following (Multi-TF)
// @version 1.0.0
// @description Multi-timeframe EMA crossover with higher timeframe confirmation. Fast EMA crosses Slow EMA on LTF + price alignment with EMA200. ATR-based stop loss with 3:1 R:R.
// @author MarketMind
// @tags trend-following,multi-timeframe,ema-crossover,momentum
// @strategyType TREND_FOLLOWING
// @momentumType PULLBACK
// @param emaFastPeriod Fast EMA period
// @param emaSlowPeriod Slow EMA period
// @param atrPeriod ATR period for stop loss
// @param stopLossATR Stop loss as ATR multiplier
// @param takeProfitRatio Risk:Reward ratio

//@version=5
indicator('Enhanced Trend Following (Multi-TF)', overlay=true)

emaFastPeriod = input.int(9, 'emaFastPeriod', minval=5, maxval=21, step=1)
emaSlowPeriod = input.int(21, 'emaSlowPeriod', minval=15, maxval=50, step=1)
atrPeriod = input.int(14, 'atrPeriod', minval=7, maxval=21, step=1)
stopLossATR = input.float(1.5, 'stopLossATR', minval=1, maxval=3, step=0.25)
takeProfitRatio = input.float(3, 'takeProfitRatio', minval=2, maxval=5, step=0.5)

emaFast = ta.ema(close, emaFastPeriod)
emaSlow = ta.ema(close, emaSlowPeriod)
ema200 = ta.ema(close, 200)
atr = ta.atr(atrPeriod)
atrVal = atr

volSma20 = ta.sma(volume, 20)

longEntry = (ta.crossover(emaFast, emaSlow) and close > ema200)
shortEntry = (ta.crossunder(emaFast, emaSlow) and close < ema200)

confBase = 55
confBonus0 = close > ema200 ? 15 : 0
confBonus1 = close < ema200 ? 15 : 0
confBonus2 = volume > ta.sma(volume, 20) ? 10 : 0
confValue = math.min(confBase + confBonus0 + confBonus1 + confBonus2, 95)

exitLong = false
exitShort = false

sig = longEntry ? 1 : shortEntry ? -1 : 0
sl = longEntry ? close - atrVal * 0.6 : shortEntry ? close + atrVal * 0.6 : na
tp = longEntry ? close + math.abs(close - (close - atrVal * 0.6)) * takeProfitRatio : shortEntry ? close - math.abs((close + atrVal * 0.6) - close) * takeProfitRatio : na
conf = longEntry or shortEntry ? confValue : 0
exitSig = exitLong ? 1 : exitShort ? -1 : 0

plot(sig, 'signal', display=display.none)
plot(sl, 'stopLoss', display=display.none)
plot(tp, 'takeProfit', display=display.none)
plot(conf, 'confidence', display=display.none)
plot(exitSig, 'exitSignal', display=display.none)
