{
  "id": "engulfing-pattern",
  "name": "Engulfing Pattern",
  "version": "1.0.0",
  "description": "Bullish/Bearish Engulfing candlestick pattern. Padrão forte de reversão onde candle atual engolfa a anterior completamente.",
  "author": "MarketMind",
  "tags": ["reversal", "candlestick", "engulfing", "pattern"],
  "source": "Japanese Candlestick Classic",

  "status": "active",
  "optimizedParams": {
    "maxPositionSize": 70,
    "maxConcurrentPositions": 2,
    "maxTotalExposure": 80,
    "useAlgorithmicLevels": true,
    "useTrailingStop": false,
    "onlyWithTrend": false,
    "minConfidence": 70,
    "commission": 0.001
  },
  "recommendedTimeframes": {
    "primary": "4h",
    "secondary": ["1h", "1d"],
    "avoid": ["1m", "5m"],
    "notes": "Engulfing works on 4h and daily"
  },

  "parameters": {
    "minBodyRatio": { "default": 1.5, "min": 1.2, "max": 2, "step": 0.1, "description": "Ratio mínimo engulfing/engulfed" },
    "atrMultiplier": { "default": 2, "min": 1.5, "max": 3, "step": 0.5, "description": "ATR para stop" }
  },

  "indicators": {
    "atr": { "type": "atr", "params": { "period": 14 } }
  },

  "entry": {
    "long": {
      "operator": "AND",
      "conditions": [
        { "left": "close[1]", "op": "<", "right": "open[1]" },
        { "left": "close", "op": ">", "right": "open" },
        { "left": "open", "op": "<", "right": "close[1]" },
        { "left": "close", "op": ">", "right": "open[1]" }
      ]
    },
    "short": {
      "operator": "AND",
      "conditions": [
        { "left": "close[1]", "op": ">", "right": "open[1]" },
        { "left": "close", "op": "<", "right": "open" },
        { "left": "open", "op": ">", "right": "close[1]" },
        { "left": "close", "op": "<", "right": "open[1]" }
      ]
    }
  },

  "exit": {
    "stopLoss": { "type": "atr", "multiplier": "$atrMultiplier", "indicator": "atr" },
    "takeProfit": { "type": "riskReward", "multiplier": 2 }
  },

  "confidence": {
    "base": 70,
    "bonuses": [
      { "condition": { "left": "volume", "op": ">", "right": "volume.sma20" }, "bonus": 10, "description": "Volume confirms" },
      { "condition": { "left": "volume", "op": ">", "right": "volume[1]" }, "bonus": 5, "description": "Increasing volume" }
    ],
    "max": 90
  },

  "filters": { "minConfidence": 70, "minRiskReward": 1.5 }
}
