{
  "id": "williams-momentum",
  "name": "Williams %R Momentum",
  "version": "1.0.0",
  "description": "Momentum strategy using Williams %R oscillator. Entry when Williams %R crosses from oversold/overbought zones with volume confirmation. Quick momentum trades.",
  "author": "MarketMind",
  "tags": ["momentum", "williams", "oscillator", "quick-trades"],

  "status": "unprofitable",
  "optimizedParams": {
    "maxPositionSize": 50,
    "useAlgorithmicLevels": true,
    "onlyWithTrend": true,
    "minConfidence": 55,
    "commission": 0.1
  },
  "backtestSummary": {
    "profitFactor": 0.83,
    "winRate": 35.29,
    "totalTrades": 34,
    "netPnlPercent": -5.17,
    "testedAt": "2025-12-07",
    "testedTimeframe": "1d",
    "testedSymbol": "BTCUSDT"
  },
  "recommendedTimeframes": {
    "primary": "1d",
    "secondary": ["4h"],
    "avoid": ["1m", "5m", "15m"],
    "notes": "Williams %R momentum works best on daily timeframe"
  },

  "parameters": {
    "williamsPeriod": { "default": 14, "min": 10, "max": 21, "step": 1, "description": "Williams %R period" },
    "oversold": { "default": -80, "min": -90, "max": -70, "step": 5, "description": "Oversold level" },
    "overbought": { "default": -20, "min": -30, "max": -10, "step": 5, "description": "Overbought level" },
    "atrMultiplier": { "default": 1.25, "min": 1, "max": 2, "step": 0.25, "description": "ATR multiplier for stop" },
    "rrMultiplier": { "default": 1.5, "min": 1, "max": 2.5, "step": 0.25, "description": "Risk-reward multiplier" }
  },

  "indicators": {
    "williamsR": {
      "type": "williamsR",
      "params": { "period": "$williamsPeriod" }
    },
    "ema20": {
      "type": "ema",
      "params": { "period": 20 }
    },
    "atr": {
      "type": "atr",
      "params": { "period": 14 }
    }
  },

  "entry": {
    "long": {
      "operator": "AND",
      "conditions": [
        { "left": "williamsR.prev", "op": "<", "right": "$oversold" },
        { "left": "williamsR", "op": ">=", "right": "$oversold" }
      ]
    },
    "short": {
      "operator": "AND",
      "conditions": [
        { "left": "williamsR.prev", "op": ">", "right": "$overbought" },
        { "left": "williamsR", "op": "<=", "right": "$overbought" }
      ]
    }
  },

  "exit": {
    "stopLoss": {
      "type": "atr",
      "multiplier": "$atrMultiplier",
      "indicator": "atr"
    },
    "takeProfit": {
      "type": "riskReward",
      "multiplier": "$rrMultiplier"
    }
  },

  "confidence": {
    "base": 60,
    "bonuses": [
      { "condition": { "left": "volume", "op": ">", "right": "volume.sma20" }, "bonus": 15, "description": "Volume confirmation" },
      { "condition": { "left": "williamsR", "op": "<", "right": -90 }, "bonus": 5, "description": "Extreme oversold" },
      { "condition": { "left": "williamsR", "op": ">", "right": -10 }, "bonus": 5, "description": "Extreme overbought" }
    ],
    "max": 85
  },

  "filters": {
    "minConfidence": 55,
    "minRiskReward": 1.25
  }
}
