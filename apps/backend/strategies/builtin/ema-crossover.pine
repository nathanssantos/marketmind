// @id ema-crossover
// @name EMA Crossover
// @version 1.0.0
// @description Estratégia clássica de cruzamento de EMAs. Long quando EMA rápida cruza acima da EMA lenta. Short no cruzamento inverso.
// @author MarketMind
// @tags trend-following,ema,crossover,momentum
// @strategyType TREND_FOLLOWING
// @momentumType BREAKOUT
// @param fastPeriod Período da EMA rápida
// @param slowPeriod Período da EMA lenta
// @param atrMultiplier Multiplicador do ATR para stop loss
// @param rrMultiplier Multiplicador de risk-reward para take profit

//@version=5
indicator('EMA Crossover', overlay=true)

fastPeriod = input.int(9, 'fastPeriod', minval=5, maxval=21, step=1)
slowPeriod = input.int(21, 'slowPeriod', minval=15, maxval=50, step=1)
atrMultiplier = input.float(1.5, 'atrMultiplier', minval=1, maxval=3, step=0.25)
rrMultiplier = input.float(2, 'rrMultiplier', minval=1.5, maxval=4, step=0.5)

emaFast = ta.ema(close, fastPeriod)
emaSlow = ta.ema(close, slowPeriod)
atr = ta.atr(14)
atrVal = atr

volSma20 = ta.sma(volume, 20)

longEntry = ta.crossover(emaFast, emaSlow)
shortEntry = ta.crossunder(emaFast, emaSlow)

confBase = 65
confBonus0 = volume > ta.sma(volume, 20) ? 10 : 0
confBonus1 = atr > 0 ? 5 : 0
confValue = math.min(confBase + confBonus0 + confBonus1, 90)

exitLong = false
exitShort = false

sig = longEntry ? 1 : shortEntry ? -1 : 0
sl = longEntry ? close - atrVal * 0.6 : shortEntry ? close + atrVal * 0.6 : na
tp = longEntry ? close + math.abs(close - (close - atrVal * 0.6)) * rrMultiplier : shortEntry ? close - math.abs((close + atrVal * 0.6) - close) * rrMultiplier : na
conf = longEntry or shortEntry ? confValue : 0
exitSig = exitLong ? 1 : exitShort ? -1 : 0

plot(sig, 'signal', display=display.none)
plot(sl, 'stopLoss', display=display.none)
plot(tp, 'takeProfit', display=display.none)
plot(conf, 'confidence', display=display.none)
plot(exitSig, 'exitSignal', display=display.none)
