{
  "id": "mean-reversion-bb-rsi",
  "name": "Mean Reversion (Bollinger + RSI)",
  "version": "1.0.0",
  "description": "Long quando preço toca banda inferior do Bollinger + RSI oversold. Short quando toca banda superior + RSI overbought.",
  "author": "MarketMind",
  "tags": ["mean-reversion", "bollinger-bands", "rsi", "momentum"],

  "status": "experimental",
  "optimizedParams": {
    "maxPositionSize": 50,
    "useAlgorithmicLevels": true,
    "onlyWithTrend": true,
    "minConfidence": 65,
    "commission": 0.001
  },
  "recommendedTimeframes": {
    "primary": "1d",
    "secondary": ["4h"],
    "avoid": ["1m", "5m", "15m"],
    "notes": "Mean-reversion strategies work best on daily timeframe"
  },

  "parameters": {
    "bbPeriod": { "default": 20, "min": 10, "max": 50, "step": 5, "description": "Período das Bollinger Bands" },
    "bbStdDev": { "default": 2, "min": 1.5, "max": 3, "step": 0.5, "description": "Desvio padrão das bandas" },
    "rsiPeriod": { "default": 14, "min": 7, "max": 21, "step": 1, "description": "Período do RSI" },
    "rsiOversold": { "default": 30, "min": 20, "max": 40, "step": 5, "description": "Nível de oversold do RSI" },
    "rsiOverbought": { "default": 70, "min": 60, "max": 80, "step": 5, "description": "Nível de overbought do RSI" },
    "atrMultiplier": { "default": 2, "min": 1, "max": 4, "step": 0.5, "description": "Multiplicador do ATR para stop loss" }
  },

  "indicators": {
    "bb": {
      "type": "bollingerBands",
      "params": { "period": "$bbPeriod", "stdDev": "$bbStdDev" }
    },
    "rsi": {
      "type": "rsi",
      "params": { "period": "$rsiPeriod" }
    },
    "atr": {
      "type": "atr",
      "params": { "period": 14 }
    }
  },

  "entry": {
    "long": {
      "operator": "AND",
      "conditions": [
        { "left": "close", "op": "<=", "right": "bb.lower" },
        { "left": "rsi", "op": "<=", "right": "$rsiOversold" }
      ]
    },
    "short": {
      "operator": "AND",
      "conditions": [
        { "left": "close", "op": ">=", "right": "bb.upper" },
        { "left": "rsi", "op": ">=", "right": "$rsiOverbought" }
      ]
    }
  },

  "exit": {
    "stopLoss": {
      "type": "atr",
      "multiplier": "$atrMultiplier",
      "indicator": "atr"
    },
    "takeProfit": {
      "type": "indicator",
      "value": "bb.middle"
    }
  },

  "confidence": {
    "base": 60,
    "bonuses": [
      { "condition": { "left": "rsi", "op": "<", "right": 25 }, "bonus": 10, "description": "RSI extremamente oversold" },
      { "condition": { "left": "rsi", "op": ">", "right": 75 }, "bonus": 10, "description": "RSI extremamente overbought" },
      { "condition": { "left": "volume", "op": ">", "right": "volume.sma20" }, "bonus": 10, "description": "Volume acima da média" }
    ],
    "max": 95
  },

  "filters": {
    "minConfidence": 65,
    "minRiskReward": 1.5
  }
}
