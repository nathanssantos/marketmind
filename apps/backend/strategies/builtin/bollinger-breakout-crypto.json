{
  "id": "bollinger-breakout-crypto",
  "name": "Bollinger Bands Breakout Crypto",
  "version": "1.0.0",
  "description": "Estratégia de breakout usando Bollinger Bands: entry quando preço cruza abaixo da lower band e depois volta para dentro. Exit na middle band. Efetivo em mercados voláteis.",
  "author": "MarketMind",
  "tags": [
    "mean-reversion",
    "bollinger",
    "breakout",
    "volatility"
  ],
  "source": "CoinBureau - Backtest Guide",
  "status": "active",
  "enabled": false,
  "group": "breakout",
  "recommendedTimeframes": {
    "primary": "4h",
    "secondary": [
      "1h",
      "1d"
    ],
    "avoid": [
      "1m",
      "5m"
    ],
    "notes": "BB breakout works well on 4h for crypto volatility"
  },
  "parameters": {
    "bbPeriod": {
      "default": 20,
      "min": 15,
      "max": 30,
      "step": 5,
      "description": "Período das Bollinger Bands"
    },
    "bbStdDev": {
      "default": 2,
      "min": 1.5,
      "max": 3,
      "step": 0.5,
      "description": "Desvios padrão"
    },
    "atrMultiplier": {
      "default": 2,
      "min": 1.5,
      "max": 3,
      "step": 0.5,
      "description": "Multiplicador ATR para stop"
    }
  },
  "indicators": {
    "bb": {
      "type": "bollingerBands",
      "params": {
        "period": "$bbPeriod",
        "stdDev": "$bbStdDev"
      }
    },
    "atr": {
      "type": "atr",
      "params": {
        "period": 14
      }
    }
  },
  "entry": {
    "long": {
      "operator": "AND",
      "conditions": [
        {
          "left": "close.prev",
          "op": "<",
          "right": "bb.lower.prev"
        },
        {
          "left": "close",
          "op": ">",
          "right": "bb.lower"
        }
      ]
    },
    "short": {
      "operator": "AND",
      "conditions": [
        {
          "left": "close.prev",
          "op": ">",
          "right": "bb.upper.prev"
        },
        {
          "left": "close",
          "op": "<",
          "right": "bb.upper"
        }
      ]
    },
    "entryPrice": {
      "type": "swingHighLow",
      "expirationBars": 3
    }
  },
  "exit": {
    "stopLoss": {
      "type": "swingHighLow",
      "buffer": 0.6,
      "indicator": "atr"
    },
    "takeProfit": {
      "type": "indicator",
      "indicator": "bb.middle",
      "fallback": {
        "type": "riskReward",
        "multiplier": 2
      }
    },
    "conditions": {
      "long": {
        "operator": "OR",
        "conditions": [
          {
            "left": "close",
            "op": ">=",
            "right": "bb.middle"
          }
        ]
      },
      "short": {
        "operator": "OR",
        "conditions": [
          {
            "left": "close",
            "op": "<=",
            "right": "bb.middle"
          }
        ]
      }
    }
  },
  "confidence": {
    "base": 65,
    "bonuses": [
      {
        "condition": {
          "left": "volume",
          "op": ">",
          "right": "volume.sma20"
        },
        "bonus": 10,
        "description": "Volume spike"
      },
      {
        "condition": {
          "left": "bb.bandwidth",
          "op": "<",
          "right": 0.1
        },
        "bonus": 10,
        "description": "BB squeeze"
      }
    ],
    "max": 90
  },
  "filters": {
    "minConfidence": 65,
    "minRiskReward": 1,
    "trendFilter": {
      "enabled": false,
      "indicator": "ema",
      "period": 200,
      "allowCounterTrend": true
    }
  },
  "education": {
    "origin": "John Bollinger - Bollinger on Bollinger Bands (2001)",
    "createdYear": 2001,
    "candlePattern": {
      "lookback": 2,
      "candles": [
        {
          "offset": -1,
          "role": "reference",
          "descriptionKey": "strategies.bbBreakout.candleMinus1"
        },
        {
          "offset": 0,
          "role": "trigger",
          "descriptionKey": "strategies.bbBreakout.candleTrigger"
        }
      ],
      "indicatorsToShow": [
        "bb",
        "atr",
        "volume"
      ]
    },
    "howItWorks": {
      "summaryKey": "strategies.bbBreakout.summary",
      "entryKey": "strategies.bbBreakout.entry",
      "exitKey": "strategies.bbBreakout.exit"
    }
  }
}
