// @id engulfing-pattern
// @name Engulfing Pattern
// @version 1.0.0
// @description Bullish/Bearish Engulfing candlestick pattern. Padrão forte de reversão onde candle atual engolfa a anterior completamente.
// @author MarketMind
// @tags reversal,candlestick,engulfing,pattern
// @strategyType ANY
// @momentumType REVERSAL
// @param minBodyRatio Ratio mínimo engulfing/engulfed
// @param atrMultiplier ATR para stop

//@version=5
indicator('Engulfing Pattern', overlay=true)

minBodyRatio = input.float(1.5, 'minBodyRatio', minval=1.2, maxval=2, step=0.1)
atrMultiplier = input.float(2, 'atrMultiplier', minval=1.5, maxval=3, step=0.5)

atr = ta.atr(14)
atrVal = atr

volSma20 = ta.sma(volume, 20)

longEntry = (close[1] < open[1] and close > open and open < close[1] and close > open[1])
shortEntry = (close[1] > open[1] and close < open and open > close[1] and close < open[1])

confBase = 70
confBonus0 = volume > ta.sma(volume, 20) ? 10 : 0
confBonus1 = volume > volume[1] ? 5 : 0
confValue = math.min(confBase + confBonus0 + confBonus1, 90)

exitLong = false
exitShort = false

sig = longEntry ? 1 : shortEntry ? -1 : 0
sl = longEntry ? close - atrVal * 0.6 : shortEntry ? close + atrVal * 0.6 : na
tp = longEntry ? close + math.abs(close - (close - atrVal * 0.6)) * 2 : shortEntry ? close - math.abs((close + atrVal * 0.6) - close) * 2 : na
conf = longEntry or shortEntry ? confValue : 0
exitSig = exitLong ? 1 : exitShort ? -1 : 0

plot(sig, 'signal', display=display.none)
plot(sl, 'stopLoss', display=display.none)
plot(tp, 'takeProfit', display=display.none)
plot(conf, 'confidence', display=display.none)
plot(exitSig, 'exitSignal', display=display.none)
