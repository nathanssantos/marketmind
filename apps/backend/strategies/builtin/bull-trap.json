{
  "id": "bull-trap",
  "name": "Bull Trap",
  "version": "1.0.0",
  "description": "False breakout above resistance followed by rapid rejection. Entry SHORT when price breaks above resistance then closes back below with volume confirmation.",
  "author": "MarketMind",
  "tags": [
    "trap",
    "reversal",
    "false-breakout",
    "counter-trend"
  ],
  "status": "active",
  "optimizedParams": {
    "maxPositionSize": 40,
    "useAlgorithmicLevels": true,
    "onlyWithTrend": false,
    "minConfidence": 70,
    "commission": 0.001
  },
  "recommendedTimeframes": {
    "primary": "1h",
    "secondary": [
      "4h",
      "1d"
    ],
    "avoid": [
      "1m",
      "5m",
      "15m"
    ],
    "notes": "Best on 1h-4h for intraday traps, daily for swing trades"
  },
  "parameters": {
    "lookbackPeriod": {
      "default": 20,
      "min": 10,
      "max": 50,
      "step": 5,
      "description": "Period to find resistance levels"
    },
    "emaPeriod": {
      "default": 20,
      "min": 10,
      "max": 50,
      "step": 5,
      "description": "EMA period for trend confirmation"
    },
    "volumeMultiplier": {
      "default": 1.3,
      "min": 1.0,
      "max": 2.0,
      "step": 0.1,
      "description": "Volume multiplier for confirmation"
    },
    "atrPeriod": {
      "default": 14,
      "min": 7,
      "max": 21,
      "step": 1,
      "description": "ATR period for stop calculation"
    }
  },
  "indicators": {
    "ema": {
      "type": "ema",
      "params": {
        "period": "$emaPeriod"
      }
    },
    "atr": {
      "type": "atr",
      "params": {
        "period": "$atrPeriod"
      }
    }
  },
  "entry": {
    "short": {
      "operator": "AND",
      "conditions": [
        {
          "left": "high.prev",
          "op": ">",
          "right": "high.prev2"
        },
        {
          "left": "close",
          "op": "<",
          "right": "high.prev2"
        },
        {
          "left": "close",
          "op": "<",
          "right": "ema"
        }
      ]
    }
  },
  "exit": {
    "stopLoss": {
      "type": "swingHighLow",
      "lookback": 3,
      "buffer": 0.1,
      "indicator": "atr"
    },
    "takeProfit": {
      "type": "riskReward",
      "multiplier": 2.5
    },
    "trailingStop": {
      "enabled": true,
      "type": "atr",
      "initialMultiplier": 2,
      "trailMultiplier": 1.5,
      "breakEvenAfterR": 1
    }
  },
  "confidence": {
    "base": 60,
    "bonuses": [
      {
        "condition": {
          "left": "volume",
          "op": ">",
          "right": "volume.sma20"
        },
        "bonus": 15,
        "description": "Volume spike on rejection"
      },
      {
        "condition": {
          "left": "close",
          "op": "<",
          "right": "ema"
        },
        "bonus": 10,
        "description": "Below EMA after trap"
      }
    ],
    "max": 95
  },
  "filters": {
    "minConfidence": 70,
    "minRiskReward": 2.0
  }
}