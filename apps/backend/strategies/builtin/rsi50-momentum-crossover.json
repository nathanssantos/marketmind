{
  "id": "rsi50-momentum-crossover",
  "name": "RSI50 Momentum Crossover",
  "version": "1.0.0",
  "description": "Estratégia de momentum Bitcoin: entry quando RSI(5) cruza acima de 50, exit quando cruza abaixo. Backtestada com 122% CAGR vs 101% buy-and-hold, com apenas 39% drawdown vs 83%. Simples e efetivo.",
  "author": "MarketMind",
  "tags": [
    "momentum",
    "rsi",
    "crossover",
    "crypto-optimized",
    "trend-following"
  ],
  "source": "QuantifiedStrategies.com - Bitcoin RSI Trading Strategy",
  "status": "active",
  "enabled": false,
  "backtestSummary": {
    "referenceCAGR": 122,
    "referenceMaxDrawdown": 39,
    "referenceBenchmark": "Buy&Hold 101% CAGR, 83% DD",
    "testedPeriod": "2015-2021",
    "source": "QuantifiedStrategies.com"
  },
  "recommendedTimeframes": {
    "primary": "1d",
    "secondary": [
      "4h"
    ],
    "avoid": [
      "1m",
      "5m",
      "15m"
    ],
    "notes": "RSI momentum crossover works best on daily for crypto"
  },
  "parameters": {
    "rsiPeriod": {
      "default": 5,
      "min": 2,
      "max": 14,
      "step": 1,
      "description": "Período do RSI (5 otimizado para BTC)"
    },
    "rsiEntry": {
      "default": 50,
      "min": 45,
      "max": 60,
      "step": 5,
      "description": "Threshold de entry RSI"
    },
    "rsiExit": {
      "default": 50,
      "min": 40,
      "max": 55,
      "step": 5,
      "description": "Threshold de exit RSI"
    },
    "atrMultiplier": {
      "default": 2.5,
      "min": 2,
      "max": 4,
      "step": 0.5,
      "description": "Multiplicador ATR para stop loss"
    }
  },
  "indicators": {
    "rsi": {
      "type": "rsi",
      "params": {
        "period": "$rsiPeriod"
      }
    },
    "atr": {
      "type": "atr",
      "params": {
        "period": 14
      }
    }
  },
  "entry": {
    "long": {
      "operator": "AND",
      "conditions": [
        {
          "left": "rsi",
          "op": "crossover",
          "right": "$rsiEntry"
        }
      ]
    },
    "short": {
      "operator": "AND",
      "conditions": [
        {
          "left": "rsi",
          "op": "crossunder",
          "right": "$rsiExit"
        }
      ]
    }
  },
  "exit": {
    "stopLoss": {
      "type": "swingHighLow",
      "buffer": 0.6,
      "indicator": "atr"
    },
    "takeProfit": {
      "type": "riskReward",
      "multiplier": 3
    },
    "trailingStop": {
      "enabled": false,
      "type": "atr",
      "initialMultiplier": 2.5,
      "trailMultiplier": 4,
      "breakEvenAfterR": 2
    },
    "conditions": {
      "long": {
        "operator": "OR",
        "conditions": [
          {
            "left": "rsi",
            "op": "crossunder",
            "right": "$rsiExit"
          }
        ]
      },
      "short": {
        "operator": "OR",
        "conditions": [
          {
            "left": "rsi",
            "op": "crossover",
            "right": "$rsiEntry"
          }
        ]
      }
    }
  },
  "confidence": {
    "base": 65,
    "bonuses": [
      {
        "condition": {
          "left": "volume",
          "op": ">",
          "right": "volume.sma20"
        },
        "bonus": 10,
        "description": "Volume confirmando momentum"
      },
      {
        "condition": {
          "left": "rsi",
          "op": ">",
          "right": 55
        },
        "bonus": 5,
        "description": "Momentum forte (RSI > 55)"
      }
    ],
    "max": 90
  },
  "filters": {
    "minConfidence": 60,
    "minRiskReward": 2,
    "volumeType": "BREAKOUT",
    "strategyType": "TREND_FOLLOWING",
    "momentumType": "BREAKOUT"
  },
  "education": {
    "origin": "QuantifiedStrategies.com - Bitcoin RSI Trading Strategy Research",
    "createdYear": 2020,
    "candlePattern": {
      "lookback": 2,
      "candles": [
        {
          "offset": -1,
          "role": "reference",
          "descriptionKey": "strategies.rsi50.candleMinus1"
        },
        {
          "offset": 0,
          "role": "trigger",
          "descriptionKey": "strategies.rsi50.candleTrigger"
        }
      ],
      "indicatorsToShow": [
        "rsi",
        "atr",
        "volume"
      ]
    },
    "howItWorks": {
      "summaryKey": "strategies.rsi50.summary",
      "entryKey": "strategies.rsi50.entry",
      "exitKey": "strategies.rsi50.exit"
    }
  }
}
