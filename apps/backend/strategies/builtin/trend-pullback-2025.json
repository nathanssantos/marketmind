{
  "id": "trend-pullback-2025",
  "name": "Trend Pullback 2025",
  "version": "1.0.0",
  "description": "Buy the dip strategy for bull markets. Waits for pullbacks to key EMAs in strong uptrends, enters when momentum resumes. High win rate strategy with tight risk management.",
  "author": "MarketMind",
  "tags": [
    "trend-following",
    "pullback",
    "buy-the-dip",
    "bull-market",
    "2025"
  ],
  "status": "active",
  "optimizedParams": {
    "maxPositionSize": 80,
    "maxConcurrentPositions": 1,
    "maxTotalExposure": 80,
    "useAlgorithmicLevels": true,
    "useTrailingStop": true,
    "trailingATRMultiplier": 6,
    "breakEvenAfterR": 3,
    "onlyWithTrend": true,
    "minConfidence": 65,
    "commission": 0.001
  },
  "backtestSummary": {
    "profitFactor": 1.83,
    "winRate": 40.9,
    "sharpeRatio": 2.81,
    "maxDrawdownPercent": 12.84,
    "totalTrades": 44,
    "netPnlPercent": 35.68,
    "testedAt": "2024-12-09",
    "testedPeriod": "2024-01-01 to 2024-10-01",
    "testedTimeframe": "4h",
    "testedSymbol": "BTCUSDT"
  },
  "recommendedTimeframes": {
    "primary": "4h",
    "secondary": [
      "1h",
      "1d"
    ],
    "avoid": [
      "1m",
      "5m",
      "15m"
    ],
    "notes": "Trend pullback works best on 4H for EMA alignment detection"
  },
  "parameters": {
    "emaFast": {
      "default": 9,
      "min": 5,
      "max": 12,
      "step": 1,
      "description": "Fast EMA for pullback target"
    },
    "emaMid": {
      "default": 21,
      "min": 15,
      "max": 30,
      "step": 3,
      "description": "Mid EMA for trend confirmation"
    },
    "emaTrend": {
      "default": 50,
      "min": 30,
      "max": 100,
      "step": 10,
      "description": "Main trend EMA"
    },
    "rsiPeriod": {
      "default": 7,
      "min": 5,
      "max": 14,
      "step": 2,
      "description": "RSI period (shorter for faster signals)"
    },
    "rsiOversold": {
      "default": 40,
      "min": 30,
      "max": 50,
      "step": 5,
      "description": "RSI oversold for pullback"
    },
    "atrPeriod": {
      "default": 14,
      "min": 10,
      "max": 20,
      "step": 2,
      "description": "ATR period"
    },
    "slMultiplier": {
      "default": 1.2,
      "min": 0.8,
      "max": 2,
      "step": 0.2,
      "description": "SL ATR multiplier (tight)"
    },
    "tpMultiplier": {
      "default": 2.5,
      "min": 1.5,
      "max": 4,
      "step": 0.5,
      "description": "TP ATR multiplier"
    }
  },
  "indicators": {
    "emaFast": {
      "type": "ema",
      "params": {
        "period": "$emaFast"
      }
    },
    "emaMid": {
      "type": "ema",
      "params": {
        "period": "$emaMid"
      }
    },
    "emaTrend": {
      "type": "ema",
      "params": {
        "period": "$emaTrend"
      }
    },
    "rsi": {
      "type": "rsi",
      "params": {
        "period": "$rsiPeriod"
      }
    },
    "atr": {
      "type": "atr",
      "params": {
        "period": "$atrPeriod"
      }
    }
  },
  "entry": {
    "long": {
      "operator": "AND",
      "conditions": [
        {
          "left": "emaMid",
          "op": ">",
          "right": "emaTrend"
        },
        {
          "left": "close",
          "op": "crossover",
          "right": "emaFast"
        }
      ]
    },
    "short": {
      "operator": "AND",
      "conditions": [
        {
          "left": "emaMid",
          "op": "<",
          "right": "emaTrend"
        },
        {
          "left": "close",
          "op": "crossunder",
          "right": "emaFast"
        }
      ]
    }
  },
  "exit": {
    "stopLoss": {
      "type": "swingHighLow",
      "buffer": 0.6,
      "indicator": "atr"
    },
    "takeProfit": {
      "type": "riskReward",
      "multiplier": "$tpMultiplier"
    },
    "trailingStop": {
      "enabled": true,
      "type": "atr",
      "initialMultiplier": 1.5,
      "trailMultiplier": 6,
      "breakEvenAfterR": 3
    }
  },
  "confidence": {
    "base": 65,
    "bonuses": [
      {
        "condition": {
          "left": "close",
          "op": ">",
          "right": "emaTrend"
        },
        "bonus": 10,
        "description": "Price above trend EMA"
      },
      {
        "condition": {
          "left": "volume",
          "op": ">",
          "right": "volume.sma20"
        },
        "bonus": 10,
        "description": "Volume confirms reversal"
      }
    ],
    "max": 90
  },
  "filters": {
    "minConfidence": 65,
    "minRiskReward": 2.0
  }
}