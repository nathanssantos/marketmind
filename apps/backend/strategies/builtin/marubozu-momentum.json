{
  "id": "marubozu-momentum",
  "name": "Marubozu Momentum",
  "version": "1.0.0",
  "description": "Marubozu candlestick pattern (sem sombras). Indica forte convicção direcional. Entry na direção do Marubozu com confirmação.",
  "author": "MarketMind",
  "tags": [
    "momentum",
    "candlestick",
    "marubozu",
    "trend-continuation"
  ],
  "source": "Japanese Candlestick Classic",
  "status": "active",
  "recommendedTimeframes": {
    "primary": "4h",
    "secondary": [
      "1h",
      "1d"
    ],
    "avoid": [
      "1m",
      "5m"
    ],
    "notes": "Marubozu on 4h"
  },
  "parameters": {
    "wickTolerance": {
      "default": 0.1,
      "min": 0.05,
      "max": 0.2,
      "step": 0.05,
      "description": "Tolerância máxima para wicks (%)"
    },
    "atrMultiplier": {
      "default": 2,
      "min": 1.5,
      "max": 3,
      "step": 0.5,
      "description": "ATR para stop"
    }
  },
  "indicators": {
    "atr": {
      "type": "atr",
      "params": {
        "period": 14
      }
    }
  },
  "entry": {
    "long": {
      "operator": "AND",
      "conditions": [
        {
          "left": "close",
          "op": ">",
          "right": "open"
        },
        {
          "left": {
            "calc": "(high - close) / (high - low)"
          },
          "op": "<",
          "right": "$wickTolerance"
        },
        {
          "left": {
            "calc": "(open - low) / (high - low)"
          },
          "op": "<",
          "right": "$wickTolerance"
        }
      ]
    },
    "short": {
      "operator": "AND",
      "conditions": [
        {
          "left": "close",
          "op": "<",
          "right": "open"
        },
        {
          "left": {
            "calc": "(high - open) / (high - low)"
          },
          "op": "<",
          "right": "$wickTolerance"
        },
        {
          "left": {
            "calc": "(close - low) / (high - low)"
          },
          "op": "<",
          "right": "$wickTolerance"
        }
      ]
    }
  },
  "exit": {
    "stopLoss": {
      "type": "swingHighLow",
      "buffer": 0.6,
      "indicator": "atr"
    },
    "takeProfit": {
      "type": "riskReward",
      "multiplier": 2
    },
    "trailingStop": {
      "enabled": false,
      "type": "atr",
      "initialMultiplier": 2,
      "trailMultiplier": 2,
      "breakEvenAfterR": 1
    }
  },
  "confidence": {
    "base": 70,
    "bonuses": [
      {
        "condition": {
          "left": "volume",
          "op": ">",
          "right": "volume.sma20"
        },
        "bonus": 15,
        "description": "Strong volume"
      }
    ],
    "max": 90
  },
  "filters": {
    "minConfidence": 70,
    "minRiskReward": 1,
    "volumeType": "BREAKOUT",
    "strategyType": "TREND_FOLLOWING",
    "momentumType": "BREAKOUT"
  }
}
