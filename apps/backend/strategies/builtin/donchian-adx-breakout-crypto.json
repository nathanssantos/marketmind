  "description": "Estrat\u00e9gia trend-following para Bitcoin: entry no breakout do Donchian 15 dias APENAS quando ADX < 25 (baixa volatilidade). Backtestada com 90% CAGR, 63% win rate em BTC. Explora breakouts explosivos ap\u00f3s consolida\u00e7\u00e3o.",
  "author": "MarketMind",
  "tags": [
    "trend-following",
    "donchian",
    "adx",
    "breakout",
    "crypto-optimized",
    "volatility-filter"
  ],
  "source": "QuantifiedStrategies.com - Bitcoin Trend-Following Strategy Using ChatGPT",
  "status": "active",
  "optimizedParams": {
    "maxPositionSize": 90,
    "maxConcurrentPositions": 2,
    "maxTotalExposure": 90,
    "useAlgorithmicLevels": true,
    "useTrailingStop": true,
    "trailingATRMultiplier": 3,
    "breakEvenAfterR": 1.5,
    "onlyWithTrend": false,
    "minConfidence": 65,
    "commission": 0.001
  },
  "backtestSummary": {
    "referenceCAGR": 90,
    "referenceWinRate": 63,
    "referenceTrades": 35,
    "referenceTimeInvested": "50%",
    "referenceBenchmark": "Buy&Hold 66% CAGR",
    "testedPeriod": "2015-present",
    "source": "QuantifiedStrategies.com"
  },
  "recommendedTimeframes": {
    "primary": "1d",
    "secondary": [],
    "avoid": [
      "1m",
      "5m",
      "15m",
      "1h",
      "4h"
    ],
    "notes": "Strategy designed specifically for daily timeframe"
  },
  "parameters": {
    "donchianPeriod": {
      "default": 15,
      "min": 10,
      "max": 25,
      "step": 5,
      "description": "Per\u00edodo do Donchian Channel (15 otimizado)"
    },
    "adxPeriod": {
      "default": 14,
      "min": 10,
      "max": 20,
      "step": 2,
      "description": "Per\u00edodo do ADX"
    },
    "adxThreshold": {
      "default": 25,
      "min": 20,
      "max": 30,
      "step": 5,
      "description": "ADX m\u00e1ximo para entry (low volatility)"
    },
    "atrMultiplier": {
      "default": 2,
      "min": 1.5,
      "max": 3,
      "step": 0.5,
      "description": "Multiplicador ATR para stop loss"
    }
  },
  "indicators": {
    "donchianHigh": {
      "type": "donchian",
      "output": "upper",
      "params": {
        "period": "$donchianPeriod"
      }
    },
    "donchianLow": {
      "type": "donchian",
      "output": "lower",
      "params": {
        "period": "$donchianPeriod"
      }
    },
    "adx": {
      "type": "adx",
      "params": {
        "period": "$adxPeriod"
      }
    },
    "atr": {
      "type": "atr",
      "params": {
        "period": 14
      }
    }
  },
  "entry": {
    "long": {
      "operator": "AND",
      "conditions": [
        {
          "left": "close",
          "op": ">",
          "right": "donchianHigh.prev"
        },
        {
          "left": "adx",
          "op": "<",
          "right": "$adxThreshold"
        }
      ]
    }
  },
  "exit": {
    "stopLoss": {
      "type": "swingHighLow",
      "buffer": 0.6,
      "indicator": "atr"
    },
    "takeProfit": {
      "type": "riskReward",
      "multiplier": 3
    },
    "trailingStop": {
      "enabled": true,
      "type": "atr",
      "initialMultiplier": 2,
      "trailMultiplier": 3,
      "breakEvenAfterR": 1.5
    },
    "conditions": {
      "long": {
        "operator": "OR",
        "conditions": [
          {
            "left": "close",
            "op": "<",
            "right": "donchianLow"
          }
        ]
      }
    }
  },
  "confidence": {
    "base": 70,
    "bonuses": [
      {
        "condition": {
          "left": "volume",
          "op": ">",
          "right": "volume.sma20"
        },
        "bonus": 10,
        "description": "Volume confirmando breakout"
      },
      {
        "condition": {
          "left": "adx",
          "op": "<",
          "right": 20
        },
        "bonus": 5,
        "description": "Volatilidade muito baixa (melhor setup)"
      }
    ],
    "max": 90
  },
  "filters": {
    "minConfidence": 65,
    "minRiskReward": 2
  }
}