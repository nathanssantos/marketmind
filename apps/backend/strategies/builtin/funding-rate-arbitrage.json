{
  "id": "funding-rate-arbitrage",
  "name": "Funding Rate Arbitrage",
  "version": "1.0.0",
  "description": "Estrat\u00e9gia baseada em funding rates de futuros. Entry contra posi\u00e7\u00f5es extremas de funding. Mean reversion de sentiment.",
  "author": "MarketMind",
  "tags": [
    "funding-rate",
    "sentiment",
    "futures",
    "mean-reversion"
  ],
  "source": "Crypto Derivatives Trading",
  "status": "active",
  "optimizedParams": {
    "maxPositionSize": 60,
    "maxConcurrentPositions": 2,
    "maxTotalExposure": 70,
    "useAlgorithmicLevels": true,
    "useTrailingStop": false,
    "onlyWithTrend": false,
    "minConfidence": 70,
    "commission": 0.001
  },
  "recommendedTimeframes": {
    "primary": "8h",
    "secondary": [
      "4h",
      "1d"
    ],
    "avoid": [
      "1m",
      "5m",
      "15m",
      "1h"
    ],
    "notes": "Funding rate every 8h typically"
  },
  "parameters": {
    "extremeFunding": {
      "default": 0.1,
      "min": 0.05,
      "max": 0.2,
      "step": 0.025,
      "description": "Funding rate extreme %"
    },
    "atrMultiplier": {
      "default": 2.5,
      "min": 2,
      "max": 3.5,
      "step": 0.5,
      "description": "ATR stop"
    }
  },
  "indicators": {
    "fundingRate": {
      "type": "fundingRate",
      "params": {}
    },
    "ema20": {
      "type": "ema",
      "params": {
        "period": 20
      }
    },
    "atr": {
      "type": "atr",
      "params": {
        "period": 14
      }
    }
  },
  "entry": {
    "long": {
      "operator": "AND",
      "conditions": [
        {
          "left": "fundingRate",
          "op": "<",
          "right": {
            "calc": "-1 * $extremeFunding"
          }
        }
      ]
    },
    "short": {
      "operator": "AND",
      "conditions": [
        {
          "left": "fundingRate",
          "op": ">",
          "right": "$extremeFunding"
        }
      ]
    }
  },
  "exit": {
    "stopLoss": {
      "type": "swingHighLow",
      "buffer": 0.6,
      "indicator": "atr"
    },
    "takeProfit": {
      "type": "riskReward",
      "multiplier": 2
    },
    "conditions": {
      "long": {
        "operator": "OR",
        "conditions": [
          {
            "left": "fundingRate",
            "op": ">",
            "right": 0
          }
        ]
      },
      "short": {
        "operator": "OR",
        "conditions": [
          {
            "left": "fundingRate",
            "op": "<",
            "right": 0
          }
        ]
      }
    },
    "trailingStop": {
      "enabled": true,
      "type": "atr",
      "initialMultiplier": 2,
      "trailMultiplier": 1.5,
      "breakEvenAfterR": 1
    }
  },
  "confidence": {
    "base": 70,
    "bonuses": [
      {
        "condition": {
          "left": "fundingRate",
          "op": "<",
          "right": -0.15
        },
        "bonus": 15,
        "description": "Very negative funding"
      }
    ],
    "max": 90
  },
  "filters": {
    "minConfidence": 70,
    "minRiskReward": 1.5
  }
}