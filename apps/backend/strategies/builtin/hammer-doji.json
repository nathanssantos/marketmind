{
  "id": "hammer-doji",
  "name": "Hammer Doji",
  "version": "1.0.0",
  "description": "Hammer e Doji candlestick patterns. Padr\u00f5es de indecis\u00e3o e revers\u00e3o em suportes/resist\u00eancias. Entry com confirma\u00e7\u00e3o.",
  "author": "MarketMind",
  "tags": [
    "reversal",
    "candlestick",
    "hammer",
    "doji",
    "pattern"
  ],
  "source": "Japanese Candlestick Classic",
  "status": "active",
  "optimizedParams": {
    "maxPositionSize": 70,
    "maxConcurrentPositions": 2,
    "maxTotalExposure": 80,
    "useAlgorithmicLevels": true,
    "useTrailingStop": false,
    "onlyWithTrend": false,
    "minConfidence": 70,
    "commission": 0.001
  },
  "recommendedTimeframes": {
    "primary": "4h",
    "secondary": [
      "1h",
      "1d"
    ],
    "avoid": [
      "1m",
      "5m"
    ],
    "notes": "Hammer/Doji on 4h or daily"
  },
  "parameters": {
    "wickRatio": {
      "default": 2,
      "min": 1.5,
      "max": 3,
      "step": 0.5,
      "description": "Ratio m\u00ednimo wick/body"
    },
    "atrMultiplier": {
      "default": 2,
      "min": 1.5,
      "max": 3,
      "step": 0.5,
      "description": "ATR para stop"
    }
  },
  "indicators": {
    "candlePatterns": {
      "type": "candlePatterns",
      "params": {
        "wickRatio": "$wickRatio"
      }
    },
    "atr": {
      "type": "atr",
      "params": {
        "period": 14
      }
    }
  },
  "entry": {
    "long": {
      "operator": "AND",
      "conditions": [
        {
          "left": "candlePatterns.hammer",
          "op": "==",
          "right": true
        },
        {
          "left": "close",
          "op": ">",
          "right": "high[1]"
        }
      ]
    },
    "short": {
      "operator": "AND",
      "conditions": [
        {
          "left": "candlePatterns.invertedHammer",
          "op": "==",
          "right": true
        },
        {
          "left": "close",
          "op": "<",
          "right": "low[1]"
        }
      ]
    }
  },
  "exit": {
    "stopLoss": {
      "type": "swingHighLow",
      "buffer": 0.6,
      "indicator": "atr"
    },
    "takeProfit": {
      "type": "riskReward",
      "multiplier": 2
    },
    "trailingStop": {
      "enabled": true,
      "type": "atr",
      "initialMultiplier": 2,
      "trailMultiplier": 1.5,
      "breakEvenAfterR": 1
    }
  },
  "confidence": {
    "base": 70,
    "bonuses": [
      {
        "condition": {
          "left": "volume",
          "op": ">",
          "right": "volume.sma20"
        },
        "bonus": 10,
        "description": "Volume on pattern"
      }
    ],
    "max": 85
  },
  "filters": {
    "minConfidence": 70,
    "minRiskReward": 1.0
  }
}