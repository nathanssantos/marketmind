// @id adx-ema-trend
// @name ADX Trend Filter + EMA Crossover
// @version 1.0.0
// @description Enhanced EMA crossover strategy with ADX trend filter. Filters out false signals in ranging markets by requiring ADX > 25 for trend confirmation. 2025 refinement of classic EMA crossover.
// @author MarketMind
// @tags trend-following,adx,ema,crossover,filter
// @strategyType TREND_FOLLOWING
// @momentumType ANY
// @param fastEma Fast EMA period
// @param slowEma Slow EMA period
// @param adxPeriod ADX period
// @param adxThreshold Minimum ADX for trend
// @param atrMultiplier ATR multiplier for stop
// @param rrMultiplier Risk-reward multiplier

//@version=5
indicator('ADX Trend Filter + EMA Crossover', overlay=true)

fastEma = input.int(9, 'fastEma', minval=5, maxval=15, step=2)
slowEma = input.int(21, 'slowEma', minval=15, maxval=30, step=3)
adxPeriod = input.int(14, 'adxPeriod', minval=10, maxval=20, step=2)
adxThreshold = input.int(20, 'adxThreshold', minval=15, maxval=35, step=5)
atrMultiplier = input.float(1.5, 'atrMultiplier', minval=1, maxval=2.5, step=0.25)
rrMultiplier = input.float(2, 'rrMultiplier', minval=1.5, maxval=3, step=0.5)

emaFast = ta.ema(close, fastEma)
emaSlow = ta.ema(close, slowEma)
[_adx_plus, _adx_minus, adx_adx] = ta.dmi(adxPeriod, adxPeriod)
adx_plusDI = _adx_plus
adx_minusDI = _adx_minus
atr = ta.atr(14)
atrVal = atr

volSma20 = ta.sma(volume, 20)

longEntry = (ta.crossover(emaFast, emaSlow) and adx_adx > adxThreshold and adx_plusDI > adx_minusDI)
shortEntry = (ta.crossunder(emaFast, emaSlow) and adx_adx > adxThreshold and adx_minusDI > adx_plusDI)

confBase = 70
confBonus0 = adx_adx > 30 ? 10 : 0
confBonus1 = volume > ta.sma(volume, 20) ? 10 : 0
confBonus2 = adx_adx > 40 ? 5 : 0
confValue = math.min(confBase + confBonus0 + confBonus1 + confBonus2, 95)

exitLong = false
exitShort = false

sig = longEntry ? 1 : shortEntry ? -1 : 0
sl = longEntry ? close - atrVal * 0.6 : shortEntry ? close + atrVal * 0.6 : na
tp = longEntry ? close + math.abs(close - (close - atrVal * 0.6)) * rrMultiplier : shortEntry ? close - math.abs((close + atrVal * 0.6) - close) * rrMultiplier : na
conf = longEntry or shortEntry ? confValue : 0
exitSig = exitLong ? 1 : exitShort ? -1 : 0

plot(sig, 'signal', display=display.none)
plot(sl, 'stopLoss', display=display.none)
plot(tp, 'takeProfit', display=display.none)
plot(conf, 'confidence', display=display.none)
plot(exitSig, 'exitSignal', display=display.none)
