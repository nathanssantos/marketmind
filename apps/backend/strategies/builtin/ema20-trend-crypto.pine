// @id ema20-trend-crypto
// @name EMA20 Trend Crypto
// @version 1.0.0
// @description Estratégia de trend-following com EMA de 20 dias para Bitcoin. Backtestada com 126% CAGR, 39% max DD, profit factor 2.69 em 127 trades. Win rate baixo (33%) mas alto avg gain por trade (5.99%).
// @author MarketMind
// @tags trend-following,ema,momentum,crypto-optimized
// @strategyType TREND_FOLLOWING
// @momentumType BREAKOUT
// @param emaPeriod Período da EMA
// @param atrMultiplier Multiplicador ATR para stop loss
// @param rrMultiplier Risk-reward para take profit

//@version=5
indicator('EMA20 Trend Crypto', overlay=true)

emaPeriod = input.int(20, 'emaPeriod', minval=15, maxval=30, step=5)
atrMultiplier = input.float(2, 'atrMultiplier', minval=1.5, maxval=3, step=0.5)
rrMultiplier = input.float(3, 'rrMultiplier', minval=2, maxval=4, step=0.5)

ema = ta.ema(close, emaPeriod)
atr = ta.atr(14)
atrVal = atr

volSma20 = ta.sma(volume, 20)

longEntry = ta.crossover(close, ema)
shortEntry = ta.crossunder(close, ema)

confBase = 65
confBonus0 = volume > ta.sma(volume, 20) ? 10 : 0
confBonus1 = atr > atr[1] ? 5 : 0
confValue = math.min(confBase + confBonus0 + confBonus1, 90)

exitLong = ta.crossunder(close, ema)
exitShort = ta.crossover(close, ema)

sig = longEntry ? 1 : shortEntry ? -1 : 0
sl = longEntry ? close - atrVal * 0.6 : shortEntry ? close + atrVal * 0.6 : na
tp = longEntry ? close + math.abs(close - (close - atrVal * 0.6)) * rrMultiplier : shortEntry ? close - math.abs((close + atrVal * 0.6) - close) * rrMultiplier : na
conf = longEntry or shortEntry ? confValue : 0
exitSig = exitLong ? 1 : exitShort ? -1 : 0

plot(sig, 'signal', display=display.none)
plot(sl, 'stopLoss', display=display.none)
plot(tp, 'takeProfit', display=display.none)
plot(conf, 'confidence', display=display.none)
plot(exitSig, 'exitSignal', display=display.none)
