// @id fair-value-gap
// @name Fair Value Gap
// @version 1.0.0
// @description Trading em Fair Value Gaps (FVG/imbalances). Entry quando preço retorna a FVGs não preenchidos. Smart Money Concept.
// @author MarketMind
// @tags price-action,fvg,imbalance,smart-money
// @strategyType ANY
// @momentumType ANY
// @param minGapSize Gap mínimo %
// @param maxAge Idade máxima do FVG em candles
// @param atrMultiplier ATR stop

//@version=5
indicator('Fair Value Gap', overlay=true)

minGapSize = input.float(0.5, 'minGapSize', minval=0.25, maxval=1, step=0.25)
maxAge = input.int(20, 'maxAge', minval=10, maxval=50, step=10)
atrMultiplier = input.float(2, 'atrMultiplier', minval=1.5, maxval=3, step=0.5)

fvg_bullish = low > high[2] ? 1 : 0
fvg_bearish = high < low[2] ? 1 : 0
fvg_bullishTop = fvg_bullish == 1 ? low : na
fvg_bullishBottom = fvg_bullish == 1 ? high[2] : na
fvg_bearishTop = fvg_bearish == 1 ? low[2] : na
fvg_bearishBottom = fvg_bearish == 1 ? high : na
ema50 = ta.ema(close, 50)
atr = ta.atr(14)
atrVal = atr

volSma20 = ta.sma(volume, 20)

longEntry = (close > ema50 and low <= fvg_bullishTop and close > fvg_bullishBottom)
shortEntry = (close < ema50 and high >= fvg_bearishBottom and close < fvg_bearishTop)

confBase = 70
confBonus0 = volume > ta.sma(volume, 20) ? 10 : 0
confValue = math.min(confBase + confBonus0, 85)

exitLong = false
exitShort = false

sig = longEntry ? 1 : shortEntry ? -1 : 0
sl = longEntry ? close - atrVal * 0.6 : shortEntry ? close + atrVal * 0.6 : na
tp = longEntry ? close + math.abs(close - (close - atrVal * 0.6)) * 2 : shortEntry ? close - math.abs((close + atrVal * 0.6) - close) * 2 : na
conf = longEntry or shortEntry ? confValue : 0
exitSig = exitLong ? 1 : exitShort ? -1 : 0

plot(sig, 'signal', display=display.none)
plot(sl, 'stopLoss', display=display.none)
plot(tp, 'takeProfit', display=display.none)
plot(conf, 'confidence', display=display.none)
plot(exitSig, 'exitSignal', display=display.none)
