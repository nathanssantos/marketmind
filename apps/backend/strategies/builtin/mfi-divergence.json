{
  "enabled": false,
  "id": "mfi-divergence",
  "name": "MFI Divergence",
  "version": "1.0.0",
  "description": "Money Flow Index divergence strategy. MFI é RSI com volume. Entry em oversold/overbought com confirmação de volume.",
  "author": "MarketMind",
  "tags": [
    "mean-reversion",
    "mfi",
    "money-flow",
    "volume"
  ],
  "source": "Gene Quong & Avrum Soudack",
  "status": "active",
  "recommendedTimeframes": {
    "primary": "1d",
    "secondary": [
      "4h"
    ],
    "avoid": [
      "1m",
      "5m"
    ],
    "notes": "MFI works best on daily"
  },
  "parameters": {
    "mfiPeriod": {
      "default": 14,
      "min": 10,
      "max": 21,
      "step": 1,
      "description": "Período do MFI"
    },
    "oversold": {
      "default": 20,
      "min": 10,
      "max": 30,
      "step": 5,
      "description": "Nível oversold"
    },
    "overbought": {
      "default": 80,
      "min": 70,
      "max": 90,
      "step": 5,
      "description": "Nível overbought"
    },
    "atrMultiplier": {
      "default": 2,
      "min": 1.5,
      "max": 3,
      "step": 0.5,
      "description": "ATR para stop"
    }
  },
  "indicators": {
    "mfi": {
      "type": "mfi",
      "params": {
        "period": "$mfiPeriod"
      }
    },
    "atr": {
      "type": "atr",
      "params": {
        "period": 14
      }
    }
  },
  "entry": {
    "long": {
      "operator": "AND",
      "conditions": [
        {
          "left": "mfi",
          "op": "crossover",
          "right": "$oversold"
        }
      ]
    },
    "short": {
      "operator": "AND",
      "conditions": [
        {
          "left": "mfi",
          "op": "crossunder",
          "right": "$overbought"
        }
      ]
    }
  },
  "exit": {
    "stopLoss": {
      "type": "swingHighLow",
      "buffer": 0.6,
      "indicator": "atr"
    },
    "takeProfit": {
      "type": "riskReward",
      "multiplier": 2
    },
    "conditions": {
      "long": {
        "operator": "OR",
        "conditions": [
          {
            "left": "mfi",
            "op": ">",
            "right": "$overbought"
          }
        ]
      },
      "short": {
        "operator": "OR",
        "conditions": [
          {
            "left": "mfi",
            "op": "<",
            "right": "$oversold"
          }
        ]
      }
    },
    "trailingStop": {
      "enabled": false,
      "type": "atr",
      "initialMultiplier": 2,
      "trailMultiplier": 1.5,
      "breakEvenAfterR": 1
    }
  },
  "confidence": {
    "base": 70,
    "bonuses": [
      {
        "condition": {
          "left": "mfi",
          "op": "<",
          "right": 10
        },
        "bonus": 10,
        "description": "Extremely oversold"
      },
      {
        "condition": {
          "left": "volume",
          "op": ">",
          "right": "volume.sma20"
        },
        "bonus": 5,
        "description": "Volume spike"
      }
    ],
    "max": 90
  },
  "filters": {
    "minConfidence": 70,
    "minRiskReward": 1,
    "volumeType": "REVERSAL",
    "strategyType": "MEAN_REVERSION",
    "momentumType": "REVERSAL"
  },
  "education": {
    "origin": "Gene Quong & Avrum Soudack - Money Flow Index (1989)",
    "createdYear": 1989,
    "candlePattern": {
      "lookback": 2,
      "candles": [
        {
          "offset": -1,
          "role": "reference",
          "descriptionKey": "strategies.mfiDivergence.candleMinus1"
        },
        {
          "offset": 0,
          "role": "trigger",
          "descriptionKey": "strategies.mfiDivergence.candleTrigger"
        }
      ],
      "indicatorsToShow": [
        "mfi",
        "volume",
        "atr"
      ]
    },
    "howItWorks": {
      "summaryKey": "strategies.mfiDivergence.summary",
      "entryKey": "strategies.mfiDivergence.entry",
      "exitKey": "strategies.mfiDivergence.exit"
    }
  }
}
