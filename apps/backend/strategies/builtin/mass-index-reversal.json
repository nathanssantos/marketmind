{
  "id": "mass-index-reversal",
  "name": "Mass Index Reversal",
  "version": "1.0.0",
  "description": "Mass Index para prever revers\u00f5es. Mede range expansion/contraction. Entry quando Mass Index > 27 e depois cai abaixo de 26.5 (reversal bulge).",
  "author": "MarketMind",
  "tags": [
    "reversal",
    "mass-index",
    "volatility",
    "range"
  ],
  "source": "Donald Dorsey - Mass Index Creator",
  "status": "active",
  "optimizedParams": {
    "maxPositionSize": 70,
    "maxConcurrentPositions": 2,
    "maxTotalExposure": 80,
    "useAlgorithmicLevels": true,
    "useTrailingStop": false,
    "onlyWithTrend": false,
    "minConfidence": 70,
    "commission": 0.001
  },
  "recommendedTimeframes": {
    "primary": "1d",
    "secondary": [
      "4h"
    ],
    "avoid": [
      "1m",
      "5m",
      "15m"
    ],
    "notes": "Mass Index works on daily"
  },
  "parameters": {
    "emaPeriod": {
      "default": 9,
      "min": 7,
      "max": 12,
      "step": 1,
      "description": "Per\u00edodo EMA para Mass Index"
    },
    "sumPeriod": {
      "default": 25,
      "min": 20,
      "max": 30,
      "step": 5,
      "description": "Per\u00edodo de soma"
    },
    "bulgeThreshold": {
      "default": 27,
      "min": 26,
      "max": 28,
      "step": 0.5,
      "description": "Threshold para bulge"
    },
    "atrMultiplier": {
      "default": 2,
      "min": 1.5,
      "max": 3,
      "step": 0.5,
      "description": "ATR para stop"
    }
  },
  "indicators": {
    "massIndex": {
      "type": "massIndex",
      "params": {
        "emaPeriod": "$emaPeriod",
        "sumPeriod": "$sumPeriod"
      }
    },
    "ema9": {
      "type": "ema",
      "params": {
        "period": 9
      }
    },
    "atr": {
      "type": "atr",
      "params": {
        "period": 14
      }
    }
  },
  "entry": {
    "long": {
      "operator": "AND",
      "conditions": [
        {
          "left": "massIndex.prev",
          "op": ">",
          "right": "$bulgeThreshold"
        },
        {
          "left": "massIndex",
          "op": "<",
          "right": 26.5
        },
        {
          "left": "close",
          "op": "<",
          "right": "ema9"
        }
      ]
    },
    "short": {
      "operator": "AND",
      "conditions": [
        {
          "left": "massIndex.prev",
          "op": ">",
          "right": "$bulgeThreshold"
        },
        {
          "left": "massIndex",
          "op": "<",
          "right": 26.5
        },
        {
          "left": "close",
          "op": ">",
          "right": "ema9"
        }
      ]
    }
  },
  "exit": {
    "stopLoss": {
      "type": "swingHighLow",
      "lookback": 3,
      "buffer": 0.6,
      "indicator": "atr"
    },
    "takeProfit": {
      "type": "riskReward",
      "multiplier": 2
    },
    "trailingStop": {
      "enabled": true,
      "type": "atr",
      "initialMultiplier": 2,
      "trailMultiplier": 1.5,
      "breakEvenAfterR": 1
    }
  },
  "confidence": {
    "base": 70,
    "bonuses": [
      {
        "condition": {
          "left": "volume",
          "op": ">",
          "right": "volume.sma20"
        },
        "bonus": 10,
        "description": "Volume confirms"
      }
    ],
    "max": 85
  },
  "filters": {
    "minConfidence": 70,
    "minRiskReward": 1.5
  }
}