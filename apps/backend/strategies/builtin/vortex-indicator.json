{
  "id": "vortex-indicator",
  "name": "Vortex Indicator",
  "version": "1.0.0",
  "description": "Vortex Indicator (VI+ e VI-) para trend direction. Mede movimento positivo/negativo em relação ao range. Entry quando VI+ cruza VI-.",
  "author": "MarketMind",
  "tags": ["trend-following", "vortex", "directional"],
  "source": "Etienne Botes & Douglas Siepman",

  "status": "active",
  "optimizedParams": {
    "maxPositionSize": 70,
    "maxConcurrentPositions": 2,
    "maxTotalExposure": 80,
    "useAlgorithmicLevels": true,
    "useTrailingStop": true,
    "trailingATRMultiplier": 2.5,
    "breakEvenAfterR": 1.5,
    "onlyWithTrend": false,
    "minConfidence": 65,
    "commission": 0.001
  },
  "recommendedTimeframes": {
    "primary": "1d",
    "secondary": ["4h"],
    "avoid": ["1m", "5m"],
    "notes": "Vortex works well on daily"
  },

  "parameters": {
    "vortexPeriod": { "default": 14, "min": 10, "max": 21, "step": 1, "description": "Período do Vortex" },
    "atrMultiplier": { "default": 2, "min": 1.5, "max": 3, "step": 0.5, "description": "ATR para stop" }
  },

  "indicators": {
    "vortex": { "type": "vortex", "params": { "period": "$vortexPeriod" } },
    "atr": { "type": "atr", "params": { "period": 14 } }
  },

  "entry": {
    "long": {
      "operator": "AND",
      "conditions": [
        { "left": "vortex.plus", "op": "crossover", "right": "vortex.minus" }
      ]
    },
    "short": {
      "operator": "AND",
      "conditions": [
        { "left": "vortex.minus", "op": "crossover", "right": "vortex.plus" }
      ]
    }
  },

  "exit": {
    "stopLoss": { "type": "atr", "multiplier": "$atrMultiplier", "indicator": "atr" },
    "takeProfit": { "type": "riskReward", "multiplier": 2.5 },
    "trailingStop": { "enabled": true, "type": "atr", "initialMultiplier": 2, "trailMultiplier": 2.5, "breakEvenAfterR": 1.5 },
    "conditions": {
      "long": { "operator": "OR", "conditions": [{ "left": "vortex.minus", "op": ">", "right": "vortex.plus" }] },
      "short": { "operator": "OR", "conditions": [{ "left": "vortex.plus", "op": ">", "right": "vortex.minus" }] }
    }
  },

  "confidence": {
    "base": 65,
    "bonuses": [
      { "condition": { "left": "volume", "op": ">", "right": "volume.sma20" }, "bonus": 10, "description": "Volume confirms" }
    ],
    "max": 85
  },

  "filters": { "minConfidence": 65, "minRiskReward": 2 }
}
