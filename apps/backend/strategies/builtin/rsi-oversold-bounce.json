{
  "enabled": true,
  "id": "rsi-oversold-bounce",
  "name": "RSI Oversold Bounce",
  "version": "1.0.0",
  "description": "RSI mean-reversion. Long: RSI crosses above 30 (oversold bounce). Short: RSI crosses below 70 (overbought reversal).",
  "author": "MarketMind",
  "tags": [
    "reversal",
    "rsi",
    "oversold",
    "momentum"
  ],
  "status": "active",
  "backtestSummary": {
    "profitFactor": 2.16,
    "winRate": 53.85,
    "totalTrades": 13,
    "netPnlPercent": 1.17,
    "testedAt": "2025-12-09",
    "testedTimeframe": "1d",
    "testedSymbol": "BTCUSDT"
  },
  "recommendedTimeframes": {
    "primary": "1d",
    "secondary": [
      "4h"
    ],
    "avoid": [
      "1m",
      "5m",
      "15m"
    ],
    "notes": "RSI oversold bounce works best on daily for mean-reversion"
  },
  "parameters": {
    "rsiPeriod": {
      "default": 14,
      "min": 7,
      "max": 21,
      "step": 1,
      "description": "Período do RSI"
    },
    "oversoldLevel": {
      "default": 30,
      "min": 20,
      "max": 35,
      "step": 5,
      "description": "RSI oversold level for long entry"
    },
    "overboughtLevel": {
      "default": 70,
      "min": 65,
      "max": 80,
      "step": 5,
      "description": "RSI overbought level for short entry"
    },
    "exitLevelLong": {
      "default": 50,
      "min": 40,
      "max": 60,
      "step": 5,
      "description": "RSI exit level for long (neutral zone)"
    },
    "exitLevelShort": {
      "default": 50,
      "min": 40,
      "max": 60,
      "step": 5,
      "description": "RSI exit level for short (neutral zone)"
    },
    "atrMultiplier": {
      "default": 2,
      "min": 1,
      "max": 3,
      "step": 0.5,
      "description": "Multiplicador do ATR para stop loss"
    }
  },
  "indicators": {
    "rsi": {
      "type": "rsi",
      "params": {
        "period": "$rsiPeriod"
      }
    },
    "atr": {
      "type": "atr",
      "params": {
        "period": 14
      }
    },
    "ema20": {
      "type": "ema",
      "params": {
        "period": 20
      }
    }
  },
  "entry": {
    "long": {
      "operator": "AND",
      "conditions": [
        {
          "left": "rsi.prev",
          "op": "<",
          "right": "$oversoldLevel"
        },
        {
          "left": "rsi",
          "op": ">=",
          "right": "$oversoldLevel"
        }
      ]
    },
    "short": {
      "operator": "AND",
      "conditions": [
        {
          "left": "rsi.prev",
          "op": ">",
          "right": "$overboughtLevel"
        },
        {
          "left": "rsi",
          "op": "<=",
          "right": "$overboughtLevel"
        }
      ]
    }
  },
  "exit": {
    "conditions": {
      "long": {
        "operator": "AND",
        "conditions": [
          {
            "left": "rsi",
            "op": ">",
            "right": "$exitLevelLong"
          }
        ]
      },
      "short": {
        "operator": "AND",
        "conditions": [
          {
            "left": "rsi",
            "op": "<",
            "right": "$exitLevelShort"
          }
        ]
      }
    },
    "stopLoss": {
      "type": "swingHighLow",
      "buffer": 0.6,
      "indicator": "atr"
    },
    "takeProfit": {
      "type": "pivotBased",
      "lookback": 40,
      "fallback": {
        "type": "riskReward",
        "multiplier": 2
      }
    },
    "maxBarsInTrade": 10,
    "trailingStop": {
      "enabled": true,
      "type": "atr",
      "initialMultiplier": 2,
      "trailMultiplier": 1.5,
      "breakEvenAfterR": 1
    }
  },
  "confidence": {
    "base": 60,
    "bonuses": [
      {
        "condition": {
          "left": "rsi",
          "op": "<",
          "right": 25
        },
        "bonus": 15,
        "description": "RSI extremamente oversold antes do bounce"
      },
      {
        "condition": {
          "left": "volume",
          "op": ">",
          "right": "volume.sma20"
        },
        "bonus": 10,
        "description": "Volume acima da média"
      },
      {
        "condition": {
          "left": "close",
          "op": ">",
          "right": "ema20"
        },
        "bonus": 5,
        "description": "Preço acima da EMA 20"
      }
    ],
    "max": 95
  },
  "filters": {
    "minConfidence": 60,
    "minRiskReward": 0
  },
  "education": {
    "origin": "J. Welles Wilder Jr. - New Concepts in Technical Trading Systems (1978)",
    "createdYear": 1978,
    "candlePattern": {
      "lookback": 3,
      "candles": [
        {
          "offset": -2,
          "role": "context",
          "descriptionKey": "strategies.rsiOversoldBounce.candleMinus2"
        },
        {
          "offset": -1,
          "role": "reference",
          "descriptionKey": "strategies.rsiOversoldBounce.candleMinus1"
        },
        {
          "offset": 0,
          "role": "trigger",
          "descriptionKey": "strategies.rsiOversoldBounce.candleTrigger"
        }
      ],
      "indicatorsToShow": [
        "rsi",
        "ema20",
        "atr"
      ]
    },
    "howItWorks": {
      "summaryKey": "strategies.rsiOversoldBounce.summary",
      "entryKey": "strategies.rsiOversoldBounce.entry",
      "exitKey": "strategies.rsiOversoldBounce.exit"
    }
  }
}
