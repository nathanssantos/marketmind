{
  "id": "obv-divergence",
  "name": "OBV Divergence",
  "version": "1.0.0",
  "description": "Classic divergence trading using On-Balance Volume. Entry when price makes new high/low but OBV doesn't confirm. Early reversal detection with volume analysis.",
  "author": "MarketMind",
  "tags": [
    "divergence",
    "obv",
    "volume",
    "reversal",
    "early-detection"
  ],
  "status": "active",
  "optimizedParams": {
    "maxPositionSize": 50,
    "useAlgorithmicLevels": true,
    "onlyWithTrend": true,
    "minConfidence": 60,
    "commission": 0.001
  },
  "recommendedTimeframes": {
    "primary": "1d",
    "secondary": [
      "4h"
    ],
    "avoid": [
      "1m",
      "5m",
      "15m"
    ],
    "notes": "OBV divergence needs higher timeframes for accurate volume analysis"
  },
  "parameters": {
    "obvSmaPeriod": {
      "default": 20,
      "min": 10,
      "max": 30,
      "step": 5,
      "description": "OBV SMA period"
    },
    "lookbackPeriod": {
      "default": 10,
      "min": 5,
      "max": 20,
      "step": 5,
      "description": "Lookback for divergence"
    },
    "rsiPeriod": {
      "default": 14,
      "min": 10,
      "max": 20,
      "step": 2,
      "description": "RSI period for confirmation"
    },
    "atrMultiplier": {
      "default": 1.5,
      "min": 1,
      "max": 2,
      "step": 0.25,
      "description": "ATR multiplier for stop"
    },
    "rrMultiplier": {
      "default": 2,
      "min": 1.5,
      "max": 3,
      "step": 0.5,
      "description": "Risk-reward multiplier"
    }
  },
  "indicators": {
    "obv": {
      "type": "obv",
      "params": {
        "smaPeriod": "$obvSmaPeriod"
      }
    },
    "rsi": {
      "type": "rsi",
      "params": {
        "period": "$rsiPeriod"
      }
    },
    "atr": {
      "type": "atr",
      "params": {
        "period": 14
      }
    }
  },
  "entry": {
    "long": {
      "operator": "AND",
      "conditions": [
        {
          "left": "obv.obv",
          "op": ">",
          "right": "obv.sma"
        },
        {
          "left": "rsi",
          "op": "<",
          "right": 40
        }
      ]
    },
    "short": {
      "operator": "AND",
      "conditions": [
        {
          "left": "obv.obv",
          "op": "<",
          "right": "obv.sma"
        },
        {
          "left": "rsi",
          "op": ">",
          "right": 60
        }
      ]
    }
  },
  "exit": {
    "stopLoss": {
      "type": "swingHighLow",
      "buffer": 0.6,
      "indicator": "atr"
    },
    "takeProfit": {
      "type": "riskReward",
      "multiplier": "$rrMultiplier"
    },
    "trailingStop": {
      "enabled": true,
      "type": "atr",
      "initialMultiplier": 2,
      "trailMultiplier": 1.5,
      "breakEvenAfterR": 1
    }
  },
  "confidence": {
    "base": 65,
    "bonuses": [
      {
        "condition": {
          "left": "volume",
          "op": ">",
          "right": "volume.sma20"
        },
        "bonus": 10,
        "description": "Volume expansion"
      },
      {
        "condition": {
          "left": "rsi",
          "op": "<",
          "right": 30
        },
        "bonus": 10,
        "description": "Oversold RSI for longs"
      },
      {
        "condition": {
          "left": "rsi",
          "op": ">",
          "right": 70
        },
        "bonus": 10,
        "description": "Overbought RSI for shorts"
      }
    ],
    "max": 90
  },
  "filters": {
    "minConfidence": 60,
    "minRiskReward": 1.5
  }
}