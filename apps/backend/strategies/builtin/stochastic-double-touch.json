{
  "id": "stochastic-double-touch",
  "name": "Stochastic Double Touch",
  "version": "1.0.0",
  "description": "Setup de reversão baseado em duplo toque do Estocástico em zonas extremas sem cruzar a linha 50. Identifica pontos de reversão forte onde o preço testa zonas de oversold/overbought duas vezes antes de reverter.",
  "author": "MarketMind",
  "tags": [
    "reversal",
    "stochastic",
    "mean-reversion",
    "double-touch",
    "oscillator"
  ],
  "source": "Custom - Stochastic Double Touch Pattern",
  "status": "active",
  "enabled": false,
  "group": "pattern",
  "backtestSummary": {
    "referenceCAGR": 0,
    "referenceMaxDrawdown": 0,
    "referenceBenchmark": "Not yet backtested",
    "testedPeriod": "N/A",
    "source": "Custom Strategy"
  },
  "recommendedTimeframes": {
    "primary": "1h",
    "secondary": [
      "4h",
      "1d"
    ],
    "avoid": [
      "1m",
      "5m"
    ],
    "notes": "Funciona melhor em timeframes maiores onde as reversões são mais confiáveis"
  },
  "parameters": {
    "stochPeriod": {
      "default": 14,
      "min": 10,
      "max": 21,
      "step": 1,
      "description": "Período do Estocástico"
    },
    "stochSmoothK": {
      "default": 3,
      "min": 1,
      "max": 5,
      "step": 1,
      "description": "Suavização K do Estocástico"
    },
    "oversoldLevel": {
      "default": 20,
      "min": 15,
      "max": 30,
      "step": 5,
      "description": "Nível de oversold"
    },
    "overboughtLevel": {
      "default": 80,
      "min": 70,
      "max": 85,
      "step": 5,
      "description": "Nível de overbought"
    },
    "volumeMultiplier": {
      "default": 1.2,
      "min": 1,
      "max": 2,
      "step": 0.1,
      "description": "Multiplicador de volume mínimo"
    },
    "atrMultiplier": {
      "default": 2.5,
      "min": 2,
      "max": 4,
      "step": 0.5,
      "description": "Multiplicador ATR para take profit"
    }
  },
  "indicators": {
    "stoch": {
      "type": "stochastic",
      "params": {
        "period": "$stochPeriod",
        "smoothK": "$stochSmoothK"
      }
    },
    "atr": {
      "type": "atr",
      "params": {
        "period": 14
      }
    },
    "volumeSMA": {
      "type": "sma",
      "params": {
        "period": 20,
        "source": "volume"
      }
    }
  },
  "entry": {
    "long": {
      "operator": "AND",
      "conditions": [
        {
          "left": "stoch.k[1]",
          "op": "<",
          "right": "$oversoldLevel"
        },
        {
          "left": "stoch.k",
          "op": ">=",
          "right": "$oversoldLevel"
        },
        {
          "left": "volume",
          "op": ">",
          "right": "volumeSMA * $volumeMultiplier"
        }
      ]
    },
    "short": {
      "operator": "AND",
      "conditions": [
        {
          "left": "stoch.k[1]",
          "op": ">",
          "right": "$overboughtLevel"
        },
        {
          "left": "stoch.k",
          "op": "<=",
          "right": "$overboughtLevel"
        },
        {
          "left": "volume",
          "op": ">",
          "right": "volumeSMA * $volumeMultiplier"
        }
      ]
    }
  },
  "exit": {
    "stopLoss": {
      "type": "swingHighLow",
      "buffer": 0.5,
      "indicator": "atr",
      "lookback": 40
    },
    "takeProfit": {
      "type": "swingHighLow",
      "opposite": true,
      "lookback": 40
    },
    "trailingStop": {
      "enabled": false,
      "type": "atr",
      "initialMultiplier": 2.5,
      "trailMultiplier": 3,
      "breakEvenAfterR": 1.5
    }
  },
  "confidence": {
    "base": 70,
    "bonuses": [
      {
        "condition": {
          "left": "volume",
          "op": ">",
          "right": "volumeSMA * 1.5"
        },
        "bonus": 10,
        "description": "Volume muito alto"
      },
      {
        "condition": {
          "left": "atr",
          "op": ">",
          "right": "atr.sma20 * 1.2"
        },
        "bonus": 5,
        "description": "Volatilidade aumentando"
      }
    ],
    "max": 95
  },
  "filters": {
    "minConfidence": 70,
    "minRiskReward": 2,
    "trendFilter": {
      "enabled": false,
      "indicator": "ema",
      "period": 200,
      "allowCounterTrend": true
    },
    "volumeType": "REVERSAL",
    "strategyType": "MEAN_REVERSION",
    "momentumType": "REVERSAL"
  },
  "education": {
    "origin": "MarketMind - Stochastic oscillator reversal pattern",
    "createdYear": 2025,
    "candlePattern": {
      "lookback": 2,
      "candles": [
        {
          "offset": -1,
          "role": "reference",
          "descriptionKey": "strategies.stochDoubleTouch.candleMinus1"
        },
        {
          "offset": 0,
          "role": "trigger",
          "descriptionKey": "strategies.stochDoubleTouch.candleTrigger"
        }
      ],
      "indicatorsToShow": [
        "stoch",
        "atr",
        "volumeSMA"
      ]
    },
    "howItWorks": {
      "summaryKey": "strategies.stochDoubleTouch.summary",
      "entryKey": "strategies.stochDoubleTouch.entry",
      "exitKey": "strategies.stochDoubleTouch.exit"
    }
  }
}
