// @id volume-price-breakout
// @name Volume Price Breakout
// @version 1.0.0
// @description Estratégia de breakout com confirmação de volume: entry quando preço quebra high de N dias COM volume > 150% da média. Volume confirma força do breakout.
// @author MarketMind
// @tags breakout,volume,price-action,confirmation
// @strategyType TREND_FOLLOWING
// @momentumType BREAKOUT
// @param lookbackPeriod Período de lookback para high/low
// @param volumeMultiplier Multiplicador de volume mínimo
// @param atrMultiplier Multiplicador ATR para stop

//@version=5
indicator('Volume Price Breakout', overlay=true)

lookbackPeriod = input.int(10, 'lookbackPeriod', minval=5, maxval=20, step=5)
volumeMultiplier = input.float(1.5, 'volumeMultiplier', minval=1.2, maxval=2, step=0.1)
atrMultiplier = input.float(2, 'atrMultiplier', minval=1.5, maxval=3, step=0.5)

range_isNDayHigh = high >= ta.highest(high, lookbackPeriod)
range_isNDayLow = low <= ta.lowest(low, lookbackPeriod)
volumeSma = ta.sma(volume, 20)
atr = ta.atr(14)
atrVal = atr

volSma20 = ta.sma(volume, 20)

longEntry = (close > range_isNDayHigh and volume > (volumeSma * volumeMultiplier))
shortEntry = (close < range_isNDayLow and volume > (volumeSma * volumeMultiplier))

confBase = 70
confBonus0 = volume > (volumeSma * 2) ? 10 : 0
confValue = math.min(confBase + confBonus0, 90)

exitLong = false
exitShort = false

sig = longEntry ? 1 : shortEntry ? -1 : 0
sl = longEntry ? close - atrVal * 0.6 : shortEntry ? close + atrVal * 0.6 : na
tp = longEntry ? close + math.abs(close - (close - atrVal * 0.6)) * 2.5 : shortEntry ? close - math.abs((close + atrVal * 0.6) - close) * 2.5 : na
conf = longEntry or shortEntry ? confValue : 0
exitSig = exitLong ? 1 : exitShort ? -1 : 0

plot(sig, 'signal', display=display.none)
plot(sl, 'stopLoss', display=display.none)
plot(tp, 'takeProfit', display=display.none)
plot(conf, 'confidence', display=display.none)
plot(exitSig, 'exitSignal', display=display.none)
