{
  "id": "momentum-rotation",
  "name": "Momentum Rotation",
  "version": "1.0.0",
  "description": "Momentum rotation strategy. Long: ROC > 5% and price > EMA50. Short: ROC < -5% and price < EMA50.",
  "author": "MarketMind",
  "tags": [
    "momentum",
    "rotation",
    "relative-strength",
    "ranking"
  ],
  "source": "Dual Momentum Strategy",
  "status": "active",
  "enabled": true,
  "group": "pattern",
  "recommendedTimeframes": {
    "primary": "1d",
    "secondary": [
      "1w"
    ],
    "avoid": [
      "1m",
      "5m",
      "15m",
      "1h"
    ],
    "notes": "Momentum rotation on daily/weekly"
  },
  "parameters": {
    "momentumPeriod": {
      "default": 20,
      "min": 10,
      "max": 30,
      "step": 5,
      "description": "Período momentum"
    },
    "minMomentumLong": {
      "default": 5,
      "min": 0,
      "max": 15,
      "step": 2.5,
      "description": "Minimum positive momentum % for long"
    },
    "minMomentumShort": {
      "default": -5,
      "min": -15,
      "max": 0,
      "step": 2.5,
      "description": "Maximum negative momentum % for short"
    },
    "atrMultiplier": {
      "default": 2,
      "min": 1.5,
      "max": 3,
      "step": 0.5,
      "description": "ATR stop"
    }
  },
  "indicators": {
    "roc": {
      "type": "roc",
      "params": {
        "period": "$momentumPeriod"
      }
    },
    "ema50": {
      "type": "ema",
      "params": {
        "period": 50
      }
    },
    "atr": {
      "type": "atr",
      "params": {
        "period": 14
      }
    }
  },
  "entry": {
    "long": {
      "operator": "AND",
      "conditions": [
        {
          "left": "roc",
          "op": ">",
          "right": "$minMomentumLong"
        },
        {
          "left": "close",
          "op": ">",
          "right": "ema50"
        }
      ]
    },
    "short": {
      "operator": "AND",
      "conditions": [
        {
          "left": "roc",
          "op": "<",
          "right": "$minMomentumShort"
        },
        {
          "left": "close",
          "op": "<",
          "right": "ema50"
        }
      ]
    }
  },
  "exit": {
    "stopLoss": {
      "type": "swingHighLow",
      "buffer": 0.6,
      "indicator": "atr"
    },
    "takeProfit": {
      "type": "riskReward",
      "multiplier": 2.5
    },
    "trailingStop": {
      "enabled": true,
      "type": "atr",
      "initialMultiplier": 2,
      "trailMultiplier": 2.5,
      "breakEvenAfterR": 1.5
    },
    "conditions": {
      "long": {
        "operator": "OR",
        "conditions": [
          {
            "left": "roc",
            "op": "<",
            "right": 0
          }
        ]
      },
      "short": {
        "operator": "OR",
        "conditions": [
          {
            "left": "roc",
            "op": ">",
            "right": 0
          }
        ]
      }
    }
  },
  "confidence": {
    "base": 65,
    "bonuses": [
      {
        "condition": {
          "left": "roc",
          "op": ">",
          "right": 15
        },
        "bonus": 15,
        "description": "Strong momentum"
      },
      {
        "condition": {
          "left": "volume",
          "op": ">",
          "right": "volume.sma20"
        },
        "bonus": 5,
        "description": "Volume"
      }
    ],
    "max": 90
  },
  "filters": {
    "minConfidence": 65,
    "minRiskReward": 2,
    "trendFilter": {
      "enabled": true,
      "indicator": "ema",
      "period": 200,
      "allowCounterTrend": false
    }
  },
  "education": {
    "origin": "Gary Antonacci - 'Dual Momentum Investing' (2014)",
    "createdYear": 2014,
    "candlePattern": {
      "lookback": 1,
      "candles": [
        {
          "offset": 0,
          "role": "trigger",
          "descriptionKey": "strategies.momentumRotation.candleTrigger"
        }
      ],
      "indicatorsToShow": [
        "roc",
        "ema50",
        "atr"
      ]
    },
    "howItWorks": {
      "summaryKey": "strategies.momentumRotation.summary",
      "entryKey": "strategies.momentumRotation.entry",
      "exitKey": "strategies.momentumRotation.exit"
    }
  }
}
