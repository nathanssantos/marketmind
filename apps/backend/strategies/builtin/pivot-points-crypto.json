{
  "id": "pivot-points-crypto",
  "name": "Pivot Points Crypto",
  "version": "1.0.0",
  "description": "Classic Pivot Points strategy para crypto. Entry em bounces de n\u00edveis de suporte/resist\u00eancia calculados (S1, R1, etc).",
  "author": "MarketMind",
  "tags": [
    "support-resistance",
    "pivot-points",
    "levels",
    "intraday"
  ],
  "source": "Floor Traders Classic",
  "status": "active",
  "optimizedParams": {
    "maxPositionSize": 70,
    "maxConcurrentPositions": 2,
    "maxTotalExposure": 80,
    "useAlgorithmicLevels": true,
    "useTrailingStop": false,
    "onlyWithTrend": false,
    "minConfidence": 70,
    "commission": 0.001
  },
  "recommendedTimeframes": {
    "primary": "1h",
    "secondary": [
      "4h"
    ],
    "avoid": [
      "1m",
      "5m"
    ],
    "notes": "Pivot points work well intraday"
  },
  "parameters": {
    "pivotType": {
      "default": "standard",
      "options": [
        "standard",
        "fibonacci",
        "woodie"
      ],
      "description": "Tipo de pivot"
    },
    "atrMultiplier": {
      "default": 1.5,
      "min": 1,
      "max": 2.5,
      "step": 0.5,
      "description": "ATR para stop"
    }
  },
  "indicators": {
    "pivots": {
      "type": "pivotPoints",
      "params": {
        "type": "$pivotType"
      }
    },
    "atr": {
      "type": "atr",
      "params": {
        "period": 14
      }
    }
  },
  "entry": {
    "long": {
      "operator": "AND",
      "conditions": [
        {
          "left": "low",
          "op": "<=",
          "right": "pivots.s1"
        },
        {
          "left": "close",
          "op": ">",
          "right": "pivots.s1"
        }
      ]
    },
    "short": {
      "operator": "AND",
      "conditions": [
        {
          "left": "high",
          "op": ">=",
          "right": "pivots.r1"
        },
        {
          "left": "close",
          "op": "<",
          "right": "pivots.r1"
        }
      ]
    }
  },
  "exit": {
    "stopLoss": {
      "type": "swingHighLow",
      "buffer": 0.6,
      "indicator": "atr"
    },
    "takeProfit": {
      "type": "indicator",
      "indicator": "pivots.pivot"
    },
    "conditions": {
      "long": {
        "operator": "OR",
        "conditions": [
          {
            "left": "close",
            "op": ">=",
            "right": "pivots.pivot"
          }
        ]
      },
      "short": {
        "operator": "OR",
        "conditions": [
          {
            "left": "close",
            "op": "<=",
            "right": "pivots.pivot"
          }
        ]
      }
    },
    "trailingStop": {
      "enabled": true,
      "type": "atr",
      "initialMultiplier": 2,
      "trailMultiplier": 1.5,
      "breakEvenAfterR": 1
    }
  },
  "confidence": {
    "base": 70,
    "bonuses": [
      {
        "condition": {
          "left": "volume",
          "op": ">",
          "right": "volume.sma20"
        },
        "bonus": 10,
        "description": "Volume at support"
      }
    ],
    "max": 85
  },
  "filters": {
    "minConfidence": 70,
    "minRiskReward": 1.5
  }
}