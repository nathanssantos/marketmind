{
  "id": "order-flow-imbalance",
  "name": "Order Flow Imbalance",
  "version": "1.0.0",
  "description": "Detecta desequilíbrios de orderflow via volume. Entry quando volume de compra/venda é significativamente desbalanceado.",
  "author": "MarketMind",
  "tags": [
    "orderflow",
    "volume",
    "imbalance",
    "institutional"
  ],
  "source": "Order Flow Analysis",
  "status": "active",
  "recommendedTimeframes": {
    "primary": "1h",
    "secondary": [
      "15m",
      "4h"
    ],
    "avoid": [
      "1m",
      "5m"
    ],
    "notes": "Order flow on 1h"
  },
  "parameters": {
    "imbalanceRatio": {
      "default": 2,
      "min": 1.5,
      "max": 3,
      "step": 0.5,
      "description": "Ratio mínimo buy/sell"
    },
    "volumeMultiplier": {
      "default": 1.5,
      "min": 1.2,
      "max": 2,
      "step": 0.1,
      "description": "Volume > média"
    },
    "atrMultiplier": {
      "default": 2,
      "min": 1.5,
      "max": 3,
      "step": 0.5,
      "description": "ATR stop"
    }
  },
  "indicators": {
    "deltaVolume": {
      "type": "deltaVolume",
      "params": {
        "period": 14
      }
    },
    "volumeSma": {
      "type": "sma",
      "params": {
        "period": 20,
        "source": "volume"
      }
    },
    "atr": {
      "type": "atr",
      "params": {
        "period": 14
      }
    }
  },
  "entry": {
    "long": {
      "operator": "AND",
      "conditions": [
        {
          "left": "deltaVolume.ratio",
          "op": ">",
          "right": "$imbalanceRatio"
        },
        {
          "left": "volume",
          "op": ">",
          "right": {
            "calc": "volumeSma * $volumeMultiplier"
          }
        },
        {
          "left": "close",
          "op": ">",
          "right": "open"
        }
      ]
    },
    "short": {
      "operator": "AND",
      "conditions": [
        {
          "left": "deltaVolume.ratio",
          "op": "<",
          "right": {
            "calc": "1 / $imbalanceRatio"
          }
        },
        {
          "left": "volume",
          "op": ">",
          "right": {
            "calc": "volumeSma * $volumeMultiplier"
          }
        },
        {
          "left": "close",
          "op": "<",
          "right": "open"
        }
      ]
    }
  },
  "exit": {
    "stopLoss": {
      "type": "swingHighLow",
      "buffer": 0.6,
      "indicator": "atr"
    },
    "takeProfit": {
      "type": "riskReward",
      "multiplier": 2
    },
    "trailingStop": {
      "enabled": true,
      "type": "atr",
      "initialMultiplier": 2,
      "trailMultiplier": 2,
      "breakEvenAfterR": 1
    }
  },
  "confidence": {
    "base": 70,
    "bonuses": [
      {
        "condition": {
          "left": "volume",
          "op": ">",
          "right": {
            "calc": "volumeSma * 2"
          }
        },
        "bonus": 15,
        "description": "Very high volume"
      }
    ],
    "max": 90
  },
  "filters": {
    "minConfidence": 70,
    "minRiskReward": 1
  }
}
