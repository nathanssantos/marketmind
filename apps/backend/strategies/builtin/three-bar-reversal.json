{
  "id": "three-bar-reversal",
  "name": "Three Bar Reversal",
  "version": "1.0.0",
  "description": "Padr\u00e3o de 3 candles para revers\u00e3o. Entry ap\u00f3s padr\u00e3o de exaust\u00e3o de tend\u00eancia com confirma\u00e7\u00e3o na terceira candle.",
  "author": "MarketMind",
  "tags": [
    "reversal",
    "candlestick",
    "pattern",
    "price-action"
  ],
  "source": "Price Action Classic",
  "status": "active",
  "optimizedParams": {
    "maxPositionSize": 70,
    "maxConcurrentPositions": 2,
    "maxTotalExposure": 80,
    "useAlgorithmicLevels": true,
    "useTrailingStop": false,
    "onlyWithTrend": false,
    "minConfidence": 70,
    "commission": 0.001
  },
  "recommendedTimeframes": {
    "primary": "4h",
    "secondary": [
      "1h",
      "1d"
    ],
    "avoid": [
      "1m",
      "5m"
    ],
    "notes": "Three bar reversal on 4h"
  },
  "parameters": {
    "atrMultiplier": {
      "default": 2,
      "min": 1.5,
      "max": 3,
      "step": 0.5,
      "description": "ATR para stop"
    }
  },
  "indicators": {
    "atr": {
      "type": "atr",
      "params": {
        "period": 14
      }
    }
  },
  "entry": {
    "long": {
      "operator": "AND",
      "conditions": [
        {
          "left": "close[2]",
          "op": "<",
          "right": "open[2]"
        },
        {
          "left": "close[1]",
          "op": "<",
          "right": "open[1]"
        },
        {
          "left": "close",
          "op": ">",
          "right": "open"
        },
        {
          "left": "close",
          "op": ">",
          "right": "high[1]"
        }
      ]
    },
    "short": {
      "operator": "AND",
      "conditions": [
        {
          "left": "close[2]",
          "op": ">",
          "right": "open[2]"
        },
        {
          "left": "close[1]",
          "op": ">",
          "right": "open[1]"
        },
        {
          "left": "close",
          "op": "<",
          "right": "open"
        },
        {
          "left": "close",
          "op": "<",
          "right": "low[1]"
        }
      ]
    }
  },
  "exit": {
    "stopLoss": {
      "type": "swingHighLow",
      "lookback": 3,
      "buffer": 0.6,
      "indicator": "atr"
    },
    "takeProfit": {
      "type": "riskReward",
      "multiplier": 2
    },
    "trailingStop": {
      "enabled": true,
      "type": "atr",
      "initialMultiplier": 2,
      "trailMultiplier": 1.5,
      "breakEvenAfterR": 1
    }
  },
  "confidence": {
    "base": 70,
    "bonuses": [
      {
        "condition": {
          "left": "volume",
          "op": ">",
          "right": "volume.sma20"
        },
        "bonus": 10,
        "description": "Volume confirms reversal"
      }
    ],
    "max": 85
  },
  "filters": {
    "minConfidence": 70,
    "minRiskReward": 1.5
  }
}