{
  "id": "divergence-rsi-macd",
  "name": "Divergence (RSI + MACD)",
  "version": "1.0.0",
  "description": "Detects bullish/bearish divergences using RSI and MACD. Price makes new low but RSI/MACD doesn't confirm = bullish divergence. Opposite for bearish. Classic reversal signal.",
  "author": "MarketMind",
  "tags": ["divergence", "rsi", "macd", "reversal"],

  "status": "experimental",
  "optimizedParams": {
    "maxPositionSize": 40,
    "useAlgorithmicLevels": true,
    "onlyWithTrend": false,
    "minConfidence": 75,
    "commission": 0.001
  },
  "recommendedTimeframes": {
    "primary": "4h",
    "secondary": ["1h", "1d"],
    "avoid": ["1m", "5m", "15m"],
    "notes": "Best on 4h-daily for reliable divergences"
  },

  "parameters": {
    "rsiPeriod": { "default": 14, "min": 7, "max": 21, "step": 1, "description": "RSI period" },
    "macdFast": { "default": 12, "min": 8, "max": 16, "step": 1, "description": "MACD fast period" },
    "macdSlow": { "default": 26, "min": 20, "max": 32, "step": 1, "description": "MACD slow period" },
    "macdSignal": { "default": 9, "min": 5, "max": 12, "step": 1, "description": "MACD signal period" },
    "divergenceLookback": { "default": 20, "min": 10, "max": 50, "step": 5, "description": "Lookback for divergence detection" },
    "targetMultiplier": { "default": 2.0, "min": 1.5, "max": 3.0, "step": 0.5, "description": "Risk:Reward target" },
    "atrPeriod": { "default": 14, "min": 7, "max": 21, "step": 1, "description": "ATR for stop calculation" }
  },

  "indicators": {
    "rsi": {
      "type": "rsi",
      "params": { "period": "$rsiPeriod" }
    },
    "macd": {
      "type": "macd",
      "params": { "fastPeriod": "$macdFast", "slowPeriod": "$macdSlow", "signalPeriod": "$macdSignal" }
    },
    "atr": {
      "type": "atr",
      "params": { "period": "$atrPeriod" }
    }
  },

  "entry": {
    "long": {
      "operator": "AND",
      "conditions": [
        { "left": "low", "op": "<", "right": "low.prev20" },
        { "left": "rsi", "op": ">", "right": "30" },
        { "left": "rsi", "op": ">", "right": "rsi.prev20" }
      ]
    },
    "short": {
      "operator": "AND",
      "conditions": [
        { "left": "high", "op": ">", "right": "high.prev20" },
        { "left": "rsi", "op": "<", "right": "70" },
        { "left": "rsi", "op": "<", "right": "rsi.prev20" }
      ]
    }
  },

  "exit": {
    "stopLoss": {
      "type": "atr",
      "multiplier": 1.5,
      "indicator": "atr"
    },
    "takeProfit": {
      "type": "riskReward",
      "multiplier": "$targetMultiplier"
    }
  },

  "confidence": {
    "base": 70,
    "bonuses": [
      { "condition": { "left": "rsi", "op": "<", "right": 30 }, "bonus": 10, "description": "RSI oversold (bullish)" },
      { "condition": { "left": "rsi", "op": ">", "right": 70 }, "bonus": 10, "description": "RSI overbought (bearish)" },
      { "condition": { "left": "volume", "op": ">", "right": "volume.sma20" }, "bonus": 5, "description": "Volume confirmation" }
    ],
    "max": 95
  },

  "filters": {
    "minConfidence": 75,
    "minRiskReward": 2.0
  }
}
