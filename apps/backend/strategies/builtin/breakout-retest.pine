// @id breakout-retest
// @name Breakout Retest
// @version 1.0.0
// @description Breakout of key support/resistance level followed by successful retest. Entry after price breaks level, retests it as new support/resistance, and continues in breakout direction.
// @author Classic Technical Analysis
// @tags breakout,retest,support-resistance,trend-continuation
// @strategyType TREND_FOLLOWING
// @momentumType BREAKOUT
// @param lookbackPeriod Period to identify support/resistance
// @param emaPeriod EMA period for trend confirmation
// @param volumeMultiplier Volume multiplier for breakout confirmation
// @param retestTolerance Tolerance % for valid retest
// @param atrPeriod ATR period for stop calculation

//@version=5
indicator('Breakout Retest', overlay=true)

lookbackPeriod = input.int(30, 'lookbackPeriod', minval=15, maxval=60, step=5)
emaPeriod = input.int(20, 'emaPeriod', minval=10, maxval=50, step=5)
volumeMultiplier = input.float(1.4, 'volumeMultiplier', minval=1, maxval=2, step=0.1)
retestTolerance = input.float(0.5, 'retestTolerance', minval=0.2, maxval=1, step=0.1)
atrPeriod = input.int(14, 'atrPeriod', minval=7, maxval=21, step=1)

ema = ta.ema(close, emaPeriod)
atr = ta.atr(atrPeriod)
ema200 = ta.ema(close, 200)
atrVal = atr

volSma20 = ta.sma(volume, 20)

longEntry = (close > high[2] and low[1] <= high[2] and close > ema)
shortEntry = (close < low[2] and high[1] >= low[2] and close < ema)

confBase = 65
confBonus0 = volume > ta.sma(volume, 20) ? 15 : 0
confBonus1 = close > ema200 ? 8 : 0
confBonus2 = close < ema200 ? 8 : 0
confValue = math.min(confBase + confBonus0 + confBonus1 + confBonus2, 95)

exitLong = false
exitShort = false

sig = longEntry ? 1 : shortEntry ? -1 : 0
sl = longEntry ? close - atrVal * 0.6 : shortEntry ? close + atrVal * 0.6 : na
tp = longEntry ? close + math.abs(close - (close - atrVal * 0.6)) * 2.5 : shortEntry ? close - math.abs((close + atrVal * 0.6) - close) * 2.5 : na
conf = longEntry or shortEntry ? confValue : 0
exitSig = exitLong ? 1 : exitShort ? -1 : 0

plot(sig, 'signal', display=display.none)
plot(sl, 'stopLoss', display=display.none)
plot(tp, 'takeProfit', display=display.none)
plot(conf, 'confidence', display=display.none)
plot(exitSig, 'exitSignal', display=display.none)
