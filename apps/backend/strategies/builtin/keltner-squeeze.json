{
  "enabled": true,
  "id": "keltner-squeeze",
  "name": "Keltner Squeeze Breakout",
  "version": "1.0.0",
  "description": "Volatility squeeze strategy. Entry when Bollinger Bands are inside Keltner Channel (low volatility) and price breaks out. High probability breakout setup.",
  "author": "MarketMind",
  "tags": [
    "breakout",
    "squeeze",
    "keltner",
    "bollinger",
    "volatility"
  ],
  "status": "active",
  "backtestSummary": {
    "profitFactor": 0.41,
    "winRate": 30.77,
    "totalTrades": 13,
    "netPnlPercent": -12.67,
    "testedAt": "2025-12-07",
    "testedTimeframe": "4h",
    "testedSymbol": "BTCUSDT"
  },
  "recommendedTimeframes": {
    "primary": "4h",
    "secondary": [
      "1h",
      "1d"
    ],
    "avoid": [
      "1m",
      "5m"
    ],
    "notes": "Squeeze breakout works best on 4H for volatility detection"
  },
  "parameters": {
    "keltnerEmaPeriod": {
      "default": 20,
      "min": 15,
      "max": 30,
      "step": 5,
      "description": "Keltner EMA period"
    },
    "keltnerAtrPeriod": {
      "default": 10,
      "min": 5,
      "max": 20,
      "step": 5,
      "description": "Keltner ATR period"
    },
    "keltnerMultiplier": {
      "default": 1.5,
      "min": 1,
      "max": 2.5,
      "step": 0.5,
      "description": "Keltner ATR multiplier"
    },
    "bbPeriod": {
      "default": 20,
      "min": 15,
      "max": 30,
      "step": 5,
      "description": "Bollinger Bands period"
    },
    "bbStdDev": {
      "default": 2,
      "min": 1.5,
      "max": 2.5,
      "step": 0.5,
      "description": "Bollinger Bands std deviation"
    },
    "atrMultiplier": {
      "default": 1.5,
      "min": 1,
      "max": 2.5,
      "step": 0.5,
      "description": "ATR multiplier for stop loss"
    },
    "rrMultiplier": {
      "default": 2.5,
      "min": 2,
      "max": 4,
      "step": 0.5,
      "description": "Risk-reward multiplier"
    }
  },
  "indicators": {
    "keltner": {
      "type": "keltner",
      "params": {
        "emaPeriod": "$keltnerEmaPeriod",
        "atrPeriod": "$keltnerAtrPeriod",
        "multiplier": "$keltnerMultiplier"
      }
    },
    "bb": {
      "type": "bollingerBands",
      "params": {
        "period": "$bbPeriod",
        "stdDev": "$bbStdDev"
      }
    },
    "atr": {
      "type": "atr",
      "params": {
        "period": 14
      }
    }
  },
  "entry": {
    "long": {
      "operator": "AND",
      "conditions": [
        {
          "left": "bb.upper",
          "op": "<",
          "right": "keltner.upper"
        },
        {
          "left": "bb.lower",
          "op": ">",
          "right": "keltner.lower"
        },
        {
          "left": "close",
          "op": ">",
          "right": "keltner.upper"
        }
      ]
    },
    "short": {
      "operator": "AND",
      "conditions": [
        {
          "left": "bb.upper",
          "op": "<",
          "right": "keltner.upper"
        },
        {
          "left": "bb.lower",
          "op": ">",
          "right": "keltner.lower"
        },
        {
          "left": "close",
          "op": "<",
          "right": "keltner.lower"
        }
      ]
    }
  },
  "exit": {
    "stopLoss": {
      "type": "swingHighLow",
      "buffer": 0.6,
      "indicator": "atr"
    },
    "takeProfit": {
      "type": "riskReward",
      "multiplier": "$rrMultiplier"
    },
    "trailingStop": {
      "enabled": true,
      "type": "atr",
      "initialMultiplier": 2,
      "trailMultiplier": 1.5,
      "breakEvenAfterR": 1
    }
  },
  "confidence": {
    "base": 70,
    "bonuses": [
      {
        "condition": {
          "left": "volume",
          "op": ">",
          "right": "volume.sma20"
        },
        "bonus": 10,
        "description": "Breakout volume confirmation"
      },
      {
        "condition": {
          "left": "atr",
          "op": ">",
          "right": 0
        },
        "bonus": 5,
        "description": "Volatility expansion"
      }
    ],
    "max": 90
  },
  "filters": {
    "minConfidence": 65,
    "minRiskReward": 2
  }
}
