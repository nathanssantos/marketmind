// @id ema9-21-rsi-confirmation
// @name EMA 9/21 RSI Confirmation
// @version 1.0.0
// @description Estratégia de day trading para crypto: EMA 9 cruza EMA 21 COM confirmação RSI acima de 50 (long) ou abaixo de 50 (short). Combina trend-following com momentum confirmation. Ideal para 15m-4h.
// @author MarketMind
// @tags trend-following,ema,rsi,crossover,confirmation,day-trading
// @strategyType TREND_FOLLOWING
// @momentumType ANY
// @param fastPeriod Período da EMA rápida
// @param slowPeriod Período da EMA lenta
// @param rsiPeriod Período do RSI
// @param rsiLongThreshold RSI mínimo para long
// @param rsiShortThreshold RSI máximo para short
// @param rsiOverbought RSI overbought (evitar long)
// @param atrMultiplier Multiplicador ATR para stop
// @param rrMultiplier Risk-reward ratio

//@version=5
indicator('EMA 9/21 RSI Confirmation', overlay=true)

fastPeriod = input.int(9, 'fastPeriod', minval=5, maxval=15, step=1)
slowPeriod = input.int(21, 'slowPeriod', minval=15, maxval=30, step=1)
rsiPeriod = input.int(14, 'rsiPeriod', minval=10, maxval=21, step=1)
rsiLongThreshold = input.int(50, 'rsiLongThreshold', minval=45, maxval=55, step=5)
rsiShortThreshold = input.int(50, 'rsiShortThreshold', minval=45, maxval=55, step=5)
rsiOverbought = input.int(70, 'rsiOverbought', minval=65, maxval=80, step=5)
atrMultiplier = input.float(1.5, 'atrMultiplier', minval=1, maxval=2.5, step=0.25)
rrMultiplier = input.float(2, 'rrMultiplier', minval=1.5, maxval=3, step=0.5)

emaFast = ta.ema(close, fastPeriod)
emaSlow = ta.ema(close, slowPeriod)
rsi = ta.rsi(close, rsiPeriod)
atr = ta.atr(14)
atrVal = atr

volSma20 = ta.sma(volume, 20)

longEntry = (ta.crossover(emaFast, emaSlow) and rsi > rsiLongThreshold and rsi < rsiOverbought)
shortEntry = (ta.crossunder(emaFast, emaSlow) and rsi < rsiShortThreshold)

confBase = 70
confBonus0 = volume > ta.sma(volume, 20) ? 10 : 0
confBonus1 = rsi > 55 ? 5 : 0
confBonus2 = rsi < 45 ? 5 : 0
confValue = math.min(confBase + confBonus0 + confBonus1 + confBonus2, 90)

exitLong = false
exitShort = false

sig = longEntry ? 1 : shortEntry ? -1 : 0
sl = longEntry ? close - atrVal * 0.6 : shortEntry ? close + atrVal * 0.6 : na
tp = longEntry ? close + math.abs(close - (close - atrVal * 0.6)) * rrMultiplier : shortEntry ? close - math.abs((close + atrVal * 0.6) - close) * rrMultiplier : na
conf = longEntry or shortEntry ? confValue : 0
exitSig = exitLong ? 1 : exitShort ? -1 : 0

plot(sig, 'signal', display=display.none)
plot(sl, 'stopLoss', display=display.none)
plot(tp, 'takeProfit', display=display.none)
plot(conf, 'confidence', display=display.none)
plot(exitSig, 'exitSignal', display=display.none)
