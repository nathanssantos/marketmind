{
  "id": "macd-divergence",
  "name": "MACD Signal Line Crossover",
  "version": "1.0.0",
  "description": "Long quando linha MACD cruza acima da linha de sinal. Short no cruzamento inverso. Estratégia clássica de momentum.",
  "author": "MarketMind",
  "tags": ["momentum", "macd", "crossover", "trend"],

  "status": "unprofitable",
  "optimizedParams": {
    "maxPositionSize": 50,
    "useAlgorithmicLevels": true,
    "onlyWithTrend": true,
    "minConfidence": 60,
    "commission": 0.1
  },
  "backtestSummary": {
    "profitFactor": 0.84,
    "winRate": 32.73,
    "totalTrades": 55,
    "netPnlPercent": -4.78,
    "testedAt": "2025-12-07",
    "testedTimeframe": "4h",
    "testedSymbol": "BTCUSDT"
  },
  "recommendedTimeframes": {
    "primary": "4h",
    "secondary": ["1h", "1d"],
    "avoid": ["1m", "5m"],
    "notes": "MACD crossover works best on 4H for momentum detection"
  },

  "parameters": {
    "fastPeriod": { "default": 12, "min": 8, "max": 16, "step": 1, "description": "Período da EMA rápida do MACD" },
    "slowPeriod": { "default": 26, "min": 20, "max": 32, "step": 1, "description": "Período da EMA lenta do MACD" },
    "signalPeriod": { "default": 9, "min": 5, "max": 12, "step": 1, "description": "Período da linha de sinal" },
    "atrMultiplier": { "default": 1.5, "min": 1, "max": 3, "step": 0.25, "description": "Multiplicador do ATR para stop loss" }
  },

  "indicators": {
    "macd": {
      "type": "macd",
      "params": {
        "fastPeriod": "$fastPeriod",
        "slowPeriod": "$slowPeriod",
        "signalPeriod": "$signalPeriod"
      }
    },
    "atr": {
      "type": "atr",
      "params": { "period": 14 }
    },
    "ema50": {
      "type": "ema",
      "params": { "period": 50 }
    }
  },

  "entry": {
    "long": {
      "operator": "AND",
      "conditions": [
        { "left": "macd.macd", "op": "crossover", "right": "macd.signal" },
        { "left": "macd.histogram", "op": ">", "right": 0 }
      ]
    },
    "short": {
      "operator": "AND",
      "conditions": [
        { "left": "macd.macd", "op": "crossunder", "right": "macd.signal" },
        { "left": "macd.histogram", "op": "<", "right": 0 }
      ]
    }
  },

  "exit": {
    "stopLoss": {
      "type": "atr",
      "multiplier": "$atrMultiplier",
      "indicator": "atr"
    },
    "takeProfit": {
      "type": "riskReward",
      "multiplier": 2
    }
  },

  "confidence": {
    "base": 60,
    "bonuses": [
      { "condition": { "left": "volume", "op": ">", "right": "volume.sma20" }, "bonus": 10, "description": "Volume acima da média" },
      { "condition": { "left": "close", "op": ">", "right": "ema50" }, "bonus": 10, "description": "Tendência de alta (LONG)" },
      { "condition": { "left": "close", "op": "<", "right": "ema50" }, "bonus": 10, "description": "Tendência de baixa (SHORT)" }
    ],
    "max": 90
  },

  "filters": {
    "minConfidence": 60,
    "minRiskReward": 1.5
  }
}
