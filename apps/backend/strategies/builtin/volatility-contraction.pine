// @id volatility-contraction
// @name Volatility Contraction
// @version 1.0.0
// @description Entry após contração de volatilidade (squeeze). ATR/BB contraction precede expansão. Entry no início da expansão.
// @author MarketMind
// @tags volatility,squeeze,contraction,expansion
// @strategyType ANY
// @momentumType ANY
// @param bbPeriod BB período
// @param keltnerPeriod Keltner período
// @param keltnerMult Keltner multiplicador
// @param atrMultiplier ATR stop

//@version=5
indicator('Volatility Contraction', overlay=true)

bbPeriod = input.int(20, 'bbPeriod', minval=15, maxval=25, step=5)
keltnerPeriod = input.int(20, 'keltnerPeriod', minval=15, maxval=25, step=5)
keltnerMult = input.float(1.5, 'keltnerMult', minval=1, maxval=2, step=0.25)
atrMultiplier = input.float(2, 'atrMultiplier', minval=1.5, maxval=3, step=0.5)

[bb_middle, bb_upper, bb_lower] = ta.bb(close, bbPeriod, 2)
bb_bandwidth = (bb_upper - bb_lower) / bb_middle
[keltner_middle, keltner_upper, keltner_lower] = ta.kc(close, keltnerPeriod, keltnerMult)
momentum = ta.roc(close, 12)
atr = ta.atr(14)
atrVal = atr

volSma20 = ta.sma(volume, 20)

longEntry = (bb_lower[1] > keltner_lower[1] and bb_lower < keltner_lower and momentum > 0)
shortEntry = (bb_upper[1] < keltner_upper[1] and bb_upper > keltner_upper and momentum < 0)

confBase = 70
confBonus0 = volume > ta.sma(volume, 20) ? 15 : 0
confValue = math.min(confBase + confBonus0, 90)

exitLong = false
exitShort = false

sig = longEntry ? 1 : shortEntry ? -1 : 0
sl = longEntry ? close - atrVal * 0.6 : shortEntry ? close + atrVal * 0.6 : na
tp = longEntry ? close + math.abs(close - (close - atrVal * 0.6)) * 2.5 : shortEntry ? close - math.abs((close + atrVal * 0.6) - close) * 2.5 : na
conf = longEntry or shortEntry ? confValue : 0
exitSig = exitLong ? 1 : exitShort ? -1 : 0

plot(sig, 'signal', display=display.none)
plot(sl, 'stopLoss', display=display.none)
plot(tp, 'takeProfit', display=display.none)
plot(conf, 'confidence', display=display.none)
plot(exitSig, 'exitSignal', display=display.none)
