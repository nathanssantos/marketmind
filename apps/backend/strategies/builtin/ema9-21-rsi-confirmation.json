{
  "id": "ema9-21-rsi-confirmation",
  "name": "EMA 9/21 RSI Confirmation",
  "version": "1.0.0",
  "description": "Estrat\u00e9gia de day trading para crypto: EMA 9 cruza EMA 21 COM confirma\u00e7\u00e3o RSI acima de 50 (long) ou abaixo de 50 (short). Combina trend-following com momentum confirmation. Ideal para 15m-4h.",
  "author": "MarketMind",
  "tags": [
    "trend-following",
    "ema",
    "rsi",
    "crossover",
    "confirmation",
    "day-trading"
  ],
  "source": "TradingView - Day Trading Strategy Using EMA Crossovers + RSI for Crypto",
  "status": "active",
  "optimizedParams": {
    "maxPositionSize": 50,
    "maxConcurrentPositions": 2,
    "maxTotalExposure": 80,
    "useAlgorithmicLevels": true,
    "useTrailingStop": true,
    "trailingATRMultiplier": 2,
    "breakEvenAfterR": 1,
    "onlyWithTrend": false,
    "minConfidence": 70,
    "commission": 0.001
  },
  "backtestSummary": {
    "notes": "Strategy designed for trending markets, avoid choppy conditions",
    "riskRewardRatio": "1.5:1 to 2:1",
    "source": "TradingView Community"
  },
  "recommendedTimeframes": {
    "primary": "15m",
    "secondary": [
      "5m",
      "1h",
      "4h"
    ],
    "avoid": [
      "1m",
      "1d"
    ],
    "notes": "Best for intraday trading in trending markets"
  },
  "parameters": {
    "fastPeriod": {
      "default": 9,
      "min": 5,
      "max": 15,
      "step": 1,
      "description": "Per\u00edodo da EMA r\u00e1pida"
    },
    "slowPeriod": {
      "default": 21,
      "min": 15,
      "max": 30,
      "step": 1,
      "description": "Per\u00edodo da EMA lenta"
    },
    "rsiPeriod": {
      "default": 14,
      "min": 10,
      "max": 21,
      "step": 1,
      "description": "Per\u00edodo do RSI"
    },
    "rsiLongThreshold": {
      "default": 50,
      "min": 45,
      "max": 55,
      "step": 5,
      "description": "RSI m\u00ednimo para long"
    },
    "rsiShortThreshold": {
      "default": 50,
      "min": 45,
      "max": 55,
      "step": 5,
      "description": "RSI m\u00e1ximo para short"
    },
    "rsiOverbought": {
      "default": 70,
      "min": 65,
      "max": 80,
      "step": 5,
      "description": "RSI overbought (evitar long)"
    },
    "atrMultiplier": {
      "default": 1.5,
      "min": 1,
      "max": 2.5,
      "step": 0.25,
      "description": "Multiplicador ATR para stop"
    },
    "rrMultiplier": {
      "default": 2,
      "min": 1.5,
      "max": 3,
      "step": 0.5,
      "description": "Risk-reward ratio"
    }
  },
  "indicators": {
    "emaFast": {
      "type": "ema",
      "params": {
        "period": "$fastPeriod"
      }
    },
    "emaSlow": {
      "type": "ema",
      "params": {
        "period": "$slowPeriod"
      }
    },
    "rsi": {
      "type": "rsi",
      "params": {
        "period": "$rsiPeriod"
      }
    },
    "atr": {
      "type": "atr",
      "params": {
        "period": 14
      }
    }
  },
  "entry": {
    "long": {
      "operator": "AND",
      "conditions": [
        {
          "left": "emaFast",
          "op": "crossover",
          "right": "emaSlow"
        },
        {
          "left": "rsi",
          "op": ">",
          "right": "$rsiLongThreshold"
        },
        {
          "left": "rsi",
          "op": "<",
          "right": "$rsiOverbought"
        }
      ]
    },
    "short": {
      "operator": "AND",
      "conditions": [
        {
          "left": "emaFast",
          "op": "crossunder",
          "right": "emaSlow"
        },
        {
          "left": "rsi",
          "op": "<",
          "right": "$rsiShortThreshold"
        }
      ]
    }
  },
  "exit": {
    "stopLoss": {
      "type": "swingHighLow",
      "buffer": 0.6,
      "indicator": "atr"
    },
    "takeProfit": {
      "type": "riskReward",
      "multiplier": "$rrMultiplier"
    },
    "trailingStop": {
      "enabled": true,
      "type": "atr",
      "initialMultiplier": 1.5,
      "trailMultiplier": 2,
      "breakEvenAfterR": 1
    }
  },
  "confidence": {
    "base": 70,
    "bonuses": [
      {
        "condition": {
          "left": "volume",
          "op": ">",
          "right": "volume.sma20"
        },
        "bonus": 10,
        "description": "Volume confirmando crossover"
      },
      {
        "condition": {
          "left": "rsi",
          "op": ">",
          "right": 55,
          "for": "long"
        },
        "bonus": 5,
        "description": "RSI momentum forte"
      },
      {
        "condition": {
          "left": "rsi",
          "op": "<",
          "right": 45,
          "for": "short"
        },
        "bonus": 5,
        "description": "RSI momentum forte bearish"
      }
    ],
    "max": 90
  },
  "filters": {
    "minConfidence": 70,
    "minRiskReward": 1.5
  }
}