// @id triple-confirmation-reversal
// @name Triple Confirmation Mean Reversion
// @version 1.0.0
// @description Mean reversion strategy (LONG ONLY) requiring RSI + MFI dual confirmation. Relaxed thresholds for more signals.
// @author MarketMind
// @tags mean-reversion,rsi,mfi,bollinger,reversal
// @strategyType MEAN_REVERSION
// @momentumType REVERSAL
// @param rsiPeriod RSI period
// @param rsiOversold RSI oversold level (more relaxed)
// @param rsiOverbought RSI overbought level (relaxed)
// @param mfiPeriod MFI period
// @param mfiOversold MFI oversold level (more relaxed)
// @param mfiOverbought MFI overbought level (relaxed)
// @param bbPeriod Bollinger Bands period
// @param atrMultiplier ATR multiplier for stop loss
// @param rrMultiplier Risk-reward multiplier

//@version=5
indicator('Triple Confirmation Mean Reversion', overlay=true)

rsiPeriod = input.int(14, 'rsiPeriod', minval=10, maxval=20, step=2)
rsiOversold = input.int(40, 'rsiOversold', minval=30, maxval=50, step=5)
rsiOverbought = input.int(65, 'rsiOverbought', minval=60, maxval=75, step=5)
mfiPeriod = input.int(14, 'mfiPeriod', minval=10, maxval=20, step=2)
mfiOversold = input.int(40, 'mfiOversold', minval=30, maxval=50, step=5)
mfiOverbought = input.int(70, 'mfiOverbought', minval=60, maxval=80, step=5)
bbPeriod = input.int(20, 'bbPeriod', minval=15, maxval=30, step=5)
atrMultiplier = input.float(1.5, 'atrMultiplier', minval=1, maxval=2, step=0.25)
rrMultiplier = input.float(2, 'rrMultiplier', minval=1.5, maxval=3, step=0.5)

rsi = ta.rsi(close, rsiPeriod)
mfi = ta.mfi(hlc3, mfiPeriod)
[bb_middle, bb_upper, bb_lower] = ta.bb(close, bbPeriod, 2)
bb_bandwidth = (bb_upper - bb_lower) / bb_middle
atr = ta.atr(14)
atrVal = atr

volSma20 = ta.sma(volume, 20)

longEntry = (rsi < rsiOversold and mfi < mfiOversold)
shortEntry = (rsi > rsiOverbought and mfi > mfiOverbought)

confBase = 75
confBonus0 = volume > ta.sma(volume, 20) ? 10 : 0
confBonus1 = rsi < 25 ? 5 : 0
confValue = math.min(confBase + confBonus0 + confBonus1, 95)

exitLong = false
exitShort = false

sig = longEntry ? 1 : shortEntry ? -1 : 0
sl = longEntry ? close - atrVal * 0.6 : shortEntry ? close + atrVal * 0.6 : na
tp = longEntry ? close + math.abs(close - (close - atrVal * 0.6)) * rrMultiplier : shortEntry ? close - math.abs((close + atrVal * 0.6) - close) * rrMultiplier : na
conf = longEntry or shortEntry ? confValue : 0
exitSig = exitLong ? 1 : exitShort ? -1 : 0

plot(sig, 'signal', display=display.none)
plot(sl, 'stopLoss', display=display.none)
plot(tp, 'takeProfit', display=display.none)
plot(conf, 'confidence', display=display.none)
plot(exitSig, 'exitSignal', display=display.none)
