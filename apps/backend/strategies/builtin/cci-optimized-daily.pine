// @id cci-optimized-daily
// @name CCI Optimized Daily
// @version 1.0.0
// @description Optimized CCI strategy (LONG ONLY) using period 50 (not standard 20). Research: 1108% return over 20 years on S&P 500. WARNING: Best for indices, may underperform on crypto.
// @author MarketMind
// @tags trend-following,cci,optimized,daily,indices-best
// @strategyType TREND_FOLLOWING
// @momentumType ANY
// @param cciPeriod CCI period (50 is optimal, not 20!)
// @param cciEntry CCI entry threshold (long) - relaxed for crypto
// @param cciExit CCI exit threshold
// @param atrPeriod ATR period
// @param slMultiplier Stop loss ATR multiplier
// @param tpMultiplier Take profit ATR multiplier

//@version=5
indicator('CCI Optimized Daily', overlay=true)

cciPeriod = input.int(50, 'cciPeriod', minval=30, maxval=80, step=10)
cciEntry = input.int(-50, 'cciEntry', minval=-150, maxval=0, step=25)
cciExit = input.int(100, 'cciExit', minval=50, maxval=150, step=25)
atrPeriod = input.int(14, 'atrPeriod', minval=10, maxval=20, step=2)
slMultiplier = input.float(2, 'slMultiplier', minval=1.5, maxval=3, step=0.5)
tpMultiplier = input.float(3, 'tpMultiplier', minval=2, maxval=5, step=0.5)

cci = ta.cci(cciPeriod)
atr = ta.atr(atrPeriod)
ema200 = ta.ema(close, 200)
atrVal = atr

volSma20 = ta.sma(volume, 20)

longEntry = (cci < cciEntry and close > ema200)
shortEntry = false

confBase = 65
confBonus0 = cci < -150 ? 10 : 0
confBonus1 = volume > ta.sma(volume, 20) ? 10 : 0
confValue = math.min(confBase + confBonus0 + confBonus1, 95)

exitLong = false
exitShort = false

sig = longEntry ? 1 : shortEntry ? -1 : 0
sl = longEntry ? close - atrVal * 0.6 : shortEntry ? close + atrVal * 0.6 : na
tp = longEntry ? close + math.abs(close - (close - atrVal * 0.6)) * tpMultiplier : shortEntry ? close - math.abs((close + atrVal * 0.6) - close) * tpMultiplier : na
conf = longEntry or shortEntry ? confValue : 0
exitSig = exitLong ? 1 : exitShort ? -1 : 0

plot(sig, 'signal', display=display.none)
plot(sl, 'stopLoss', display=display.none)
plot(tp, 'takeProfit', display=display.none)
plot(conf, 'confidence', display=display.none)
plot(exitSig, 'exitSignal', display=display.none)
