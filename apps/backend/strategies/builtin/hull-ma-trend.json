{
  "id": "hull-ma-trend",
  "name": "Hull MA Trend",
  "version": "1.0.0",
  "description": "Hull Moving Average trend following. HMA \u00e9 muito responsiva com menos lag que EMA. Entry quando HMA muda de dire\u00e7\u00e3o.",
  "author": "MarketMind",
  "tags": [
    "trend-following",
    "hull-ma",
    "momentum",
    "low-lag"
  ],
  "source": "Alan Hull - HMA Creator",
  "status": "active",
  "optimizedParams": {
    "maxPositionSize": 80,
    "maxConcurrentPositions": 1,
    "maxTotalExposure": 80,
    "useAlgorithmicLevels": true,
    "useTrailingStop": true,
    "trailingATRMultiplier": 2.5,
    "breakEvenAfterR": 1.5,
    "onlyWithTrend": false,
    "minConfidence": 65,
    "commission": 0.001
  },
  "recommendedTimeframes": {
    "primary": "4h",
    "secondary": [
      "1h",
      "1d"
    ],
    "avoid": [
      "1m",
      "5m"
    ],
    "notes": "HMA works well on 4h for crypto"
  },
  "parameters": {
    "hmaPeriod": {
      "default": 20,
      "min": 14,
      "max": 30,
      "step": 2,
      "description": "Per\u00edodo do HMA"
    },
    "atrMultiplier": {
      "default": 2,
      "min": 1.5,
      "max": 3,
      "step": 0.5,
      "description": "ATR para stop"
    }
  },
  "indicators": {
    "hma": {
      "type": "hma",
      "params": {
        "period": "$hmaPeriod"
      }
    },
    "atr": {
      "type": "atr",
      "params": {
        "period": 14
      }
    }
  },
  "entry": {
    "long": {
      "operator": "AND",
      "conditions": [
        {
          "left": "hma",
          "op": ">",
          "right": "hma.prev"
        },
        {
          "left": "hma.prev",
          "op": "<=",
          "right": "hma.prev2"
        }
      ]
    },
    "short": {
      "operator": "AND",
      "conditions": [
        {
          "left": "hma",
          "op": "<",
          "right": "hma.prev"
        },
        {
          "left": "hma.prev",
          "op": ">=",
          "right": "hma.prev2"
        }
      ]
    }
  },
  "exit": {
    "stopLoss": {
      "type": "swingHighLow",
      "lookback": 3,
      "buffer": 0.1,
      "indicator": "atr"
    },
    "takeProfit": {
      "type": "riskReward",
      "multiplier": 2.5
    },
    "trailingStop": {
      "enabled": true,
      "type": "atr",
      "initialMultiplier": 2,
      "trailMultiplier": 2.5,
      "breakEvenAfterR": 1.5
    },
    "conditions": {
      "long": {
        "operator": "OR",
        "conditions": [
          {
            "left": "hma",
            "op": "<",
            "right": "hma.prev"
          }
        ]
      },
      "short": {
        "operator": "OR",
        "conditions": [
          {
            "left": "hma",
            "op": ">",
            "right": "hma.prev"
          }
        ]
      }
    }
  },
  "confidence": {
    "base": 65,
    "bonuses": [
      {
        "condition": {
          "left": "volume",
          "op": ">",
          "right": "volume.sma20"
        },
        "bonus": 10,
        "description": "Volume confirms"
      }
    ],
    "max": 85
  },
  "filters": {
    "minConfidence": 65,
    "minRiskReward": 2
  }
}