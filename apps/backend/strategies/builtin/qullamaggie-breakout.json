{
  "id": "qullamaggie-breakout",
  "name": "Qullamaggie Breakout",
  "version": "1.0.0",
  "description": "Kristjan Kullamägi's continuation breakout setup. Entry on range expansion after orderly consolidation while price surfs EMA10/20. One of his 3 'timeless' setups that made him tens of millions.",
  "author": "Kristjan Kullamägi / MarketMind",
  "tags": [
    "qullamaggie",
    "breakout",
    "momentum",
    "swing-trading"
  ],
  "status": "active",
  "enabled": true,
  "group": "qullamaggie",
  "optimizedParams": {
    "maxPositionSize": 100,
    "useAlgorithmicLevels": true,
    "onlyWithTrend": true,
    "minConfidence": 65,
    "commission": 0.001,
    "maxConcurrentPositions": 2,
    "maxTotalExposure": 70,
    "trailingATRMultiplier": 2,
    "breakEvenAfterR": 1.5
  },
  "recommendedTimeframes": {
    "primary": "1d",
    "secondary": [
      "4h"
    ],
    "avoid": [
      "1m",
      "5m",
      "15m"
    ],
    "notes": "Best on daily charts for swing trades. Qullamaggie uses daily timeframe for most breakouts."
  },
  "parameters": {
    "ema10Period": {
      "default": 10,
      "min": 8,
      "max": 12,
      "step": 1,
      "description": "Fast EMA period (Qullamaggie uses 10)"
    },
    "ema20Period": {
      "default": 20,
      "min": 18,
      "max": 22,
      "step": 1,
      "description": "Slow EMA period (Qullamaggie uses 20)"
    },
    "ema50Period": {
      "default": 50,
      "min": 45,
      "max": 55,
      "step": 1,
      "description": "Trend EMA period for additional confirmation"
    },
    "atrPeriod": {
      "default": 14,
      "min": 7,
      "max": 21,
      "step": 1,
      "description": "ATR period for volatility measurement"
    },
    "consolidationLookback": {
      "default": 15,
      "min": 10,
      "max": 25,
      "step": 1,
      "description": "Bars to look back for consolidation range"
    },
    "atrStopMultiplier": {
      "default": 1.5,
      "min": 1,
      "max": 2.5,
      "step": 0.25,
      "description": "ATR multiplier for stop loss"
    },
    "volumeMultiplier": {
      "default": 1.2,
      "min": 1,
      "max": 2,
      "step": 0.1,
      "description": "Minimum volume as multiplier of 20-period average"
    }
  },
  "indicators": {
    "ema10": {
      "type": "ema",
      "params": {
        "period": "$ema10Period"
      }
    },
    "ema20": {
      "type": "ema",
      "params": {
        "period": "$ema20Period"
      }
    },
    "ema50": {
      "type": "ema",
      "params": {
        "period": "$ema50Period"
      }
    },
    "ema200": {
      "type": "ema",
      "params": {
        "period": 200
      }
    },
    "atr": {
      "type": "atr",
      "params": {
        "period": "$atrPeriod"
      }
    },
    "highestHigh": {
      "type": "highest",
      "params": {
        "period": "$consolidationLookback",
        "source": "high"
      }
    },
    "lowestLow": {
      "type": "lowest",
      "params": {
        "period": "$consolidationLookback",
        "source": "low"
      }
    }
  },
  "entry": {
    "long": {
      "operator": "AND",
      "conditions": [
        {
          "left": "close",
          "op": ">",
          "right": "ema10"
        },
        {
          "left": "close",
          "op": ">",
          "right": "ema20"
        },
        {
          "left": "ema10",
          "op": ">",
          "right": "ema20"
        },
        {
          "left": "ema10",
          "op": ">",
          "right": "ema10.prev"
        },
        {
          "left": "ema20",
          "op": ">",
          "right": "ema20.prev"
        },
        {
          "left": "close",
          "op": ">",
          "right": "highestHigh.prev"
        },
        {
          "left": "volume",
          "op": ">",
          "right": {
            "calc": "volume.sma20 * $volumeMultiplier"
          }
        }
      ]
    },
    "short": {
      "operator": "AND",
      "conditions": [
        {
          "left": "close",
          "op": "<",
          "right": "ema10"
        },
        {
          "left": "close",
          "op": "<",
          "right": "ema20"
        },
        {
          "left": "ema10",
          "op": "<",
          "right": "ema20"
        },
        {
          "left": "ema10",
          "op": "<",
          "right": "ema10.prev"
        },
        {
          "left": "ema20",
          "op": "<",
          "right": "ema20.prev"
        },
        {
          "left": "close",
          "op": "<",
          "right": "lowestLow.prev"
        },
        {
          "left": "volume",
          "op": ">",
          "right": {
            "calc": "volume.sma20 * $volumeMultiplier"
          }
        }
      ]
    }
  },
  "exit": {
    "stopLoss": {
      "type": "swingHighLow",
      "lookback": 10,
      "buffer": 0.5,
      "indicator": "atr"
    },
    "takeProfit": {
      "type": "riskReward",
      "multiplier": 3
    },
    "trailingStop": {
      "enabled": true,
      "type": "indicator",
      "indicator": "ema10",
      "initialMultiplier": 1.5,
      "trailMultiplier": 1,
      "breakEvenAfterR": 1
    }
  },
  "confidence": {
    "base": 55,
    "bonuses": [
      {
        "condition": {
          "left": "close",
          "op": ">",
          "right": "ema50"
        },
        "bonus": 10,
        "description": "Price above EMA50 (stronger trend)"
      },
      {
        "condition": {
          "left": "close",
          "op": ">",
          "right": "ema200"
        },
        "bonus": 10,
        "description": "Price above EMA200 (macro trend aligned)"
      },
      {
        "condition": {
          "left": "volume",
          "op": ">",
          "right": {
            "calc": "volume.sma20 * 1.5"
          }
        },
        "bonus": 10,
        "description": "Strong volume confirmation (1.5x average)"
      },
      {
        "condition": {
          "left": "ema10",
          "op": ">",
          "right": "ema50"
        },
        "bonus": 10,
        "description": "EMA10 > EMA50 (trend strength)"
      },
      {
        "condition": {
          "left": {
            "calc": "(high - low) / atr"
          },
          "op": ">",
          "right": 1.5
        },
        "bonus": 5,
        "description": "Range expansion (breakout bar)"
      }
    ],
    "max": 100
  },
  "filters": {
    "minConfidence": 60,
    "minRiskReward": 1.5,
    "trendFilter": {
      "enabled": true,
      "indicator": "ema",
      "period": 200,
      "allowCounterTrend": false
    }
  },
  "education": {
    "origin": "Kristjan Kullamägi (Qullamaggie) - '3 Timeless Setups'",
    "createdYear": 2015,
    "candlePattern": {
      "lookback": 3,
      "candles": [
        { "offset": -2, "role": "consolidation", "descriptionKey": "strategies.qullamBreakout.candleMinus2" },
        { "offset": -1, "role": "consolidation", "descriptionKey": "strategies.qullamBreakout.candleMinus1" },
        { "offset": 0, "role": "breakout", "descriptionKey": "strategies.qullamBreakout.candleTrigger" }
      ],
      "indicatorsToShow": ["ema10", "ema20", "ema50", "volume"]
    },
    "howItWorks": {
      "summaryKey": "strategies.qullamBreakout.summary",
      "entryKey": "strategies.qullamBreakout.entry",
      "exitKey": "strategies.qullamBreakout.exit"
    }
  }
}
