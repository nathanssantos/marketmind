import type { WsUserDataEvents } from 'binance';
import type { Mock } from 'vitest';
import { afterEach, beforeEach, describe, expect, it, vi } from 'vitest';
import { db } from '../../db';
import { createBinanceClient } from '../binance-client';
import { binanceUserStreamService } from '../binance-user-stream';

vi.mock('../../db');
vi.mock('../binance-client');
vi.mock('../websocket');

const MOCK_WALLET = {
  id: 1,
  userId: 1,
  name: 'Integration Test Wallet',
  exchange: 'binance',
  apiKey: 'test-key',
  apiSecret: 'test-secret',
  isTestnet: false,
  isPaperTrading: false,
  balance: 10000,
  createdAt: new Date(),
  updatedAt: new Date(),
};

const MOCK_KLINES = [
  {
    openTime: Date.now() - 300000,
    open: '50000',
    high: '50500',
    low: '49500',
    close: '50200',
    volume: '100',
    closeTime: Date.now() - 240000,
  },
  {
    openTime: Date.now() - 240000,
    open: '50200',
    high: '50800',
    low: '50000',
    close: '50600',
    volume: '150',
    closeTime: Date.now() - 180000,
  },
];

describe('Order Flow Integration', () => {
  let mockBinanceClient: any;
  let mockDbQuery: any;
  let mockDbInsert: any;
  let mockDbUpdate: any;

  beforeEach(() => {
    vi.clearAllMocks();

    mockBinanceClient = {
      futuresOrder: vi.fn()
        .mockResolvedValueOnce({ orderId: 111111, status: 'FILLED' })
        .mockResolvedValueOnce({ orderId: 222222, status: 'NEW' })
        .mockResolvedValueOnce({ orderId: 333333, status: 'NEW' }),
      futuresCancelOrder: vi.fn().mockResolvedValue({}),
      futuresKlines: vi.fn().mockResolvedValue(MOCK_KLINES),
      futuresAccountBalance: vi.fn().mockResolvedValue([
        { asset: 'USDT', balance: '10000' },
      ]),
    };

    (createBinanceClient as Mock).mockReturnValue(mockBinanceClient);

    mockDbQuery = {
      findMany: vi.fn().mockResolvedValue([]),
      findFirst: vi.fn().mockResolvedValue(null),
    };

    mockDbInsert = vi.fn().mockReturnValue({
      values: vi.fn().mockReturnValue({
        returning: vi.fn().mockResolvedValue([
          {
            id: 1,
            walletId: 1,
            symbol: 'BTCUSDT',
            side: 'LONG',
            entryPrice: 50600,
            quantity: 0.1,
            stopLoss: 49600,
            takeProfit: 52600,
            status: 'OPEN',
            entryOrderId: 111111,
            stopLossOrderId: 222222,
            takeProfitOrderId: 333333,
          },
        ]),
      }),
    });

    mockDbUpdate = vi.fn().mockReturnValue({
      set: vi.fn().mockReturnValue({
        where: vi.fn().mockReturnValue({
          returning: vi.fn().mockResolvedValue([
            {
              id: 1,
              status: 'CLOSED',
              exitPrice: 52600,
              realizedPnL: 200,
            },
          ]),
        }),
      }),
    });

    (db.query as any) = {
      wallets: mockDbQuery,
      tradeExecutions: mockDbQuery,
    };

    (db.insert as any) = mockDbInsert;
    (db.update as any) = mockDbUpdate;
  });

  afterEach(() => {
    vi.restoreAllMocks();
  });

  describe('Complete LONG Position Flow', () => {
    it('should create entry + SL + TP orders and save all orderIds', async () => {
      const result = await mockDbInsert()
        .values({})
        .returning();

      const execution = result[0];

      expect(execution.entryOrderId).toBe(111111);
      expect(execution.stopLossOrderId).toBe(222222);
      expect(execution.takeProfitOrderId).toBe(333333);
      expect(execution.status).toBe('OPEN');
    });

    it('should close position when TP fills and cancel SL', async () => {
      const openPosition = {
        id: 1,
        walletId: 1,
        symbol: 'BTCUSDT',
        side: 'LONG' as const,
        entryPrice: 50600,
        quantity: 0.1,
        stopLoss: 49600,
        takeProfit: 52600,
        status: 'OPEN' as const,
        entryOrderId: 111111,
        stopLossOrderId: 222222,
        takeProfitOrderId: 333333,
      };

      mockDbQuery.findFirst.mockResolvedValue(openPosition);

      const executionReport: WsUserDataEvents['executionReport'] = {
        eventType: 'executionReport',
        eventTime: Date.now(),
        symbol: 'BTCUSDT',
        orderId: 333333,
        orderStatus: 'FILLED',
        orderType: 'LIMIT',
        side: 'SELL',
        executionType: 'TRADE',
        price: '52600',
        quantity: '0.1',
        lastFilledPrice: '52600',
        totalFilledQuantity: '0.1',
        commission: '0',
        commissionAsset: 'USDT',
        transactionTime: Date.now(),
      };

      const service = binanceUserStreamService as any;
      await service.handleOrderUpdate(MOCK_WALLET.id, executionReport);

      expect(mockBinanceClient.futuresCancelOrder).toHaveBeenCalledWith({
        symbol: 'BTCUSDT',
        orderId: 222222,
      });

      expect(mockDbUpdate).toHaveBeenCalled();
    });

    it('should calculate correct PnL when TP fills on LONG', async () => {
      const openPosition = {
        id: 1,
        walletId: 1,
        symbol: 'BTCUSDT',
        side: 'LONG' as const,
        entryPrice: 50600,
        quantity: 0.1,
        stopLoss: 49600,
        takeProfit: 52600,
        status: 'OPEN' as const,
        entryOrderId: 111111,
        stopLossOrderId: 222222,
        takeProfitOrderId: 333333,
      };

      mockDbQuery.findFirst.mockResolvedValue(openPosition);

      const executionReport: WsUserDataEvents['executionReport'] = {
        eventType: 'executionReport',
        eventTime: Date.now(),
        symbol: 'BTCUSDT',
        orderId: 333333,
        orderStatus: 'FILLED',
        orderType: 'LIMIT',
        side: 'SELL',
        executionType: 'TRADE',
        price: '52600',
        quantity: '0.1',
        lastFilledPrice: '52600',
        totalFilledQuantity: '0.1',
        commission: '0',
        commissionAsset: 'USDT',
        transactionTime: Date.now(),
      };

      const service = binanceUserStreamService as any;
      await service.handleOrderUpdate(MOCK_WALLET.id, executionReport);

      expect(mockDbUpdate).toHaveBeenCalled();
      expect(mockBinanceClient.futuresCancelOrder).toHaveBeenCalled();
    });

    it('should close position when SL fills and cancel TP', async () => {
      const openPosition = {
        id: 1,
        walletId: 1,
        symbol: 'BTCUSDT',
        side: 'LONG' as const,
        entryPrice: 50600,
        quantity: 0.1,
        stopLoss: 49600,
        takeProfit: 52600,
        status: 'OPEN' as const,
        entryOrderId: 111111,
        stopLossOrderId: 222222,
        takeProfitOrderId: 333333,
      };

      mockDbQuery.findFirst.mockResolvedValue(openPosition);

      const executionReport: WsUserDataEvents['executionReport'] = {
        eventType: 'executionReport',
        eventTime: Date.now(),
        symbol: 'BTCUSDT',
        orderId: 222222,
        orderStatus: 'FILLED',
        orderType: 'STOP_MARKET',
        side: 'SELL',
        executionType: 'TRADE',
        price: '49600',
        quantity: '0.1',
        lastFilledPrice: '49600',
        totalFilledQuantity: '0.1',
        commission: '0',
        commissionAsset: 'USDT',
        transactionTime: Date.now(),
      };

      const service = binanceUserStreamService as any;
      await service.handleOrderUpdate(MOCK_WALLET.id, executionReport);

      expect(mockBinanceClient.futuresCancelOrder).toHaveBeenCalledWith({
        symbol: 'BTCUSDT',
        orderId: 333333,
      });
    });

    it('should calculate correct negative PnL when SL fills on LONG', async () => {
      const openPosition = {
        id: 1,
        walletId: 1,
        symbol: 'BTCUSDT',
        side: 'LONG' as const,
        entryPrice: 50600,
        quantity: 0.1,
        stopLoss: 49600,
        takeProfit: 52600,
        status: 'OPEN' as const,
        entryOrderId: 111111,
        stopLossOrderId: 222222,
        takeProfitOrderId: 333333,
      };

      mockDbQuery.findFirst.mockResolvedValue(openPosition);

      const executionReport: WsUserDataEvents['executionReport'] = {
        eventType: 'executionReport',
        eventTime: Date.now(),
        symbol: 'BTCUSDT',
        orderId: 222222,
        orderStatus: 'FILLED',
        orderType: 'STOP_MARKET',
        side: 'SELL',
        executionType: 'TRADE',
        price: '49600',
        quantity: '0.1',
        lastFilledPrice: '49600',
        totalFilledQuantity: '0.1',
        commission: '0',
        commissionAsset: 'USDT',
        transactionTime: Date.now(),
      };

      const service = binanceUserStreamService as any;
      await service.handleOrderUpdate(MOCK_WALLET.id, executionReport);

      expect(mockDbUpdate).toHaveBeenCalled();
      expect(mockBinanceClient.futuresCancelOrder).toHaveBeenCalled();
    });
  });

  describe('Complete SHORT Position Flow', () => {
    it('should create entry + SL + TP orders for SHORT', async () => {
      mockBinanceClient.futuresOrder
        .mockResolvedValueOnce({ orderId: 444444, status: 'FILLED' })
        .mockResolvedValueOnce({ orderId: 555555, status: 'NEW' })
        .mockResolvedValueOnce({ orderId: 666666, status: 'NEW' });

      mockDbInsert = vi.fn().mockReturnValue({
        values: vi.fn().mockReturnValue({
          returning: vi.fn().mockResolvedValue([
            {
              id: 2,
              walletId: 1,
              symbol: 'ETHUSDT',
              side: 'SHORT',
              entryPrice: 3000,
              quantity: 1,
              stopLoss: 3100,
              takeProfit: 2900,
              status: 'OPEN',
              entryOrderId: 444444,
              stopLossOrderId: 555555,
              takeProfitOrderId: 666666,
            },
          ]),
        }),
      });

      const result = await mockDbInsert()
        .values({})
        .returning();

      const execution = result[0];

      expect(execution.entryOrderId).toBe(444444);
      expect(execution.stopLossOrderId).toBe(555555);
      expect(execution.takeProfitOrderId).toBe(666666);
      expect(execution.side).toBe('SHORT');
    });

    it('should close SHORT position when TP fills and cancel SL', async () => {
      const openPosition = {
        id: 2,
        walletId: 1,
        symbol: 'ETHUSDT',
        side: 'SHORT' as const,
        entryPrice: 3000,
        quantity: 1,
        stopLoss: 3100,
        takeProfit: 2900,
        status: 'OPEN' as const,
        entryOrderId: 444444,
        stopLossOrderId: 555555,
        takeProfitOrderId: 666666,
      };

      mockDbQuery.findFirst.mockResolvedValue(openPosition);

      const executionReport: WsUserDataEvents['executionReport'] = {
        eventType: 'executionReport',
        eventTime: Date.now(),
        symbol: 'ETHUSDT',
        orderId: 666666,
        orderStatus: 'FILLED',
        orderType: 'LIMIT',
        side: 'BUY',
        executionType: 'TRADE',
        price: '2900',
        quantity: '1',
        lastFilledPrice: '2900',
        totalFilledQuantity: '1',
        commission: '0',
        commissionAsset: 'USDT',
        transactionTime: Date.now(),
      };

      const service = binanceUserStreamService as any;
      await service.handleOrderUpdate(MOCK_WALLET.id, executionReport);

      expect(mockBinanceClient.futuresCancelOrder).toHaveBeenCalledWith({
        symbol: 'ETHUSDT',
        orderId: 555555,
      });
    });

    it('should calculate correct PnL when TP fills on SHORT', async () => {
      const openPosition = {
        id: 2,
        walletId: 1,
        symbol: 'ETHUSDT',
        side: 'SHORT' as const,
        entryPrice: 3000,
        quantity: 1,
        stopLoss: 3100,
        takeProfit: 2900,
        status: 'OPEN' as const,
        entryOrderId: 444444,
        stopLossOrderId: 555555,
        takeProfitOrderId: 666666,
      };

      mockDbQuery.findFirst.mockResolvedValue(openPosition);

      const executionReport: WsUserDataEvents['executionReport'] = {
        eventType: 'executionReport',
        eventTime: Date.now(),
        symbol: 'ETHUSDT',
        orderId: 666666,
        orderStatus: 'FILLED',
        orderType: 'LIMIT',
        side: 'BUY',
        executionType: 'TRADE',
        price: '2900',
        quantity: '1',
        lastFilledPrice: '2900',
        totalFilledQuantity: '1',
        commission: '0',
        commissionAsset: 'USDT',
        transactionTime: Date.now(),
      };

      const service = binanceUserStreamService as any;
      await service.handleOrderUpdate(MOCK_WALLET.id, executionReport);

      expect(mockDbUpdate).toHaveBeenCalled();
      expect(mockBinanceClient.futuresCancelOrder).toHaveBeenCalled();
    });

    it('should calculate correct negative PnL when SL fills on SHORT', async () => {
      const openPosition = {
        id: 2,
        walletId: 1,
        symbol: 'ETHUSDT',
        side: 'SHORT' as const,
        entryPrice: 3000,
        quantity: 1,
        stopLoss: 3100,
        takeProfit: 2900,
        status: 'OPEN' as const,
        entryOrderId: 444444,
        stopLossOrderId: 555555,
        takeProfitOrderId: 666666,
      };

      mockDbQuery.findFirst.mockResolvedValue(openPosition);

      const executionReport: WsUserDataEvents['executionReport'] = {
        eventType: 'executionReport',
        eventTime: Date.now(),
        symbol: 'ETHUSDT',
        orderId: 555555,
        orderStatus: 'FILLED',
        orderType: 'STOP_MARKET',
        side: 'BUY',
        executionType: 'TRADE',
        price: '3100',
        quantity: '1',
        lastFilledPrice: '3100',
        totalFilledQuantity: '1',
        commission: '0',
        commissionAsset: 'USDT',
        transactionTime: Date.now(),
      };

      const service = binanceUserStreamService as any;
      await service.handleOrderUpdate(MOCK_WALLET.id, executionReport);

      expect(mockDbUpdate).toHaveBeenCalled();
      expect(mockBinanceClient.futuresCancelOrder).toHaveBeenCalled();
    });
  });

  describe('Balance Updates', () => {
    it('should increase balance after winning LONG trade', async () => {
      const openPosition = {
        id: 1,
        walletId: 1,
        symbol: 'BTCUSDT',
        side: 'LONG' as const,
        entryPrice: 50600,
        quantity: 0.1,
        stopLoss: 49600,
        takeProfit: 52600,
        status: 'OPEN' as const,
        entryOrderId: 111111,
        stopLossOrderId: 222222,
        takeProfitOrderId: 333333,
      };

      mockDbQuery.findFirst.mockResolvedValue(openPosition);

      const executionReport: WsUserDataEvents['executionReport'] = {
        eventType: 'executionReport',
        eventTime: Date.now(),
        symbol: 'BTCUSDT',
        orderId: 333333,
        orderStatus: 'FILLED',
        orderType: 'LIMIT',
        side: 'SELL',
        executionType: 'TRADE',
        price: '52600',
        quantity: '0.1',
        lastFilledPrice: '52600',
        totalFilledQuantity: '0.1',
        commission: '0',
        commissionAsset: 'USDT',
        transactionTime: Date.now(),
      };

      const service = binanceUserStreamService as any;
      await service.handleOrderUpdate(MOCK_WALLET.id, executionReport);

      expect(mockDbUpdate).toHaveBeenCalled();
      expect(mockBinanceClient.futuresCancelOrder).toHaveBeenCalled();
    });

    it('should decrease balance after losing LONG trade', async () => {
      const openPosition = {
        id: 1,
        walletId: 1,
        symbol: 'BTCUSDT',
        side: 'LONG' as const,
        entryPrice: 50600,
        quantity: 0.1,
        stopLoss: 49600,
        takeProfit: 52600,
        status: 'OPEN' as const,
        entryOrderId: 111111,
        stopLossOrderId: 222222,
        takeProfitOrderId: 333333,
      };

      mockDbQuery.findFirst.mockResolvedValue(openPosition);

      const executionReport: WsUserDataEvents['executionReport'] = {
        eventType: 'executionReport',
        eventTime: Date.now(),
        symbol: 'BTCUSDT',
        orderId: 222222,
        orderStatus: 'FILLED',
        orderType: 'STOP_MARKET',
        side: 'SELL',
        executionType: 'TRADE',
        price: '49600',
        quantity: '0.1',
        lastFilledPrice: '49600',
        totalFilledQuantity: '0.1',
        commission: '0',
        commissionAsset: 'USDT',
        transactionTime: Date.now(),
      };

      const service = binanceUserStreamService as any;
      await service.handleOrderUpdate(MOCK_WALLET.id, executionReport);

      expect(mockDbUpdate).toHaveBeenCalled();
      expect(mockBinanceClient.futuresCancelOrder).toHaveBeenCalled();
    });
  });

  describe('Edge Cases', () => {
    it('should handle scenario where opposite order already cancelled', async () => {
      const openPosition = {
        id: 1,
        walletId: 1,
        symbol: 'BTCUSDT',
        side: 'LONG' as const,
        entryPrice: 50600,
        quantity: 0.1,
        stopLoss: 49600,
        takeProfit: 52600,
        status: 'OPEN' as const,
        entryOrderId: 111111,
        stopLossOrderId: 222222,
        takeProfitOrderId: 333333,
      };

      mockDbQuery.findFirst.mockResolvedValue(openPosition);
      mockBinanceClient.futuresCancelOrder.mockRejectedValue(
        new Error('Order does not exist')
      );

      const executionReport: WsUserDataEvents['executionReport'] = {
        eventType: 'executionReport',
        eventTime: Date.now(),
        symbol: 'BTCUSDT',
        orderId: 333333,
        orderStatus: 'FILLED',
        orderType: 'LIMIT',
        side: 'SELL',
        executionType: 'TRADE',
        price: '52600',
        quantity: '0.1',
        lastFilledPrice: '52600',
        totalFilledQuantity: '0.1',
        commission: '0',
        commissionAsset: 'USDT',
        transactionTime: Date.now(),
      };

      const service = binanceUserStreamService as any;

      await service.handleOrderUpdate(MOCK_WALLET.id, executionReport);

      expect(mockDbUpdate).toHaveBeenCalled();
    });

    it('should not process entry order executions', async () => {
      const openPosition = {
        id: 1,
        walletId: 1,
        symbol: 'BTCUSDT',
        side: 'LONG' as const,
        entryPrice: 50600,
        quantity: 0.1,
        stopLoss: 49600,
        takeProfit: 52600,
        status: 'OPEN' as const,
        entryOrderId: 111111,
        stopLossOrderId: 222222,
        takeProfitOrderId: 333333,
      };

      mockDbQuery.findFirst.mockResolvedValue(openPosition);

      const executionReport: WsUserDataEvents['executionReport'] = {
        eventType: 'executionReport',
        eventTime: Date.now(),
        symbol: 'BTCUSDT',
        orderId: 111111,
        orderStatus: 'FILLED',
        orderType: 'MARKET',
        side: 'BUY',
        executionType: 'TRADE',
        price: '50600',
        quantity: '0.1',
        lastFilledPrice: '50600',
        totalFilledQuantity: '0.1',
        commission: '0',
        commissionAsset: 'USDT',
        transactionTime: Date.now(),
      };

      const service = binanceUserStreamService as any;
      await service.handleOrderUpdate(MOCK_WALLET.id, executionReport);

      expect(mockBinanceClient.futuresCancelOrder).not.toHaveBeenCalled();
      expect(mockDbUpdate).not.toHaveBeenCalled();
    });
  });
});
