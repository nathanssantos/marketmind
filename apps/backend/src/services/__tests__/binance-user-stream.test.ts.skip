import type { WsUserDataEvents } from 'binance';
import type { Mock } from 'vitest';
import { afterEach, beforeEach, describe, expect, it, vi } from 'vitest';
import { db } from '../../db';
import { tradeExecutions } from '../../db/schema';
import { createBinanceClient } from '../binance-client';
import { binanceUserStreamService } from '../binance-user-stream';
import { websocketService } from '../websocket';

vi.mock('../../db');
vi.mock('../binance-client');
vi.mock('../websocket');
vi.mock('binance', () => ({
  WebsocketClient: vi.fn(() => ({
    on: vi.fn(),
    subscribeUserDataStream: vi.fn(),
  })),
}));

const MOCK_WALLET = {
  id: 1,
  userId: 1,
  name: 'Test Wallet',
  exchange: 'binance',
  apiKey: 'test-key',
  apiSecret: 'test-secret',
  isTestnet: false,
  isPaperTrading: false,
  balance: 10000,
  createdAt: new Date(),
  updatedAt: new Date(),
};

const MOCK_LONG_POSITION = {
  id: 1,
  walletId: 1,
  symbol: 'BTCUSDT',
  side: 'LONG' as const,
  entryPrice: 50000,
  quantity: 0.1,
  stopLoss: 49000,
  takeProfit: 52000,
  status: 'OPEN' as const,
  entryOrderId: 111111,
  stopLossOrderId: 222222,
  takeProfitOrderId: 333333,
  createdAt: new Date(),
  updatedAt: new Date(),
};

const MOCK_SHORT_POSITION = {
  id: 2,
  walletId: 1,
  symbol: 'ETHUSDT',
  side: 'SHORT' as const,
  entryPrice: 3000,
  quantity: 1,
  stopLoss: 3100,
  takeProfit: 2900,
  status: 'OPEN' as const,
  entryOrderId: 444444,
  stopLossOrderId: 555555,
  takeProfitOrderId: 666666,
  createdAt: new Date(),
  updatedAt: new Date(),
};

describe('BinanceUserStreamService', () => {
  let mockBinanceClient: any;
  let mockWsClient: any;
  let mockDbQuery: any;
  let mockDbUpdate: any;
  let mockDbDelete: any;

  beforeEach(() => {
    vi.clearAllMocks();

    mockBinanceClient = {
      futuresUserDataStreamStart: vi.fn().mockResolvedValue({ listenKey: 'test-listen-key' }),
      futuresUserDataStreamKeepAlive: vi.fn().mockResolvedValue({}),
      futuresCancelOrder: vi.fn().mockResolvedValue({}),
    };

    mockWsClient = {
      on: vi.fn(),
      subscribeUserDataStream: vi.fn(),
    };

    (createBinanceClient as Mock).mockReturnValue(mockBinanceClient);

    mockDbQuery = {
      findMany: vi.fn().mockResolvedValue([MOCK_WALLET]),
      findFirst: vi.fn().mockResolvedValue(MOCK_LONG_POSITION),
    };

    mockDbUpdate = vi.fn().mockReturnValue({
      set: vi.fn().mockReturnValue({
        where: vi.fn().mockReturnValue({
          returning: vi.fn().mockResolvedValue([{ ...MOCK_LONG_POSITION, status: 'CLOSED' }]),
        }),
      }),
    });

    mockDbDelete = vi.fn().mockReturnValue({
      where: vi.fn().mockResolvedValue(1),
    });

    (db.query as any) = {
      wallets: mockDbQuery,
      tradeExecutions: mockDbQuery,
    };

    (db.update as any) = mockDbUpdate;
    (db.delete as any) = mockDbDelete;

    (websocketService.emitPositionUpdate as Mock) = vi.fn();
  });

  afterEach(() => {
    vi.restoreAllMocks();
  });

  describe('Service Initialization', () => {
    it('should start and subscribe to live wallets', async () => {
      await binanceUserStreamService.start();

      expect(mockDbQuery.findMany).toHaveBeenCalledWith({
        where: expect.anything(),
      });

      expect(createBinanceClient).toHaveBeenCalledWith(
        MOCK_WALLET.apiKey,
        MOCK_WALLET.apiSecret,
        false
      );

      expect(mockBinanceClient.futuresUserDataStreamStart).toHaveBeenCalled();
    });

    it('should not subscribe to paper trading wallets', async () => {
      const paperWallet = { ...MOCK_WALLET, isPaperTrading: true };
      mockDbQuery.findMany.mockResolvedValue([paperWallet]);

      await binanceUserStreamService.start();

      expect(mockBinanceClient.futuresUserDataStreamStart).not.toHaveBeenCalled();
    });

    it('should handle multiple wallets', async () => {
      const wallet2 = { ...MOCK_WALLET, id: 2, name: 'Wallet 2' };
      mockDbQuery.findMany.mockResolvedValue([MOCK_WALLET, wallet2]);

      await binanceUserStreamService.start();

      expect(mockBinanceClient.futuresUserDataStreamStart).toHaveBeenCalledTimes(2);
    });
  });

  describe('Stop Loss Order Execution', () => {
    it('should close LONG position and cancel TP when SL fills', async () => {
      const executionReport: WsUserDataEvents['executionReport'] = {
        eventType: 'executionReport',
        eventTime: Date.now(),
        symbol: 'BTCUSDT',
        orderId: 222222,
        orderStatus: 'FILLED',
        orderType: 'STOP_MARKET',
        side: 'SELL',
        executionType: 'TRADE',
        price: '49000',
        quantity: '0.1',
        lastFilledPrice: '49000',
        totalFilledQuantity: '0.1',
        commission: '0',
        commissionAsset: 'USDT',
        transactionTime: Date.now(),
      };

      mockDbQuery.findFirst.mockResolvedValue(MOCK_LONG_POSITION);

      const service = binanceUserStreamService as any;
      await service.handleOrderUpdate(MOCK_WALLET.id, executionReport);

      expect(mockDbQuery.findFirst).toHaveBeenCalledWith({
        where: expect.anything(),
      });

      expect(mockBinanceClient.futuresCancelOrder).toHaveBeenCalledWith({
        symbol: 'BTCUSDT',
        orderId: 333333,
      });

      expect(mockDbUpdate).toHaveBeenCalledWith(tradeExecutions);

      expect(websocketService.emitPositionUpdate).toHaveBeenCalledWith(
        MOCK_WALLET.userId,
        expect.objectContaining({
          status: 'CLOSED',
        })
      );
    });

    it('should calculate negative PnL for LONG position hitting SL', async () => {
      const executionReport: WsUserDataEvents['executionReport'] = {
        eventType: 'executionReport',
        eventTime: Date.now(),
        symbol: 'BTCUSDT',
        orderId: 222222,
        orderStatus: 'FILLED',
        orderType: 'STOP_MARKET',
        side: 'SELL',
        executionType: 'TRADE',
        price: '49000',
        quantity: '0.1',
        lastFilledPrice: '49000',
        totalFilledQuantity: '0.1',
        commission: '0',
        commissionAsset: 'USDT',
        transactionTime: Date.now(),
      };

      mockDbQuery.findFirst.mockResolvedValue(MOCK_LONG_POSITION);

      const service = binanceUserStreamService as any;
      await service.handleOrderUpdate(MOCK_WALLET.id, executionReport);

      const updateCall = mockDbUpdate.mock.results[0].value.set.mock.calls[0][0];
      const expectedPnL = (49000 - 50000) * 0.1;

      expect(updateCall.realizedPnL).toBeCloseTo(expectedPnL, 2);
      expect(updateCall.exitPrice).toBe(49000);
    });

    it('should close SHORT position and cancel TP when SL fills', async () => {
      const executionReport: WsUserDataEvents['executionReport'] = {
        eventType: 'executionReport',
        eventTime: Date.now(),
        symbol: 'ETHUSDT',
        orderId: 555555,
        orderStatus: 'FILLED',
        orderType: 'STOP_MARKET',
        side: 'BUY',
        executionType: 'TRADE',
        price: '3100',
        quantity: '1',
        lastFilledPrice: '3100',
        totalFilledQuantity: '1',
        commission: '0',
        commissionAsset: 'USDT',
        transactionTime: Date.now(),
      };

      mockDbQuery.findFirst.mockResolvedValue(MOCK_SHORT_POSITION);

      const service = binanceUserStreamService as any;
      await service.handleOrderUpdate(MOCK_WALLET.id, executionReport);

      expect(mockBinanceClient.futuresCancelOrder).toHaveBeenCalledWith({
        symbol: 'ETHUSDT',
        orderId: 666666,
      });

      const updateCall = mockDbUpdate.mock.results[0].value.set.mock.calls[0][0];
      const expectedPnL = (3000 - 3100) * 1;

      expect(updateCall.realizedPnL).toBeCloseTo(expectedPnL, 2);
    });
  });

  describe('Take Profit Order Execution', () => {
    it('should close LONG position and cancel SL when TP fills', async () => {
      const executionReport: WsUserDataEvents['executionReport'] = {
        eventType: 'executionReport',
        eventTime: Date.now(),
        symbol: 'BTCUSDT',
        orderId: 333333,
        orderStatus: 'FILLED',
        orderType: 'LIMIT',
        side: 'SELL',
        executionType: 'TRADE',
        price: '52000',
        quantity: '0.1',
        lastFilledPrice: '52000',
        totalFilledQuantity: '0.1',
        commission: '0',
        commissionAsset: 'USDT',
        transactionTime: Date.now(),
      };

      mockDbQuery.findFirst.mockResolvedValue(MOCK_LONG_POSITION);

      const service = binanceUserStreamService as any;
      await service.handleOrderUpdate(MOCK_WALLET.id, executionReport);

      expect(mockBinanceClient.futuresCancelOrder).toHaveBeenCalledWith({
        symbol: 'BTCUSDT',
        orderId: 222222,
      });

      const updateCall = mockDbUpdate.mock.results[0].value.set.mock.calls[0][0];
      const expectedPnL = (52000 - 50000) * 0.1;

      expect(updateCall.realizedPnL).toBeCloseTo(expectedPnL, 2);
      expect(updateCall.exitPrice).toBe(52000);
    });

    it('should calculate positive PnL for LONG position hitting TP', async () => {
      const executionReport: WsUserDataEvents['executionReport'] = {
        eventType: 'executionReport',
        eventTime: Date.now(),
        symbol: 'BTCUSDT',
        orderId: 333333,
        orderStatus: 'FILLED',
        orderType: 'LIMIT',
        side: 'SELL',
        executionType: 'TRADE',
        price: '52000',
        quantity: '0.1',
        lastFilledPrice: '52000',
        totalFilledQuantity: '0.1',
        commission: '0',
        commissionAsset: 'USDT',
        transactionTime: Date.now(),
      };

      mockDbQuery.findFirst.mockResolvedValue(MOCK_LONG_POSITION);

      const service = binanceUserStreamService as any;
      await service.handleOrderUpdate(MOCK_WALLET.id, executionReport);

      const updateCall = mockDbUpdate.mock.results[0].value.set.mock.calls[0][0];

      expect(updateCall.realizedPnL).toBeGreaterThan(0);
      expect(updateCall.status).toBe('CLOSED');
    });

    it('should close SHORT position and cancel SL when TP fills', async () => {
      const executionReport: WsUserDataEvents['executionReport'] = {
        eventType: 'executionReport',
        eventTime: Date.now(),
        symbol: 'ETHUSDT',
        orderId: 666666,
        orderStatus: 'FILLED',
        orderType: 'LIMIT',
        side: 'BUY',
        executionType: 'TRADE',
        price: '2900',
        quantity: '1',
        lastFilledPrice: '2900',
        totalFilledQuantity: '1',
        commission: '0',
        commissionAsset: 'USDT',
        transactionTime: Date.now(),
      };

      mockDbQuery.findFirst.mockResolvedValue(MOCK_SHORT_POSITION);

      const service = binanceUserStreamService as any;
      await service.handleOrderUpdate(MOCK_WALLET.id, executionReport);

      expect(mockBinanceClient.futuresCancelOrder).toHaveBeenCalledWith({
        symbol: 'ETHUSDT',
        orderId: 555555,
      });

      const updateCall = mockDbUpdate.mock.results[0].value.set.mock.calls[0][0];
      const expectedPnL = (3000 - 2900) * 1;

      expect(updateCall.realizedPnL).toBeCloseTo(expectedPnL, 2);
      expect(updateCall.realizedPnL).toBeGreaterThan(0);
    });
  });

  describe('Order Identification', () => {
    it('should ignore entry order executions', async () => {
      const executionReport: WsUserDataEvents['executionReport'] = {
        eventType: 'executionReport',
        eventTime: Date.now(),
        symbol: 'BTCUSDT',
        orderId: 111111,
        orderStatus: 'FILLED',
        orderType: 'MARKET',
        side: 'BUY',
        executionType: 'TRADE',
        price: '50000',
        quantity: '0.1',
        lastFilledPrice: '50000',
        totalFilledQuantity: '0.1',
        commission: '0',
        commissionAsset: 'USDT',
        transactionTime: Date.now(),
      };

      mockDbQuery.findFirst.mockResolvedValue(MOCK_LONG_POSITION);

      const service = binanceUserStreamService as any;
      await service.handleOrderUpdate(MOCK_WALLET.id, executionReport);

      expect(mockBinanceClient.futuresCancelOrder).not.toHaveBeenCalled();
      expect(mockDbUpdate).not.toHaveBeenCalled();
    });

    it('should ignore non-FILLED order statuses', async () => {
      const executionReport: WsUserDataEvents['executionReport'] = {
        eventType: 'executionReport',
        eventTime: Date.now(),
        symbol: 'BTCUSDT',
        orderId: 222222,
        orderStatus: 'NEW',
        orderType: 'STOP_MARKET',
        side: 'SELL',
        executionType: 'NEW',
        price: '49000',
        quantity: '0.1',
        lastFilledPrice: '0',
        totalFilledQuantity: '0',
        commission: '0',
        commissionAsset: 'USDT',
        transactionTime: Date.now(),
      };

      const service = binanceUserStreamService as any;
      await service.handleOrderUpdate(MOCK_WALLET.id, executionReport);

      expect(mockDbQuery.findFirst).not.toHaveBeenCalled();
      expect(mockBinanceClient.futuresCancelOrder).not.toHaveBeenCalled();
    });

    it('should handle unknown order IDs gracefully', async () => {
      const executionReport: WsUserDataEvents['executionReport'] = {
        eventType: 'executionReport',
        eventTime: Date.now(),
        symbol: 'BTCUSDT',
        orderId: 999999,
        orderStatus: 'FILLED',
        orderType: 'LIMIT',
        side: 'SELL',
        executionType: 'TRADE',
        price: '50000',
        quantity: '0.1',
        lastFilledPrice: '50000',
        totalFilledQuantity: '0.1',
        commission: '0',
        commissionAsset: 'USDT',
        transactionTime: Date.now(),
      };

      mockDbQuery.findFirst.mockResolvedValue(null);

      const service = binanceUserStreamService as any;

      await expect(
        service.handleOrderUpdate(MOCK_WALLET.id, executionReport)
      ).rejects.toThrow();
    });
  });

  describe('Balance Updates', () => {
    it('should update wallet balance after closing winning position', async () => {
      const executionReport: WsUserDataEvents['executionReport'] = {
        eventType: 'executionReport',
        eventTime: Date.now(),
        symbol: 'BTCUSDT',
        orderId: 333333,
        orderStatus: 'FILLED',
        orderType: 'LIMIT',
        side: 'SELL',
        executionType: 'TRADE',
        price: '52000',
        quantity: '0.1',
        lastFilledPrice: '52000',
        totalFilledQuantity: '0.1',
        commission: '0',
        commissionAsset: 'USDT',
        transactionTime: Date.now(),
      };

      mockDbQuery.findFirst.mockResolvedValue(MOCK_LONG_POSITION);

      const service = binanceUserStreamService as any;
      await service.handleOrderUpdate(MOCK_WALLET.id, executionReport);

      const expectedPnL = (52000 - 50000) * 0.1;
      const expectedBalance = MOCK_WALLET.balance + expectedPnL;

      expect(mockDbUpdate).toHaveBeenCalledTimes(2);
    });

    it('should update wallet balance after closing losing position', async () => {
      const executionReport: WsUserDataEvents['executionReport'] = {
        eventType: 'executionReport',
        eventTime: Date.now(),
        symbol: 'BTCUSDT',
        orderId: 222222,
        orderStatus: 'FILLED',
        orderType: 'STOP_MARKET',
        side: 'SELL',
        executionType: 'TRADE',
        price: '49000',
        quantity: '0.1',
        lastFilledPrice: '49000',
        totalFilledQuantity: '0.1',
        commission: '0',
        commissionAsset: 'USDT',
        transactionTime: Date.now(),
      };

      mockDbQuery.findFirst.mockResolvedValue(MOCK_LONG_POSITION);

      const service = binanceUserStreamService as any;
      await service.handleOrderUpdate(MOCK_WALLET.id, executionReport);

      const expectedPnL = (49000 - 50000) * 0.1;

      expect(expectedPnL).toBeLessThan(0);
    });
  });

  describe('WebSocket Notifications', () => {
    it('should emit position update to frontend after closure', async () => {
      const executionReport: WsUserDataEvents['executionReport'] = {
        eventType: 'executionReport',
        eventTime: Date.now(),
        symbol: 'BTCUSDT',
        orderId: 333333,
        orderStatus: 'FILLED',
        orderType: 'LIMIT',
        side: 'SELL',
        executionType: 'TRADE',
        price: '52000',
        quantity: '0.1',
        lastFilledPrice: '52000',
        totalFilledQuantity: '0.1',
        commission: '0',
        commissionAsset: 'USDT',
        transactionTime: Date.now(),
      };

      mockDbQuery.findFirst.mockResolvedValue(MOCK_LONG_POSITION);

      const service = binanceUserStreamService as any;
      await service.handleOrderUpdate(MOCK_WALLET.id, executionReport);

      expect(websocketService.emitPositionUpdate).toHaveBeenCalledWith(
        MOCK_WALLET.userId,
        expect.objectContaining({
          id: MOCK_LONG_POSITION.id,
          status: 'CLOSED',
          exitPrice: 52000,
        })
      );
    });
  });

  describe('Error Handling', () => {
    it('should handle Binance API errors when cancelling orders', async () => {
      const executionReport: WsUserDataEvents['executionReport'] = {
        eventType: 'executionReport',
        eventTime: Date.now(),
        symbol: 'BTCUSDT',
        orderId: 222222,
        orderStatus: 'FILLED',
        orderType: 'STOP_MARKET',
        side: 'SELL',
        executionType: 'TRADE',
        price: '49000',
        quantity: '0.1',
        lastFilledPrice: '49000',
        totalFilledQuantity: '0.1',
        commission: '0',
        commissionAsset: 'USDT',
        transactionTime: Date.now(),
      };

      mockDbQuery.findFirst.mockResolvedValue(MOCK_LONG_POSITION);
      mockBinanceClient.futuresCancelOrder.mockRejectedValue(
        new Error('Order already filled')
      );

      const service = binanceUserStreamService as any;

      await service.handleOrderUpdate(MOCK_WALLET.id, executionReport);

      expect(mockDbUpdate).toHaveBeenCalled();
    });

    it('should handle database errors gracefully', async () => {
      const executionReport: WsUserDataEvents['executionReport'] = {
        eventType: 'executionReport',
        eventTime: Date.now(),
        symbol: 'BTCUSDT',
        orderId: 222222,
        orderStatus: 'FILLED',
        orderType: 'STOP_MARKET',
        side: 'SELL',
        executionType: 'TRADE',
        price: '49000',
        quantity: '0.1',
        lastFilledPrice: '49000',
        totalFilledQuantity: '0.1',
        commission: '0',
        commissionAsset: 'USDT',
        transactionTime: Date.now(),
      };

      mockDbQuery.findFirst.mockRejectedValue(new Error('Database connection lost'));

      const service = binanceUserStreamService as any;

      await expect(
        service.handleOrderUpdate(MOCK_WALLET.id, executionReport)
      ).rejects.toThrow('Database connection lost');
    });
  });

  describe('ListenKey Management', () => {
    it('should refresh listenKey every 30 minutes', async () => {
      vi.useFakeTimers();

      await binanceUserStreamService.start();

      expect(mockBinanceClient.futuresUserDataStreamStart).toHaveBeenCalledTimes(1);

      vi.advanceTimersByTime(30 * 60 * 1000);

      expect(mockBinanceClient.futuresUserDataStreamKeepAlive).toHaveBeenCalled();

      vi.useRealTimers();
    });

    it('should handle listenKey refresh errors', async () => {
      mockBinanceClient.futuresUserDataStreamKeepAlive.mockRejectedValue(
        new Error('Invalid listenKey')
      );

      const service = binanceUserStreamService as any;

      await expect(
        service.refreshListenKey(MOCK_WALLET.id, 'invalid-key')
      ).rejects.toThrow();
    });
  });
});
